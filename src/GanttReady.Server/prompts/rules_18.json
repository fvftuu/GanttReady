r\u003E\r\n    \u003Ctd\u003E\u4E3B\u673A\u003C/td\u003E\r\n    \u003Ctd\u003E202X-XX-XX\u003C/td\u003E\r\n    \u003Ctd\u003E-\u003C/td\u003E\r\n    \u003Ctd\u003E0\u5929\u003C/td\u003E\r\n    \u003Ctd\u003E\uD83D\uDFE2 \u6B63\u5E38\u003C/td\u003E\r\n  \u003C/tr\u003E\r\n  \u003Ctr\u003E\r\n    \u003Ctd\u003E\u7532\u677F\u673A\u68B0\u003C/td\u003E\r\n    \u003Ctd\u003E202X-XX-XX\u003C/td\u003E\r\n    \u003Ctd\u003E-\u003C/td\u003E\r\n    \u003Ctd\u003E0\u5929\u003C/td\u003E\r\n    \u003Ctd\u003E\uD83D\uDFE2 \u6B63\u5E38\u003C/td\u003E\r\n  \u003C/tr\u003E\r\n\u003C/table\u003E\r\n\r\n\u003Ch3\u003E3.3 \u5206\u6BB5\u5EFA\u9020\u9636\u6BB5\u003C/h3\u003E\r\n\u003Cp\u003E\u8BE6\u7EC6\u8BF4\u660E\u5206\u6BB5\u5EFA\u9020\u5404\u5DE5\u5E8F\u7684\u5B8C\u6210\u60C5\u51B5\uFF1A\u003C/p\u003E\r\n\u003Cul\u003E\r\n\u003Cli\u003E\u94A2\u6750\u9884\u5904\u7406\uFF1A\u5DF2\u5B8C\u6210XX\u5428\uFF0C\u5360\u603B\u9700\u6C42\u91CF\u7684XX%\u003C/li\u003E\r\n\u003Cli\u003E\u6570\u63A7\u5207\u5272\uFF1A\u5DF2\u5B8C\u6210XX\u5428\uFF0C\u5360\u603B\u9700\u6C42\u91CF\u7684XX%\u003C/li\u003E\r\n\u003Cli\u003E\u5C0F\u7EC4\u7ACB\uFF1A\u5DF2\u5B8C\u6210XX\u4E2A\u5206\u6BB5\uFF0C\u5360\u603B\u6570\u7684XX%\u003C/li\u003E\r\n\u003Cli\u003E\u4E2D\u7EC4\u7ACB\uFF1A\u5DF2\u5B8C\u6210XX\u4E2A\u5206\u6BB5\uFF0C\u5360\u603B\u6570\u7684XX%\u003C/li\u003E\r\n\u003Cli\u003E\u5927\u7EC4\u7ACB\u6210\u578B\uFF1A\u5DF2\u5B8C\u6210XX\u4E2A\u5206\u6BB5\uFF0C\u5360\u603B\u6570\u7684XX%\u003C/li\u003E\r\n\u003Cli\u003E\u710A\u63A5\u4E00\u6B21\u5408\u683C\u7387\uFF1AXX%\uFF08\u76EE\u6807\u226597%\uFF09\u003C/li\u003E\r\n\u003C/ul\u003E\r\n\r\n\u003Ch3\u003E3.4 \u8239\u53F0\u5408\u62E2\u9636\u6BB5\u003C/h3\u003E\r\n\u003Cp\u003E\u8BF4\u660E\u8239\u53F0\u5408\u62E2\u7684\u8FDB\u5EA6\u60C5\u51B5\uFF1A\u003C/p\u003E\r\n\u003Cul\u003E\r\n\u003Cli\u003E\u5DF2\u540A\u88C5\u5206\u6BB5\uFF1AXX\u4E2A\uFF0C\u5360\u603B\u6BB5\u6570\u7684XX%\u003C/li\u003E\r\n\u003Cli\u003E\u5206\u6BB5\u540A\u88C5\u5B9A\u4F4D\u5B8C\u6210\u7387\uFF1AXX%\u003C/li\u003E\r\n\u003Cli\u003E\u5927\u5408\u62E2\u710A\u63A5\u5B8C\u6210\u7387\uFF1AXX%\u003C/li\u003E\r\n\u003Cli\u003E\u4E3B\u8239\u4F53\u6210\u578B\u8FDB\u5EA6\uFF1AXX%\u003C/li\u003E\r\n\u003C/ul\u003E\r\n\r\n\u003Ch2\u003E\u56DB\u3001\u95EE\u9898\u4E0E\u98CE\u9669\u5206\u6790\u003C/h2\u003E\r\n\u003Ch3\u003E4.1 \u5173\u952E\u6EDE\u540E\u4EFB\u52A1\u6E05\u5355\u003C/h3\u003E\r\n\u003Cp\u003E\u4EC5\u663E\u793A\u5F71\u54CD\u4EA4\u8239\u65E5\u671F\u7684\u6EDE\u540E\u4EFB\u52A1\uFF0C\u6309\u5F71\u54CD\u7A0B\u5EA6\u6392\u5E8F\uFF1A\u003C/p\u003E\r\n\u003Ctable\u003E\r\n  \u003Ctr\u003E\r\n    \u003Cth\u003E\u4EFB\u52A1\u540D\u79F0\u003C/th\u003E\r\n    \u003Cth\u003E\u8D1F\u8D23\u90E8\u95E8\u003C/th\u003E\r\n    \u003Cth\u003E\u6EDE\u540E\u5929\u6570\u003C/th\u003E\r\n    \u003Cth\u003E\u5BF9\u4EA4\u8239\u7684\u5F71\u54CD\u003C/th\u003E\r\n    \u003Cth\u003E\u521D\u6B65\u539F\u56E0\u63A8\u65AD\u003C/th\u003E\r\n  \u003C/tr\u003E\r\n  \u003Ctr\u003E\r\n    \u003Ctd\u003E\u8F6E\u673A\u4E0E\u7535\u6C14\u8BE6\u7EC6\u8BBE\u8BA1\u003C/td\u003E\r\n    \u003Ctd\u003E\u8BBE\u8BA1\u90E8\u003C/td\u003E\r\n    \u003Ctd\u003E1\u5929\u003C/td\u003E\r\n    \u003Ctd\u003E\u5BFC\u81F4\u540E\u7EED\u8BBE\u5907\u91C7\u8D2D\u6EDE\u540E1\u5929\u003C/td\u003E\r\n    \u003Ctd\u003E\u56FE\u7EB8\u8BC4\u5BA1\u610F\u89C1\u8F83\u591A\u003C/td\u003E\r\n  \u003C/tr\u003E\r\n\u003C/table\u003E\r\n\r\n\u003Ch3\u003E4.2 \u4E3B\u8981\u95EE\u9898\u8BF4\u660E\u003C/h3\u003E\r\n\u003Cp\u003E\u8BE6\u7EC6\u8BF4\u660E\u6700\u4E25\u91CD\u76842-3\u4E2A\u95EE\u9898\uFF1A\u003C/p\u003E\r\n\u003Cul\u003E\r\n\u003Cli\u003E\u95EE\u9898\u63CF\u8FF0\u003C/li\u003E\r\n\u003Cli\u003E\u4EA7\u751F\u539F\u56E0\u003C/li\u003E\r\n\u003Cli\u003E\u5DF2\u7ECF\u91C7\u53D6\u7684\u63AA\u65BD\u003C/li\u003E\r\n\u003Cli\u003E\u5BF9\u9879\u76EE\u7684\u5F71\u54CD\u7A0B\u5EA6\u003C/li\u003E\r\n\u003C/ul\u003E\r\n\r\n\u003Ch3\u003E4.3 \u98CE\u9669\u8BC4\u4F30\u003C/h3\u003E\r\n\u003Cp\u003E\u8BC4\u4F30\u5F53\u524D\u9879\u76EE\u5B58\u5728\u7684\u4E3B\u8981\u98CE\u9669\uFF1A\u003C/p\u003E\r\n\u003Ctable\u003E\r\n  \u003Ctr\u003E\r\n    \u003Cth\u003E\u98CE\u9669\u63CF\u8FF0\u003C/th\u003E\r\n    \u003Cth\u003E\u53D1\u751F\u6982\u7387\u003C/th\u003E\r\n    \u003Cth\u003E\u5F71\u54CD\u7A0B\u5EA6\u003C/th\u003E\r\n    \u003Cth\u003E\u98CE\u9669\u7B49\u7EA7\u003C/th\u003E\r\n    \u003Cth\u003E\u5E94\u5BF9\u63AA\u65BD\u003C/th\u003E\r\n  \u003C/tr\u003E\r\n  \u003Ctr\u003E\r\n    \u003Ctd\u003E\u94A2\u6750\u4EF7\u683C\u4E0A\u6DA8\u003C/td\u003E\r\n    \u003Ctd\u003E\u4E2D\u003C/td\u003E\r\n    \u003Ctd\u003E\u4E2D\u003C/td\u003E\r\n    \u003Ctd\u003E\uD83D\uDFE1 \u4E2D\u98CE\u9669\u003C/td\u003E\r\n    \u003Ctd\u003E\u63D0\u524D\u9501\u5B9A\u94A2\u6750\u4EF7\u683C\u003C/td\u003E\r\n  \u003C/tr\u003E\r\n  \u003Ctr\u003E\r\n    \u003Ctd\u003E\u4E3B\u673A\u5230\u8D27\u5EF6\u8FDF\u003C/td\u003E\r\n    \u003Ctd\u003E\u4F4E\u003C/td\u003E\r\n    \u003Ctd\u003E\u9AD8\u003C/td\u003E\r\n    \u003Ctd\u003E\uD83D\uDFE1 \u4E2D\u98CE\u9669\u003C/td\u003E\r\n    \u003Ctd\u003E\u6D3E\u4E13\u4EBA\u9A7B\u5382\u50AC\u4EA4\u003C/td\u003E\r\n  \u003C/tr\u003E\r\n  \u003Ctr\u003E\r\n    \u003Ctd\u003E\u6076\u52A3\u5929\u6C14\u5F71\u54CD\u8239\u53F0\u4F5C\u4E1A\u003C/td\u003E\r\n    \u003Ctd\u003E\u4E2D\u003C/td\u003E\r\n    \u003Ctd\u003E\u4E2D\u003C/td\u003E\r\n    \u003Ctd\u003E\uD83D\uDFE1 \u4E2D\u98CE\u9669\u003C/td\u003E\r\n    \u003Ctd\u003E\u8C03\u6574\u65BD\u5DE5\u8BA1\u5212\uFF0C\u505A\u597D\u9632\u96E8\u63AA\u65BD\u003C/td\u003E\r\n  \u003C/tr\u003E\r\n\u003C/table\u003E\r\n\r\n\u003Ch2\u003E\u4E94\u3001\u4E0B\u4E00\u6B65\u884C\u52A8\u8BA1\u5212\u003C/h2\u003E\r\n\u003Ch3\u003E5.1 \u4E0B\u5468\u6838\u5FC3\u76EE\u6807\u003C/h3\u003E\r\n\u003Cp\u003E\u660E\u786E\u4E0B\u4E00\u4E2A\u5468\u671F\u7684\u6838\u5FC3\u76EE\u6807\uFF1A\u003C/p\u003E\r\n\u003Cul\u003E\r\n\u003Cli\u003E\u6574\u4F53\u8FDB\u5EA6\u76EE\u6807\uFF1A\u8FBE\u5230XX%\u003C/li\u003E\r\n\u003Cli\u003E\u8BBE\u8BA1\u76EE\u6807\uFF1A\u5B8C\u6210XX\u56FE\u7EB8\u7684\u8BBE\u8BA1\u548C\u8BC4\u5BA1\u003C/li\u003E\r\n\u003Cli\u003E\u91C7\u8D2D\u76EE\u6807\uFF1A\u5B8C\u6210XX\u7269\u8D44\u7684\u91C7\u8D2D\u003C/li\u003E\r\n\u003Cli\u003E\u5EFA\u9020\u76EE\u6807\uFF1A\u5B8C\u6210XX\u4E2A\u5206\u6BB5\u7684\u5EFA\u9020\u003C/li\u003E\r\n\u003C/ul\u003E\r\n\r\n\u003Ch3\u003E5.2 \u91CD\u70B9\u5DE5\u4F5C\u5B89\u6392\u003C/h3\u003E\r\n\u003Cp\u003E\u5217\u51FA\u4E0B\u5468\u7684\u91CD\u70B9\u5DE5\u4F5C\u4EFB\u52A1\uFF1A\u003C/p\u003E\r\n\u003Ctable\u003E\r\n  \u003Ctr\u003E\r\n    \u003Cth\u003E\u5DE5\u4F5C\u5185\u5BB9\u003C/th\u003E\r\n    \u003Cth\u003E\u8D1F\u8D23\u90E8\u95E8\u003C/th\u003E\r\n    \u003Cth\u003E\u8BA1\u5212\u5B8C\u6210\u65F6\u95F4\u003C/th\u003E\r\n    \u003Cth\u003E\u4EA4\u4ED8\u7269\u003C/th\u003E\r\n  \u003C/tr\u003E\r\n  \u003Ctr\u003E\r\n    \u003Ctd\u003E\u5B8C\u6210\u8F6E\u673A\u4E0E\u7535\u6C14\u8BE6\u7EC6\u8BBE\u8BA1\u003C/td\u003E\r\n    \u003Ctd\u003E\u8BBE\u8BA1\u90E8\u003C/td\u003E\r\n    \u003Ctd\u003E202X-XX-XX\u003C/td\u003E\r\n    \u003Ctd\u003E\u5B8C\u6574\u7684\u65BD\u5DE5\u56FE\u7EB8\u003C/td\u003E\r\n  \u003C/tr\u003E\r\n  \u003Ctr\u003E\r\n    \u003Ctd\u003E\u5B8C\u6210\u7B2C\u4E00\u6279\u8239\u677F\u5230\u8D27\u9A8C\u6536\u003C/td\u003E\r\n    \u003Ctd\u003E\u7269\u8D44\u90E8\u003C/td\u003E\r\n    \u003Ctd\u003E202X-XX-XX\u003C/td\u003E\r\n    \u003Ctd\u003E\u94A2\u6750\u9A8C\u6536\u62A5\u544A\u003C/td\u003E\r\n  \u003C/tr\u003E\r\n\u003C/table\u003E\r\n\r\n\u003Ch3\u003E5.3 \u95EE\u9898\u6574\u6539\u4E0E\u8D76\u5DE5\u8BA1\u5212\u003C/h3\u003E\r\n\u003Cp\u003E\u9488\u5BF9\u6EDE\u540E\u4EFB\u52A1\u548C\u95EE\u9898\uFF0C\u5236\u5B9A\u5177\u4F53\u7684\u6574\u6539\u548C\u8D76\u5DE5\u63AA\u65BD\uFF1A\u003C/p\u003E\r\n\u003Ctable\u003E\r\n  \u003Ctr\u003E\r\n    \u003Cth\u003E\u95EE\u9898\u003C/th\u003E\r\n    \u003Cth\u003E\u6574\u6539\u63AA\u65BD\u003C/th\u003E\r\n    \u003Cth\u003E\u8D1F\u8D23\u4EBA\u003C/th\u003E\r\n    \u003Cth\u003E\u5B8C\u6210\u65F6\u95F4\u003C/th\u003E\r\n    \u003Cth\u003E\u9884\u671F\u6548\u679C\u003C/th\u003E\r\n  \u003C/tr\u003E\r\n  \u003Ctr\u003E\r\n    \u003Ctd\u003E\u8F6E\u673A\u4E0E\u7535\u6C14\u8BE6\u7EC6\u8BBE\u8BA1\u6EDE\u540E1\u5929\u003C/td\u003E\r\n    \u003Ctd\u003E\u589E\u52A0\u8BBE\u8BA1\u4EBA\u5458\uFF0C\u52A0\u73ED\u8D76\u5DE5\uFF0C\u52A0\u5FEB\u56FE\u7EB8\u8BC4\u5BA1\u003C/td\u003E\r\n    \u003Ctd\u003E\u5F20\u4E09\u003C/td\u003E\r\n    \u003Ctd\u003E202X-XX-XX\u003C/td\u003E\r\n    \u003Ctd\u003E\u8FFD\u56DE1\u5929\u5DE5\u671F\u003C/td\u003E\r\n  \u003C/tr\u003E\r\n\u003C/table\u003E\r\n\r\n\u003Ch3\u003E5.4 \u9700\u8981\u534F\u8C03\u7684\u652F\u6301\u003C/h3\u003E\r\n\u003Cp\u003E\u5217\u51FA\u9700\u8981\u4E0A\u7EA7\u6216\u5176\u4ED6\u90E8\u95E8\u534F\u8C03\u89E3\u51B3\u7684\u4E8B\u9879\uFF1A\u003C/p\u003E\r\n\u003Cul\u003E\r\n\u003Cli\u003E\u9700\u8981\u534F\u8C03\u589E\u52A0XX\u540D\u8BBE\u8BA1\u4EBA\u5458\u003C/li\u003E\r\n\u003Cli\u003E\u9700\u8981\u516C\u53F8\u534F\u52A9\u4E0E\u4E3B\u673A\u4F9B\u5E94\u5546\u6C9F\u901A\u4EA4\u8D27\u4E8B\u5B9C\u003C/li\u003E\r\n\u003Cli\u003E\u9700\u8981\u8239\u7EA7\u793E\u5B89\u6392XX\u56FE\u7EB8\u7684\u8BC4\u5BA1\u003C/li\u003E\r\n\u003C/ul\u003E\r\n\r\n\u003Ch2\u003E\u516D\u3001\u5206\u5C42\u7EA7\u6458\u8981\u003C/h2\u003E\r\n\u003Ch3\u003E6.1 \u6267\u884C\u5C42\u6458\u8981\uFF08\u8F66\u95F4/\u73ED\u7EC4\uFF09\u003C/h3\u003E\r\n\u003Cul\u003E\r\n\u003Cli\u003E\u4F60\u90E8\u95E8\u8D1F\u8D23\u7684\u4EFB\u52A1\u4E2D\uFF0C\u6709XX\u4E2A\u5DF2\u6EDE\u540E\uFF0CXX\u4E2A\u5373\u5C06\u5230\u671F\u003C/li\u003E\r\n\u003Cli\u003E\u4E0B\u5468\u4F60\u7684\u4E3B\u8981\u4EFB\u52A1\u662F\uFF1A[\u4EFB\u52A11\u3001\u4EFB\u52A12]\u003C/li\u003E\r\n\u003Cli\u003E\u9700\u8981\u91CD\u70B9\u5173\u6CE8\u7684\u8D28\u91CF\u5B89\u5168\u95EE\u9898\uFF1A[\u95EE\u98981\u3001\u95EE\u98982]\u003C/li\u003E\r\n\u003C/ul\u003E\r\n\r\n\u003Ch3\u003E6.2 \u7BA1\u7406\u5C42\u6458\u8981\uFF08\u9879\u76EE\u7ECF\u7406/\u751F\u4EA7\u7ECF\u7406\uFF09\u003C/h3\u003E\r\n\u003Cul\u003E\r\n\u003Cli\u003E\u9879\u76EE\u6574\u4F53\u72B6\u6001\uFF1A\uD83D\uDFE2\u6B63\u5E38/\uD83D\uDFE1\u9884\u8B66/\uD83D\uDD34\u7D27\u6025\u003C/li\u003E\r\n\u003Cli\u003E\u5173\u952E\u8DEF\u5F84\u504F\u5DEE\uFF1A\u00B1X\u5929\uFF0C\u9884\u6D4B\u4EA4\u8239\u65E5\u671F\u504F\u5DEE\uFF1A\u00B1X\u5929\u003C/li\u003E\r\n\u003Cli\u003E\u4E3B\u8981\u95EE\u9898\uFF1A[\u95EE\u98981\u3001\u95EE\u98982]\u003C/li\u003E\r\n\u003Cli\u003E\u9700\u8981\u4F60\u534F\u8C03\u7684\u4E8B\u9879\uFF1A[\u4E8B\u98791\u3001\u4E8B\u98792]\u003C/li\u003E\r\n\u003C/ul\u003E\r\n\r\n\u003Ch3\u003E6.3 \u51B3\u7B56\u5C42\u6458\u8981\uFF08\u8239\u5382\u9886\u5BFC/\u8239\u4E1C\u4EE3\u8868\uFF09\u003C/h3\u003E\r\n\u003Cul\u003E\r\n\u003Cli\u003E\u4E00\u53E5\u8BDD\u7ED3\u8BBA\uFF1A10000TEU\u96C6\u88C5\u7BB1\u8239H1234\u53F7\u5F53\u524D[\u6B63\u5E38/\u9884\u8B66/\u7D27\u6025]\uFF0C\u9884\u8BA1[\u63D0\u524D/\u5EF6\u8BEF]X\u5929\u4EA4\u8239\u003C/li\u003E\r\n\u003Cli\u003E\u6838\u5FC3\u98CE\u9669\uFF1A[\u98CE\u96691\u3001\u98CE\u96692]\u003C/li\u003E\r\n\u003Cli\u003E\u662F\u5426\u9700\u8981\u5347\u7EA7\u5E72\u9884\uFF1A\u662F/\u5426\u003C/li\u003E\r\n\u003Cli\u003E\u5EFA\u8BAE\u51B3\u7B56\uFF1A[\u7B80\u8981\u8BF4\u660E]\u003C/li\u003E\r\n\u003C/ul\u003E\r\n\r\n## \u8BED\u8A00\u8981\u6C42\r\n- \u7528\u4E2D\u6587\r\n- \u7ED3\u8BBA\u5148\u884C\uFF0C\u5148\u8BB2\u6838\u5FC3\u518D\u8BB2\u7EC6\u8282\r\n- \u6240\u6709\u6570\u636E\u5FC5\u987B\u51C6\u786E\uFF0C\u57FA\u4E8E\u7518\u7279\u56FE\u6570\u636E\u8BA1\u7B97\r\n- \u6BCF\u6761\u5EFA\u8BAE\u90FD\u8981\u5177\u4F53\u53EF\u6267\u884C\uFF0C\u907F\u514D\u7A7A\u8BDD\u5957\u8BDD\r\n- \u9002\u5F53\u4F7F\u7528 \uD83D\uDFE2\uD83D\uDFE1\uD83D\uDD34 \u6807\u6CE8\u72B6\u6001\r\n- \u6280\u672F\u672F\u8BED\u51C6\u786E\uFF0C\u7B26\u5408\u8239\u8236\u5EFA\u9020\u884C\u4E1A\u89C4\u8303\r\n- \u6D89\u53CA\u8239\u4E1C\u548C\u8239\u7EA7\u793E\u7684\u5185\u5BB9\u5FC5\u987B\u6B63\u5F0F\u4E25\u8C28\r\n**\u53EA\u8F93\u51FA HTML \u5185\u5BB9\uFF0C\u4E0D\u8981\u7528 \u0060\u0060\u0060html \u5305\u88F9\u3002\u4E0D\u8981\u6709 html/head/body \u6807\u7B7E\u3002**","IsActive":true}]