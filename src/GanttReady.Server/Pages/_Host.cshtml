@page "/"
@namespace GanttReady.Server.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>GanttReady - 进度计划管理系统</title>
    <base href="~/" />
    <link href="css/site.css?v=20260525" rel="stylesheet" />
    <link href="css/open-iconic/font/css/open-iconic-bootstrap.min.css" rel="stylesheet" />
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
    </style>
    <!-- Index page globals: must load before Blazor render to avoid race -->
    <script>
        window.setCheckedProject = function(id) { localStorage.setItem('ganttready_checked', id); };
        window.getCheckedProject = function() { return localStorage.getItem('ganttready_checked') || 0; };
        window.navToChecked = function(page) {
            // 优先从当前 URL 提取项目 ID，fallback 到 localStorage
            var m = window.location.pathname.match(/\/project\/(\d+)/);
            var id = m ? m[1] : localStorage.getItem('ganttready_checked');
            if (id > 0) { window.location.href = '/project/' + id + '/' + page; }
            else { window.location.href = '/#select-project'; }
        };
    </script>
</head>
<body>
    <app>
        <component type="typeof(App)" render-mode="Server" />
    </app>

    <div id="blazor-error-ui" style="display:none; background:#fff2f0; padding:16px; border:1px solid #ffccc7; border-radius:4px;">
        <span style="color:#ff4d4f;">发生错误，页面可能无响应。</span>
        <a href="" class="reload" style="margin-left:16px;">重新加载</a>
    </div>

    <!-- GanttReady scripts -->
    <script src="js/logic-diagram.js?v=1.0"></script>
    <script src="js/netplan.js?v=20260531a"></script>
    <script src="_framework/blazor.server.js"></script>
<script>
document.addEventListener("DOMContentLoaded", function() {
  var els = document.querySelectorAll(".page-header, .gantt-container");
  els.forEach(function(el) {
    var walker = document.createTreeWalker(el, 4, null, false);
    while (walker.nextNode()) {
      var n = walker.currentNode;
      if (n.textContent.trim() === String.fromCharCode(125)) {
        var p = n.parentElement;
        if (p && p.textContent.trim() === String.fromCharCode(125)) p.remove();
      }
    }
  });
});
</script>

<!-- Bootstrap Icons (MIT) -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<!-- Chart.js for resource histogram -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/jspdf@2.5.1/dist/jspdf.umd.min.js"></script>

</body>
</html>
