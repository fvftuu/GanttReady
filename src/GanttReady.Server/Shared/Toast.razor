@inject ToastService ToastService
@implements IDisposable

<div class="toast-container" id="toast-container">
    @foreach (var toast in _toasts)
    {
        <div class="toast toast-@toast.Type.ToString().ToLower() @(toast == _toasts.First() ? "toast-enter" : "")" @key="toast.Id">
            <span class="toast-icon">
                @if (toast.Type == ToastType.Success) { <i class="bi bi-shield-check"></i> }
                else if (toast.Type == ToastType.Error) { <i class="bi bi-x-octagon"></i> }
                else if (toast.Type == ToastType.Warning) { <i class="bi bi-exclamation-triangle"></i> }
                else if (toast.Type == ToastType.Info) { <i class="bi bi-shield-exclamation"></i> }
            </span>
            <span class="toast-msg">@toast.Message</span>
            <button class="toast-close" @onclick="() => RemoveToast(toast.Id)"><i class="bi bi-x-lg"></i></button>
        </div>
    }
</div>

@code {
    private List<ToastMessage> _toasts = new();

    protected override void OnInitialized()
    {
        ToastService.OnShow += HandleToast;
    }

    private void HandleToast(ToastMessage msg)
    {
        _toasts.Add(msg);
        InvokeAsync(StateHasChanged);

        _ = Task.Run(async () =>
        {
            await Task.Delay(msg.DurationMs);
            await InvokeAsync(() => RemoveToast(msg.Id));
        });
    }

    private void RemoveToast(string id)
    {
        _toasts.RemoveAll(t => t.Id == id);
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ToastService.OnShow -= HandleToast;
    }
}
