@inject NavigationManager NavManager
@implements IDisposable

<div class="top-row pl-4 navbar navbar-dark" style="display:flex;align-items:center;padding:0 12px;">
    <span style="display:flex;align-items:center;gap:6px;font-size:15px;font-weight:600;color:#fff;">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="flex-shrink:0;">
            <circle cx="12" cy="8" r="3" fill="#fff" opacity="0.9"/>
            <circle cx="5" cy="16" r="2" fill="#fff" opacity="0.6"/>
            <circle cx="19" cy="16" r="2" fill="#fff" opacity="0.6"/>
            <line x1="9.5" y1="10.5" x2="6.5" y2="14.5" stroke="#fff" stroke-width="1.5" opacity="0.7"/>
            <line x1="14.5" y1="10.5" x2="17.5" y2="14.5" stroke="#fff" stroke-width="1.5" opacity="0.7"/>
        </svg>
        GanttReady
    </span>
    <span style="font-size:11px;color:rgba(255,255,255,0.6);margin-left:6px;">v1.7j</span>
    <div style="flex:1;"></div>
    <button class="navbar-toggler" @onclick="ToggleNavMenu">
        <span class="navbar-toggler-icon"></span>
    </button>
</div>

<div class="@NavMenuCssClass" @onclick="ToggleNavMenu">
    <ul class="nav flex-column">
        <li class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <i class="bi bi-buildings"></i> 首页
            </NavLink>
        </li>
        <li class="nav-divider" style="height:1px;background:var(--border);margin:6px 12px;"></li>
        @{
            var pid = GetCurrentProjectId();
        }
        @if (pid.HasValue)
        {
            <li class="nav-item px-3">
                <NavLink class="nav-link" href="@($"/project/{pid.Value}/gantt")">
                    <i class="bi bi-bar-chart-steps"></i> 甘特图
                </NavLink>
            </li>
            <li class="nav-item px-3">
                <NavLink class="nav-link" href="@($"/project/{pid.Value}/analysis")">
                    <i class="bi bi-activity"></i> 分析
                </NavLink>
            </li>
            <li class="nav-item px-3">
                <NavLink class="nav-link" href="@($"/project/{pid.Value}/resources")">
                    <i class="bi bi-truck"></i> 资源
                </NavLink>
            </li>
            <li class="nav-divider" style="height:1px;background:var(--border);margin:6px 12px;"></li>
        }
        <li class="nav-item px-3">
            <NavLink class="nav-link" href="analysis">
                <i class="bi bi-clipboard-pulse"></i> 多项目分析
            </NavLink>
        </li>
    </ul>
</div>

@code {
    private bool collapseNavMenu = true;

    private string NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    protected override void OnInitialized()
    {
        NavManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        StateHasChanged();
    }

    public void Dispose()
    {
        NavManager.LocationChanged -= OnLocationChanged;
    }

    private int? GetCurrentProjectId()
    {
        var uri = NavManager.Uri;
        var idx = uri.IndexOf("/project/", StringComparison.OrdinalIgnoreCase);
        if (idx < 0) return null;
        var after = uri[(idx + 9)..];
        var end = after.IndexOfAny(new[] { '/', '?' });
        if (end < 0) end = after.Length;
        if (int.TryParse(after[..end], out var id))
            return id;
        return null;
    }
}