@inject NavigationManager NavManager
@implements IDisposable

<div class="top-row pl-4 navbar navbar-dark">
    <a class="navbar-brand" href="">NetPlan.Server</a>
    <button class="navbar-toggler" @onclick="ToggleNavMenu">
        <span class="navbar-toggler-icon"></span>
    </button>
</div>

<div class="@NavMenuCssClass" @onclick="ToggleNavMenu">
    <ul class="nav flex-column">
        <li class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="oi oi-home" aria-hidden="true"></span> 🏠 首页
            </NavLink>
        </li>
        <li class="nav-divider" style="height:1px;background:var(--border);margin:6px 12px;"></li>
        @{
            var pid = GetCurrentProjectId();
        }
        @if (pid.HasValue)
        {
            <li class="nav-item px-3">
                <NavLink class="nav-link" href="@($"/project/{pid.Value}/gantt")">
                    <span class="oi oi-calendar" aria-hidden="true"></span> 📅 甘特图
                </NavLink>
            </li>
            <li class="nav-item px-3">
                <NavLink class="nav-link" href="@($"/project/{pid.Value}/analysis")">
                    <span class="oi oi-graph" aria-hidden="true"></span> 📊 分析
                </NavLink>
            </li>
            <li class="nav-item px-3">
                <NavLink class="nav-link" href="@($"/project/{pid.Value}/resources")">
                    <span class="oi oi-people" aria-hidden="true"></span> 👥 资源
                </NavLink>
            </li>
            <li class="nav-divider" style="height:1px;background:var(--border);margin:6px 12px;"></li>
        }
        <li class="nav-item px-3">
            <NavLink class="nav-link" href="analysis">
                <span class="oi oi-graph" aria-hidden="true"></span> 📊 多项目分析
            </NavLink>
        </li>
    </ul>
</div>

@code {
    private bool collapseNavMenu = true;

    private string NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    protected override void OnInitialized()
    {
        NavManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        StateHasChanged();
    }

    public void Dispose()
    {
        NavManager.LocationChanged -= OnLocationChanged;
    }

    private int? GetCurrentProjectId()
    {
        var uri = NavManager.Uri;
        var idx = uri.IndexOf("/project/", StringComparison.OrdinalIgnoreCase);
        if (idx < 0) return null;
        var after = uri[(idx + 9)..];
        var end = after.IndexOfAny(new[] { '/', '?' });
        if (end < 0) end = after.Length;
        if (int.TryParse(after[..end], out var id))
            return id;
        return null;
    }
}