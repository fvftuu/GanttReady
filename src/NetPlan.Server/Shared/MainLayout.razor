    private List<AiToolCall>? TryParseToolCallsFromText(string? text)
    {
        if (string.IsNullOrWhiteSpace(text)) return null;
        var calls = new List<AiToolCall>();

        // Pattern 1: XML <invoke name="xxx"><parameter name="yyy">val</parameter></invoke>
        //          Or:  <tool_calls><invoke name="xxx"><parameter name="yyy">val</parameter></invoke></tool_calls>
        try
        {
            // First unwrap <tool_calls>...</tool_calls> wrapper if present
            var tcMatch = System.Text.RegularExpressions.Regex.Match(text,
                @"<\s*tool_calls\s*>(.*?)<\s*/\s*tool_calls\s*>",
                System.Text.RegularExpressions.RegexOptions.Singleline);
            var innerXml = tcMatch.Success ? tcMatch.Groups[1].Value : text;

            var invokeRegex = new System.Text.RegularExpressions.Regex(
                @"<\s*invoke\s+name\s*=\s*""(\w+)""\s*>(.*?)<\s*/\s*invoke\s*>",
                System.Text.RegularExpressions.RegexOptions.Singleline);
            var invokeMatch = invokeRegex.Match(innerXml);
            if (invokeMatch.Success)
            {
                var rawName = invokeMatch.Groups[1].Value;
                if (_toolNameMap.TryGetValue(rawName, out var mappedName))
                {
                    var paramsXml = invokeMatch.Groups[2].Value;
                    var args = new Dictionary<string, object>();
                    var paramRegex = new System.Text.RegularExpressions.Regex(
                        @"<\s*parameter\s+name\s*=\s*""(\w+)""[^>]*>(.*?)<\s*/\s*parameter\s*>",
                        System.Text.RegularExpressions.RegexOptions.Singleline);
                    foreach (System.Text.RegularExpressions.Match m in paramRegex.Matches(paramsXml))
                    {
                        var rawParam = m.Groups[1].Value;
                        var val = m.Groups[2].Value.Trim();
                        if (_paramNameMap.TryGetValue(rawParam, out var mappedParam))
                        {
                            // Try to parse as number or bool
                            if (int.TryParse(val, out var intVal)) args[mappedParam] = intVal;
                            else if (bool.TryParse(val, out var boolVal)) args[mappedParam] = boolVal;
                            else args[mappedParam] = val;
                        }
                    }
                    calls.Add(new AiToolCall
                    {
                        Id = $"call_txt_{Guid.NewGuid():N}",
                        FunctionName = mappedName,
                        FunctionArguments = System.Text.Json.JsonSerializer.Serialize(args)
                    });
                    return calls;
                }
            }
        }
        catch { }

        // Pattern 2: function_name(param1: val1, param2: val2)
        try
        {
            var fnRegex = new System.Text.RegularExpressions.Regex(
                @"(\w+)\s*\(\s*([^)]*)\s*\)");
            foreach (System.Text.RegularExpressions.Match m in fnRegex.Matches(text))
            {
                var rawName = m.Groups[1].Value;
                if (_toolNameMap.TryGetValue(rawName, out var mappedName))
                {
                    var args = new Dictionary<string, object>();
                    var paramText = m.Groups[2].Value;
                    var pairs = paramText.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
                    foreach (var pair in pairs)
                    {
                        var eqIdx = pair.IndexOf(':');
                        if (eqIdx < 0) eqIdx = pair.IndexOf('=');
                        if (eqIdx > 0)
                        {
                            var k = pair[..eqIdx].Trim();
                            var v = pair[(eqIdx + 1)..].Trim().Trim('"').Trim('\'');
                            if (_paramNameMap.TryGetValue(k, out var mappedK))
                            {
                                if (int.TryParse(v, out var intVal)) args[mappedK] = intVal;
                                else if (bool.TryParse(v, out var boolVal)) args[mappedK] = boolVal;
                                else args[mappedK] = v;
                            }
                        }
                    }
                    calls.Add(new AiToolCall
                    {
                        Id = $"call_txt_{Guid.NewGuid():N}",
                        FunctionName = mappedName,
                        FunctionArguments = System.Text.Json.JsonSerializer.Serialize(args)
                    });
                }
            }
            if (calls.Count > 0) return calls;
        }
        catch { }

        return null;
    }

    private string? StripToolCallText(string? text)
    {
        if (string.IsNullOrWhiteSpace(text)) return text;
        // Remove XML invoke blocks
        text = System.Text.RegularExpressions.Regex.Replace(
            text,
            @"<\s*invoke\s+name\s*=\s*""(\w+)""\s*>.*?<\s*/\s*invoke\s*>",
            "",
            System.Text.RegularExpressions.RegexOptions.Singleline);
        // Remove function call patterns (but keep the text around them)
        text = System.Text.RegularExpressions.Regex.Replace(
            text,
            @"(\w+)\s*\([^)]*\)\s*",
            m =>
            {
                var name = m.Groups[1].Value;
                return _toolNameMap.ContainsKey(name) ? "" : m.Value;
            });
        return text.Trim();
    }

    // ===== 参数获取辅助方法（支持多名称变体） =====
    private static string? GetArgString(Dictionary<string, object> args, string primaryKey)
    {
        // 尝试主键 + 常见变体
        var keys = new[] { primaryKey, ToSnakeCase(primaryKey), ToUnderscore(primaryKey) };
        foreach (var k in keys)
        {
            if (args.TryGetValue(k, out var v) && v != null)
            {
                var s = JsonElementToString(v);
                if (!string.IsNullOrEmpty(s)) return s;
            }
        }
        // 也尝试大小写不敏感
        foreach (var kv in args)
        {
            if (string.Equals(kv.Key, primaryKey, StringComparison.OrdinalIgnoreCase) ||
                string.Equals(kv.Key, primaryKey.Replace("_", ""), StringComparison.OrdinalIgnoreCase))
            {
                var s = JsonElementToString(kv.Value);
                if (!string.IsNullOrEmpty(s)) return s;
            }
        }
        return null;
    }

    private static string? JsonElementToString(object? value)
    {
        if (value == null) return null;
        if (value is System.Text.Json.JsonElement je)
        {
            return je.ValueKind switch
            {
                System.Text.Json.JsonValueKind.String => je.GetString(),
                System.Text.Json.JsonValueKind.Number => je.GetRawText(), // 数字直接取原始文本
                System.Text.Json.JsonValueKind.True => "true",
                System.Text.Json.JsonValueKind.False => "false",
                _ => je.GetRawText()
            };
        }
        return value.ToString();
    }

    private static DateTime? GetArgDate(Dictionary<string, object> args, string primaryKey)
    {
        var val = GetArgString(args, primaryKey);
        if (val == null) return null;
        // 统一全角/半角分隔符
        val = val.Replace('－', '-').Replace('／', '/').Replace('．', '-');
        if (DateTime.TryParse(val, out var dt1)) return dt1;
        if (DateTime.TryParseExact(val, "yyyy-MM-dd", null, System.Globalization.DateTimeStyles.None, out var dt2)) return dt2;
        if (DateTime.TryParseExact(val, "yyyy/M/d", null, System.Globalization.DateTimeStyles.None, out var dt3)) return dt3;
        if (DateTime.TryParseExact(val, "yyyy-M-d", null, System.Globalization.DateTimeStyles.None, out var dt4)) return dt4;
        return null;
    }

    private static int? GetArgInt(Dictionary<string, object> args, string primaryKey)
    {
        var val = GetArgString(args, primaryKey);
        if (val == null)
        {
            // Also try as direct numeric value
            var keys = new[] { primaryKey, ToSnakeCase(primaryKey) };
            foreach (var k in keys)
            {
                if (args.TryGetValue(k, out var v) && v is System.Text.Json.JsonElement je && je.ValueKind == System.Text.Json.JsonValueKind.Number)
                {
                    if (je.TryGetInt32(out var n)) return n;
                }
            }
            return null;
        }
        if (int.TryParse(val, out var i)) return i;
        return null;
    }

    private static string ToSnakeCase(string s) =>
        string.Concat(s.Select((c, i) => i > 0 && char.IsUpper(c) ? "_" + char.ToLower(c) : char.ToLower(c).ToString()));

    private static string ToUnderscore(string s) => s.Replace("-", "_");

    // ===== 项目创建上下文跟踪（帮 AI 记住用户已提供的信息） =====
    private string? BuildProjectCreationContext(string userMsg)
    {
        // 检查最近几个消息是否在项目创建对话中
        bool aiWasAskingAboutProject = false;
        foreach (var m in _chatMessages.AsEnumerable().Reverse().Take(4))
        {
            if (m.Role == "assistant" && m.Content != null &&
                (m.Content.Contains("项目") || m.Content.Contains("任务") || m.Content.Contains("工期")))
            {
                aiWasAskingAboutProject = true;
            }
        }
        if (!aiWasAskingAboutProject) return null;

        // 从对话历史中提取已提供的项目信息（仅提取可靠的结构化字段）
        var projectInfo = new Dictionary<string, string>();
        var rawDescriptions = new List<string>(); // 用户原始描述原文，AI 自行解析

        foreach (var m in _chatMessages)
        {
            if (m.Role != "user" || m.Content == null) continue;
            var c = m.Content;

            // 名称
            var nameMatch = System.Text.RegularExpressions.Regex.Match(c, @"名称[：:]\s*(\S+)");
            if (nameMatch.Success) projectInfo["名称"] = nameMatch.Groups[1].Value;

            // 开始日期
            var dateMatch = System.Text.RegularExpressions.Regex.Match(c, @"(\d{4}[-/年]\d{1,2}[-/月]\d{1,2})");
            if (dateMatch.Success) projectInfo["开始日期"] = dateMatch.Groups[1].Value;

            // 总工期 — 只匹配明确带"总工期"或"工期"前缀的数字，且不覆盖已有值
            var durMatch = System.Text.RegularExpressions.Regex.Match(c, @"(?:总)?工期[^0-9]*?(\d+)\s*天");
            if (durMatch.Success && !projectInfo.ContainsKey("工期"))
                projectInfo["工期"] = durMatch.Groups[1].Value + "天";

            // 收集包含项目/任务信息的用户原始消息（原文透传，AI 自行用 NLP 解析）
            if (c.Length > 5 && (c.Contains("天") || c.Contains("任务") || c.Contains("项目") || c.Contains("名称")))
            {
                rawDescriptions.Add(c);
            }
        }

        if (projectInfo.Count == 0 && rawDescriptions.Count == 0) return null;

        var summary = "【项目创建上下文 - 用户已提供的信息】\n";
        foreach (var kv in projectInfo)
            summary += $"- {kv.Key}: {kv.Value}\n";
        if (rawDescriptions.Count > 0)
        {
            summary += "\n【用户原始描述 — 请直接用 NLP 从中解析任务列表，不要人工计数】\n";
            foreach (var desc in rawDescriptions)
                summary += $"{desc}\n---\n";
        }
        summary += "上述是用户已经提供过的信息，不要再重复询问。如果信息齐全，请立即用 create_project_with_tasks 创建。";

        return summary;
    }

    private async Task SendChatMessage()
    {
        if (string.IsNullOrWhiteSpace(_chatInput) || _chatLoading) return;
        var userMsg = _chatInput.Trim();
        _chatInput = "";
        // 发送后重置输入框高度
        await JS.InvokeVoidAsync("eval", @"document.getElementById('chat-textarea') && (function(t){t.style.height='22px'})(document.getElementById('chat-textarea'));");
        _chatMessages.Add(new AiMessage { Role = "user", Content = userMsg });

        // 为 AI 补充项目创建上下文记忆（避免反复问同样的问题）
        var creationContext = BuildProjectCreationContext(userMsg);
        if (!string.IsNullOrEmpty(creationContext))
        {
            _chatMessages.Add(new AiMessage
            {
                Role = "system",
                Content = creationContext
            });
        }

        await SaveChatMessages();
        _chatLoading = true;
        StateHasChanged();

        try
        {
            var opts = await GetChatAiOptions();
            if (opts == null)
            {
                _chatMessages.Add(new AiMessage { Role = "assistant", Content = "⚠️ 请先在分析页面的「AI 设置」中配置并保存 API 连接。" });
                await SaveChatMessages();
                _chatLoading = false;
                StateHasChanged();
                return;
            }

            var context = await BuildProjectContext();
            var projectInfo = string.IsNullOrEmpty(context) ? "" : $"\n【项目背景数据】\n{context}\n";
            var pid = GetCurrentProjectId() ?? 0;
            var sysPrompt = $@"你是项目管理系统 NetPlan 的 AI 助手。回答只有一个目标：帮用户最快完成操作。

## 核心行为规则
1. **极端简洁** — 每个回复不超过 3 句话。不要分析、不要总结、不要重复用户说过的话。
2. **一次创建** — 用户提供项目信息后，缺什么问什么（每个问题1句话），收到补充后**立即创建**。不要先确认再问要不要创建。
3. **不要问已有信息** — 对话历史里已经有过的回答，不要再问第二遍。
4. **不要假装调用工具** — 不要在回复里写 `create_project(...)` 或 XML 伪代码。系统自动处理工具调用，你只需简短确认。

## 你不需要做的事
- ❌ 不需要分析任务结构
- ❌ 不需要总结用户的输入
- ❌ 不需要问「是否要创建」
- ❌ 不需要解释工具
	
## 回答示例
用户：创建项目 ABC，开始2026-06-01，任务A 30天，任务B 45天（依赖任务A）
你：收到。任务B工期45天，任务A前置是任务B还是并行？
用户：任务B在任务A之后。
你：已创建。项目 ABC，2个任务，2026-06-01 → 2026-08-15。

## 可用工具
- create_project_with_tasks：创建项目+所有任务（只要有任务就用这个）
- create_project：只创建项目（没有任务细节时用）
- create_task / update_task / get_tasks / get_all_projects

{projectInfo}
- 当前项目ID：{pid}
";

            _pendingToolCalls = null;
            _pendingToolCallMessage = null;
            _chainDepth = 0;

            var tools = AiToolDefinitions.GetAllTools(pid > 0 ? pid : null);
            var messages = new List<AiMessage>
            {
                new() { Role = "system", Content = sysPrompt },
                new() { Role = "user", Content = userMsg }
            };

            var result = await AiService.ChatWithToolsAsync(messages, tools, temperature: 0.3, overrideOptions: opts);

            if (result.IsToolCall)
            {
                // AI 提议了一个操作，等待用户确认
                _pendingToolCalls = result.ToolCalls;
                _pendingToolCallMessage = result.Text;
                // 将 AI 的 tool_calls 消息加入对话历史（后续执行或拒绝时会用到）
                _chatMessages.Add(new AiMessage
                {
                    Role = "assistant",
                    Content = result.Text ?? "",
                    ToolCalls = result.ToolCalls,
                    ReasoningContent = result.ReasoningContent
                });
            }
            else
            {
                // 兜底：尝试从回复文本中解析工具调用（兼容不支持 function calling 的模型）
                var textCalls = TryParseToolCallsFromText(result.Text);
                if (textCalls?.Count > 0)
                {
                    result.ToolCalls = textCalls;
                    _pendingToolCalls = textCalls;
                    _pendingToolCallMessage = result.Text;
                    _chatMessages.Add(new AiMessage
                    {
                        Role = "assistant",
                        Content = StripToolCallText(result.Text) ?? "",
                        ToolCalls = textCalls
                    });
                }
                else
                {
                    // 普通文本回复
                    _chatMessages.Add(new AiMessage { Role = "assistant", Content = result.Text ?? "" });
                }
            }
        }
        catch (Exception ex)
        {
            _chatMessages.Add(new AiMessage { Role = "assistant", Content = $"❌ 出错了：{ex.Message}" });
        }
        await SaveChatMessages();
        _chatLoading = false;
        StateHasChanged();
    }

    private async Task ExecutePendingToolCall()
    {
        if (_pendingToolCalls == null || _pendingToolCalls.Count == 0) return;
        _executingToolCall = true;
        StateHasChanged();

        try
        {
            var responses = new List<string>();
            foreach (var tc in _pendingToolCalls)
            {
                var result = await ExecuteToolCall(tc);
                responses.Add(result);

                // 把 tool 响应加入对话历史
                _chatMessages.Add(new AiMessage
                {
                    Role = "tool",
                    ToolCallId = tc.Id,
                    Content = result
                });
            }

            // 清空待处理
            _pendingToolCalls = null;

            // 调用 AI 生成最终回复（带工具执行结果）
            _chainDepth++;
            var opts = await GetChatAiOptions();
            if (opts != null)
            {
                if (_chainDepth >= 2)
                {
                    // 链式调用已达上限，强制 AI 只做文本总结，忽略任何工具调用
                    _chatMessages.Add(new AiMessage
                    {
                        Role = "system",
                        Content = "注意：已经连续执行了多步工具调用，现在请直接总结最终结果，不要再调用任何工具。"
                    });
                    var finalResult = await AiService.ChatWithToolsAsync(_chatMessages, new List<AiToolDefinition>(), temperature: 0.3, overrideOptions: opts);
                    _chatMessages.Add(new AiMessage { Role = "assistant", Content = finalResult.Text ?? "操作已完成。" });
                }
                else
                {
                    var result = await AiService.ChatWithToolsAsync(_chatMessages, new List<AiToolDefinition>(), temperature: 0.3, overrideOptions: opts);
                    if (result.IsToolCall)
                    {
                        // AI 又想调用工具（链式调用，最多1次），继续等待确认
                        _pendingToolCalls = result.ToolCalls;
                        _chatMessages.Add(new AiMessage
                        {
                            Role = "assistant",
                            Content = result.Text ?? "还需要执行以下操作：",
                            ToolCalls = result.ToolCalls
                        });
                    }
                    else
                    {
                        _chatMessages.Add(new AiMessage { Role = "assistant", Content = result.Text ?? "操作已完成。" });
                    }
                }
            }
        }
        catch (Exception ex)
        {
            _chatMessages.Add(new AiMessage { Role = "assistant", Content = $"❌ 执行操作时出错：{ex.Message}" });
        }

        _executingToolCall = false;
        await SaveChatMessages();
        StateHasChanged();
    }

    private async Task RejectPendingToolCall()
    {
        if (_pendingToolCalls == null) return;

        // 把拒绝结果加入对话历史 — 加入明确指令阻止重复建议
        foreach (var tc in _pendingToolCalls)
        {
            _chatMessages.Add(new AiMessage
            {
                Role = "tool",
                ToolCallId = tc.Id,
                Content = "用户拒绝了此操作。请不要再建议相同的操作，也不要再调用任何工具。简短回复「好的」或「已取消」即可。"
            });
        }

        _pendingToolCalls = null;

        // 让 AI 生成回复（知道操作被拒绝了）— 传入空工具列表，防止 AI 再次调工具
        var opts = await GetChatAiOptions();
        if (opts != null)
        {
            var result = await AiService.ChatAsync(_chatMessages, temperature: 0.3, overrideOptions: opts);
            _chatMessages.Add(new AiMessage { Role = "assistant", Content = result ?? "已取消操作。" });
        }

        await SaveChatMessages();
        StateHasChanged();
    }

    private async Task<string> ExecuteToolCall(AiToolCall tc)
    {
        try
        {
            var args = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, object>>(tc.FunctionArguments);
            if (args == null) return $"❌ 无法解析参数：{tc.FunctionArguments}";

            return tc.FunctionName switch
            {
                "get_all_projects" => await ExecuteGetAllProjects(),
                "create_project_with_tasks" => await ExecuteCreateProjectWithTasks(args),
                "create_project" => await ExecuteCreateProject(args),
                "get_tasks" => await ExecuteGetTasks(args),
                "create_task" => await ExecuteCreateTask(args),
                "update_task" => await ExecuteUpdateTask(args),
                _ => $"❌ 未知操作：{tc.FunctionName}"
            };
        }
        catch (Exception ex)
        {
            return $"❌ 执行 {tc.FunctionName} 时出错：{ex.Message}";
        }
    }

    private async Task<string> ExecuteGetAllProjects()
    {
        var allProjects = await ProjectService.GetAllProjectsAsync();
        var sb = new System.Text.StringBuilder();
        sb.AppendLine($"共 {allProjects.Count} 个项目：");
        foreach (var p in allProjects.OrderBy(p => p.PlanStartDate))
            sb.AppendLine($"  📁 ID={p.Id} {p.Name}（{p.Code}） | {p.PlanStartDate:yyyy-MM-dd} → {p.PlanEndDate:yyyy-MM-dd}");
        return sb.ToString();
    }

    private async Task<string> ExecuteCreateProjectWithTasks(Dictionary<string, object> args)
    {
        var name = GetArgString(args, "name") ?? "新项目";
        var code = GetArgString(args, "code") ?? "PROJ-" + DateTime.Now.ToString("MMddHHmmss");
        var desc = GetArgString(args, "description");
        var planStart = GetArgDate(args, "planStartDate") ?? DateTime.Today;
        var planEnd = GetArgDate(args, "planEndDate") ?? planStart.AddMonths(1);

        // 如果没传 planEndDate 但传了 duration，自动推算
        var duration = GetArgInt(args, "duration") ?? GetArgInt(args, "planDuration");
        if (!args.ContainsKey("planEndDate") && duration.HasValue)
            planEnd = planStart.AddDays(duration.Value - 1);

        // 1. 创建项目
        var project = new Project
        {
            Name = name,
            Code = code,
            Description = desc,
            PlanStartDate = planStart,
            PlanEndDate = planEnd,
            CreatedAt = DateTime.Now,
            UpdatedAt = DateTime.Now
        };
        var created = await ProjectService.CreateProjectAsync(project);
        var pid = created.Id;

        // 2. 解析任务列表
        var tasksArg = args.GetValueOrDefault("tasks");
        if (tasksArg == null)
            return $"✅ 已创建项目「{created.Name}」ID={pid}，但未提供任务列表。";

        var tasksJson = System.Text.Json.JsonSerializer.Serialize(tasksArg);
        var taskDefs = System.Text.Json.JsonSerializer.Deserialize<List<Dictionary<string, object>>>(tasksJson);
        if (taskDefs == null || taskDefs.Count == 0)
            return $"✅ 已创建项目「{created.Name}」ID={pid}，但未提供任务列表。";

        // 3. 第一遍：创建所有任务（先不处理依赖和父子关系，未指定日期的用项目开始日期暂存）
        var taskDefList = new List<(string Name, int Duration, string? Resp, bool IsMs, DateTime? Start, DateTime? End)>();
        var parentMap = new Dictionary<string, string>(); // taskName → parentTaskName
        var predMap = new Dictionary<string, List<string>>(); // taskName → predecessor names

        foreach (var td in taskDefs)
        {
            var tName = GetArgString(td, "name") ?? "未命名任务";
            var tDur = GetArgInt(td, "planDuration") ?? GetArgInt(td, "duration") ?? 1;
            var tCode = GetArgString(td, "code") ?? $"T-{taskDefList.Count + 1}";
            var tResp = GetArgString(td, "responsiblePerson");
            var tStart = GetArgDate(td, "planStartDate") ?? GetArgDate(td, "startDate");
            var tEnd = GetArgDate(td, "planEndDate") ?? GetArgDate(td, "endDate");
            var tIsMs = GetArgString(td, "isMilestone")?.ToLower() == "true";

            taskDefList.Add((tName, tDur, tResp, tIsMs, tStart, tEnd));

            var ptName = GetArgString(td, "parentTaskName");
            if (ptName != null) parentMap[tName] = ptName;
            if (td.TryGetValue("predecessorNames", out var pr) && pr != null)
            {
                var prJson = System.Text.Json.JsonSerializer.Serialize(pr);
                var prList = System.Text.Json.JsonSerializer.Deserialize<List<string>>(prJson);
                if (prList?.Count > 0)
                    predMap[tName] = prList;
            }
        }

        // 3b. 自动推算日期：按任务列表顺序从前到后排列
        var taskMap = new Dictionary<string, Models.TaskItem>();
        var lastEndDate = planStart;

        foreach (var (tName, tDur, tResp, tIsMs, tStart, tEnd) in taskDefList)
        {
            DateTime taskStart, taskEnd;

            if (tStart.HasValue && tEnd.HasValue)
            {
                // 用户指定了起止日期
                taskStart = tStart.Value;
                taskEnd = tEnd.Value;
                lastEndDate = taskEnd.AddDays(1);
            }
            else if (tStart.HasValue)
            {
                // 用户只指定了开始日期
                taskStart = tStart.Value;
                taskEnd = tStart.Value.AddDays(tDur - 1);
                lastEndDate = taskEnd.AddDays(1);
            }
            else
            {
                // 自动推算：延续上一个任务的结束日期
                taskStart = lastEndDate;
                taskEnd = lastEndDate.AddDays(tDur - 1);
                lastEndDate = taskEnd.AddDays(1);
            }

            // 检查是否有前置任务：取前置任务最晚结束日期+1作为开始
            if (predMap.TryGetValue(tName, out var predNames) && predNames.Count > 0)
            {
                var maxPredEnd = taskStart;
                foreach (var pn in predNames)
                {
                    if (taskMap.TryGetValue(pn, out var predTask) && predTask.PlanEndDate > maxPredEnd)
                        maxPredEnd = predTask.PlanEndDate.AddDays(1);
                }
                if (maxPredEnd > taskStart)
                {
                    taskStart = maxPredEnd;
                    taskEnd = taskStart.AddDays(tDur - 1);
                }
            }

            var task = new Models.TaskItem
            {
                ProjectId = pid,
                Name = tName,
                Code = $"T-{taskMap.Count + 1}",
                PlanDuration = tDur,
                PlanStartDate = taskStart,
                PlanEndDate = taskEnd,
                ResponsiblePerson = tResp,
                IsMilestone = tIsMs,
                CompletionPercentage = 0,
                CreatedAt = DateTime.Now
            };

            var createdTask = await ProjectService.CreateTaskAsync(task);
            taskMap[tName] = createdTask;
            lastEndDate = taskEnd.AddDays(1);

            // 更新项目实际结束日期
            if (taskEnd > planEnd)
                planEnd = taskEnd;
        }

        // 4. 第二遍：建立父子关系
        foreach (var kv in parentMap)
        {
            if (taskMap.TryGetValue(kv.Key, out var childTask) && taskMap.TryGetValue(kv.Value, out var parentTask))
            {
                childTask.ParentTaskId = parentTask.Id;
                childTask.OutlineLevel = parentTask.OutlineLevel + 1;
                await ProjectService.UpdateTaskAsync(childTask);
            }
        }

        // 5. 第三遍：建立前置依赖关系
        foreach (var kv in predMap)
        {
            if (!taskMap.TryGetValue(kv.Key, out var successorTask)) continue;
            foreach (var predName in kv.Value)
            {
                if (taskMap.TryGetValue(predName, out var predecessorTask))
                {
                    try
                    {
                        await ProjectService.CreateRelationAsync(new Models.TaskRelation
                        {
                            ProjectId = pid,
                            SuccessorTaskId = successorTask.Id,
                            PredecessorTaskId = predecessorTask.Id,
                            Type = Models.RelationType.FS,
                            Lag = 0
                        });
                    }
                    catch { }
                }
            }
        }

        // 更新项目的结束日期（按实际任务排程修正）
        created.PlanEndDate = planEnd;
        await ProjectService.UpdateProjectAsync(created);

        var milestoneCount = taskDefList.Count(t => t.IsMs);
        var totalDur = taskDefList.Sum(t => t.Duration);

        return $"✅ 已创建项目「{created.Name}」ID={pid}\n" +
               $"   📋 共 {taskDefList.Count} 个任务 | 总工时 {totalDur}天 | 里程碑 {milestoneCount}个\n" +
               $"   🔗 父子关系 {parentMap.Count}条 | 依赖关系 {predMap.Sum(kv => kv.Value.Count)}条\n" +
               $"   📅 {planStart:yyyy-MM-dd} → {planEnd:yyyy-MM-dd}";
    }

    private async Task<string> ExecuteCreateProject(Dictionary<string, object> args)
    {
        var name = GetArgString(args, "name") ?? "新项目";
        var code = GetArgString(args, "code") ?? "PROJ-" + DateTime.Now.ToString("MMddHHmmss");
        var desc = GetArgString(args, "description");
        var planStart = GetArgDate(args, "planStartDate") ?? DateTime.Today;
        var planEnd = GetArgDate(args, "planEndDate") ?? planStart.AddMonths(1);

        // 如果没传 planEndDate 但传了 duration，自动推算
        var duration = GetArgInt(args, "duration") ?? GetArgInt(args, "planDuration");
        if (!args.ContainsKey("planEndDate") && duration.HasValue)
            planEnd = planStart.AddDays(duration.Value - 1);

        var project = new Project
        {
            Name = name,
            Code = code,
            Description = desc,
            PlanStartDate = planStart,
            PlanEndDate = planEnd,
            CreatedAt = DateTime.Now,
            UpdatedAt = DateTime.Now
        };

        var created = await ProjectService.CreateProjectAsync(project);
        return $"✅ 已创建项目「{created.Name}」ID={created.Id}，{created.PlanStartDate:yyyy-MM-dd} → {created.PlanEndDate:yyyy-MM-dd}";
    }

    private async Task<string> ExecuteGetTasks(Dictionary<string, object> args)
    {
        if (!args.TryGetValue("projectId", out var pidObj) || pidObj == null)
            return "❌ 缺少 projectId 参数";

        var pid = Convert.ToInt32(pidObj);
        var project = await ProjectService.GetProjectByIdAsync(pid);
        if (project == null) return $"❌ 项目 ID={pid} 不存在";

        var tasks = await ProjectService.GetTasksByProjectIdAsync(pid);
        var sb = new System.Text.StringBuilder();
        sb.AppendLine($"项目 {project.Name} 共 {tasks.Count} 个任务：");
        foreach (var t in tasks.OrderBy(t => t.PlanStartDate))
        {
            var statusIcon = t.CompletionPercentage >= 100 ? "✅" : t.CompletionPercentage > 0 ? "🔄" : "⏳";
            sb.AppendLine($"  {statusIcon} {t.Name} | 工期 {t.PlanDuration}天 | {t.PlanStartDate:yyyy-MM-dd} → {t.PlanEndDate:yyyy-MM-dd} | 负责人 {t.ResponsiblePerson ?? "-"} | {t.CompletionPercentage}%");
        }
        return sb.ToString();
    }

    private async Task<string> ExecuteCreateTask(Dictionary<string, object> args)
    {
        if (!args.TryGetValue("projectId", out var pidObj) || pidObj == null)
            return "❌ 缺少 projectId 参数";
        var pid = Convert.ToInt32(pidObj);

        var project = await ProjectService.GetProjectByIdAsync(pid);
        if (project == null) return $"❌ 项目 ID={pid} 不存在";

        var task = new TaskItem
        {
            ProjectId = pid,
            Name = args.GetValueOrDefault("name")?.ToString() ?? "新任务",
            PlanDuration = args.TryGetValue("planDuration", out var dur) ? Convert.ToInt32(dur) : 1,
            PlanStartDate = args.TryGetValue("planStartDate", out var start) && DateTime.TryParse(start?.ToString(), out var sd) ? sd : DateTime.Today,
            PlanEndDate = args.TryGetValue("planEndDate", out var end) && DateTime.TryParse(end?.ToString(), out var ed) ? ed : DateTime.Today.AddDays(1),
            ResponsiblePerson = args.GetValueOrDefault("responsiblePerson")?.ToString(),
            IsMilestone = args.TryGetValue("isMilestone", out var ism) && (ism?.ToString() == "True" || ism?.ToString() == "true"),
            CompletionPercentage = 0,
            CreatedAt = DateTime.Now
        };

        // 如果没传结束日期，自动按工期算
        if (!args.ContainsKey("planEndDate") && task.PlanDuration > 0)
            task.PlanEndDate = task.PlanStartDate.AddDays(task.PlanDuration - 1);

        var newTask = await ProjectService.CreateTaskAsync(task);

        // 处理前置任务关系
        var resultMsg = $"✅ 已创建任务「{newTask.Name}」ID={newTask.Id}，工期 {newTask.PlanDuration}天，{newTask.PlanStartDate:yyyy-MM-dd} → {newTask.PlanEndDate:yyyy-MM-dd}";

        if (args.TryGetValue("predecessorNames", out var preds) && preds != null)
        {
            var predNames = System.Text.Json.JsonSerializer.Deserialize<List<string>>(preds.ToString()!);
            if (predNames?.Count > 0)
            {
                var allTasks = await ProjectService.GetTasksByProjectIdAsync(pid);
                var linked = 0;
                foreach (var pn in predNames)
                {
                    var pred = allTasks.FirstOrDefault(t => t.Name.Contains(pn, StringComparison.OrdinalIgnoreCase));
                    if (pred != null)
                    {
                        await ProjectService.CreateRelationAsync(new TaskRelation
                        {
                            ProjectId = pid,
                            SuccessorTaskId = newTask.Id,
                            PredecessorTaskId = pred.Id,
                            Type = RelationType.FS,
                            Lag = 0
                        });
                        linked++;
                        resultMsg += $"\n  → 前置任务：{pred.Name}";
                    }
                }
                if (linked > 0) resultMsg += $"\n已建立 {linked} 条依赖关系。";
            }
        }

        return resultMsg;
    }

    private async Task<string> ExecuteUpdateTask(Dictionary<string, object> args)
    {
        if (!args.TryGetValue("projectId", out var pidObj) || pidObj == null)
            return "❌ 缺少 projectId 参数";
        var pid = Convert.ToInt32(pidObj);

        if (!args.TryGetValue("taskName", out var taskNameObj) || taskNameObj == null)
            return "❌ 缺少 taskName 参数";

        var tasks = await ProjectService.GetTasksByProjectIdAsync(pid);
        var task = tasks.FirstOrDefault(t => t.Name.Contains(taskNameObj.ToString()!, StringComparison.OrdinalIgnoreCase));
        if (task == null)
            return $"❌ 未找到名称包含「{taskNameObj}」的任务";

        var changes = new List<string>();

        if (args.TryGetValue("newName", out var newName)) { task.Name = newName.ToString()!; changes.Add($"名称 → {newName}"); }
        if (args.TryGetValue("planDuration", out var dur)) { task.PlanDuration = Convert.ToInt32(dur); changes.Add($"工期 → {dur}天"); }
        if (args.TryGetValue("planStartDate", out var start) && DateTime.TryParse(start?.ToString(), out var sd)) { task.PlanStartDate = sd; changes.Add($"开始 → {sd:yyyy-MM-dd}"); }
        if (args.TryGetValue("planEndDate", out var end) && DateTime.TryParse(end?.ToString(), out var ed)) { task.PlanEndDate = ed; changes.Add($"结束 → {ed:yyyy-MM-dd}"); }
        if (args.TryGetValue("responsiblePerson", out var rp)) { task.ResponsiblePerson = rp.ToString(); changes.Add($"负责人 → {rp}"); }
        if (args.TryGetValue("completionPercent", out var cp)) { task.CompletionPercentage = Convert.ToInt32(cp); changes.Add($"完成度 → {cp}%"); }

        await ProjectService.UpdateTaskAsync(task);

        return $"✅ 已更新任务「{task.Name}」：{string.Join("、", changes)}";
    }

