@inherits LayoutComponentBase

<div class="page-body">
    <div class="page-sidebar @(_sidebarCollapsed ? "collapsed" : "")">
        <div class="sidebar-header">
            <span class="sidebar-logo">📊</span>
            <span class="sidebar-title">NetPlan</span>
        </div>
        <div class="sidebar-nav">
            <a href="/" class="nav-item">
                <span class="nav-icon">🏠</span>
                <span class="nav-label">首页</span>
            </a>
            <a href="javascript:navToChecked('gantt')" class="nav-item">
                <span class="nav-icon">📅</span>
                <span class="nav-label">甘特图</span>
            </a>
            <a href="javascript:navToChecked('network')" class="nav-item disabled">
                <span class="nav-icon">🔗</span>
                <span class="nav-label">网络图</span>
            </a>
            <a href="javascript:navToChecked('progress-slope')" class="nav-item">
                <span class="nav-icon">📈</span>
                <span class="nav-label">斜率图</span>
            </a>
            <a href="javascript:navToChecked('management-curve')" class="nav-item">
                <span class="nav-icon">📉</span>
                <span class="nav-label">曲线图</span>
            </a>
            <a href="javascript:navToChecked('resources')" class="nav-item">
                <span class="nav-icon">👥</span>
                <span class="nav-label">资源</span>
            </a>
            <a href="/analysis" class="nav-item">
                <span class="nav-icon">📊</span>
                <span class="nav-label">分析</span>
            </a>
        </div>
        <div class="sidebar-footer">
            <a href="javascript:void(0)" class="nav-item collapse-btn" @onclick="ToggleSidebar">
                <span class="nav-icon">◀</span>
                <span class="nav-label">折叠</span>
            </a>
        </div>
    </div>
    <div class="page-main">
        @Body
    </div>
</div>

@code {
    private bool _sidebarCollapsed = false;

    private void ToggleSidebar()
    {
        _sidebarCollapsed = !_sidebarCollapsed;
    }
}
