    private async Task<string> ExecuteGetTasks(Dictionary<string, object> args)
    {
        var pid = GetArgInt(args, "projectId") ?? 0;
        if (pid <= 0)
        {
            var available = string.Join("、", _projectNameCache.Select(kv => $"ID={kv.Key}({kv.Value})"));
            if (string.IsNullOrEmpty(available))
            {
                try
                {
                    var allP = await ProjectService.GetAllProjectsAsync();
                    available = string.Join("、", allP.Select(p => $"ID={p.Id}({p.Name})"));
                }
                catch { }
            }
            return $"❌ 缺少 projectId 参数。可用项目：{available}";
        }
        var project = await ProjectService.GetProjectByIdAsync(pid);
        if (project == null) return $"❌ 项目 ID={pid} 不存在";
        _projectNameCache[pid] = project.Name;

        var tasks = await ProjectService.GetTasksByProjectIdAsync(pid);
        var sb = new System.Text.StringBuilder();
        sb.AppendLine($"项目 {project.Name} 共 {tasks.Count} 个任务：");
        var totalBudget = 0m;
        var totalActual = 0m;
        var taskCount = 0;
        const int maxDisplayTasks = 40;
        foreach (var t in tasks.OrderBy(t => t.PlanStartDate))
        {
            taskCount++;
            if (taskCount > maxDisplayTasks)
            {
                totalBudget += t.BudgetCost;
                if (t.ActualCost > 0) totalActual += t.ActualCost.Value;
                continue;
            }
            var statusIcon = t.CompletionPercentage >= 100 ? "✅" : t.CompletionPercentage > 0 ? "🔄" : "⏳";
            var costInfo = t.BudgetCost > 0 ? $" 预算¥{t.BudgetCost:N0}" : "";
            if (t.ActualCost > 0) costInfo += $" 实际¥{t.ActualCost:N0}";
            sb.AppendLine($"  {statusIcon} {t.Name} | 工期 {t.PlanDuration}天 | {t.PlanStartDate:yyyy-MM-dd} → {t.PlanEndDate:yyyy-MM-dd} | 负责人 {t.ResponsiblePerson ?? "-"} | {t.CompletionPercentage}%{costInfo}");
            totalBudget += t.BudgetCost;
            if (t.ActualCost > 0) totalActual += t.ActualCost.Value;
        }
        if (tasks.Count > maxDisplayTasks)
            sb.AppendLine($"  …以及另外 {tasks.Count - maxDisplayTasks} 个任务（共计 {tasks.Count} 个）");
        if (totalBudget > 0)
            sb.AppendLine($"\n【成本汇总】预算 ¥{totalBudget:N0}，实际 ¥{(totalActual > 0 ? totalActual.ToString("N0") : "未录入")}");
        return sb.ToString();
    }

    private async Task<string> ExecuteCreateTask(Dictionary<string, object> args)
    {
        var pid = GetArgInt(args, "projectId") ?? 0;
        if (pid <= 0)
        {
            var available = string.Join("、", _projectNameCache.Select(kv => $"ID={kv.Key}({kv.Value})"));
            if (string.IsNullOrEmpty(available))
            {
                try
                {
                    var allP = await ProjectService.GetAllProjectsAsync();
                    available = string.Join("、", allP.Select(p => $"ID={p.Id}({p.Name})"));
                }
                catch { }
            }
            return $"❌ 缺少 projectId 参数。可用项目：{available}";
        }

        var project = await ProjectService.GetProjectByIdAsync(pid);
        if (project == null) return $"❌ 项目 ID={pid} 不存在";

        var task = new TaskItem
        {
            ProjectId = pid,
            Name = args.GetValueOrDefault("name")?.ToString() ?? "新任务",
            PlanDuration = args.TryGetValue("planDuration", out var dur) ? Convert.ToInt32(dur) : 1,
            PlanStartDate = args.TryGetValue("planStartDate", out var start) && DateTime.TryParse(start?.ToString(), out var sd) ? sd : DateTime.Today,
            PlanEndDate = args.TryGetValue("planEndDate", out var end) && DateTime.TryParse(end?.ToString(), out var ed) ? ed : DateTime.Today.AddDays(1),
            ResponsiblePerson = args.GetValueOrDefault("responsiblePerson")?.ToString(),
            IsMilestone = args.TryGetValue("isMilestone", out var ism) && (ism?.ToString() == "True" || ism?.ToString() == "true"),
            CompletionPercentage = 0,
            CreatedAt = DateTime.Now
        };

        if (!args.ContainsKey("planEndDate") && task.PlanDuration > 0)
            task.PlanEndDate = task.PlanStartDate.AddDays(task.PlanDuration - 1);

        var newTask = await ProjectService.CreateTaskAsync(task);

        var resultMsg = $"✅ 已创建任务「{newTask.Name}」ID={newTask.Id}，工期 {newTask.PlanDuration}天，{newTask.PlanStartDate:yyyy-MM-dd} → {newTask.PlanEndDate:yyyy-MM-dd}";

        if (args.TryGetValue("predecessorNames", out var preds) && preds != null)
        {
            var predNames = System.Text.Json.JsonSerializer.Deserialize<List<string>>(preds.ToString()!);
            if (predNames?.Count > 0)
            {
                var allTasks = await ProjectService.GetTasksByProjectIdAsync(pid);
                var linked = 0;
                foreach (var pn in predNames)
                {
                    var pred = allTasks.FirstOrDefault(t => t.Name.Contains(pn, StringComparison.OrdinalIgnoreCase));
                    if (pred != null)
                    {
                        await ProjectService.CreateRelationAsync(new TaskRelation
                        {
                            ProjectId = pid,
                            SuccessorTaskId = newTask.Id,
                            PredecessorTaskId = pred.Id,
                            Type = RelationType.FS,
                            Lag = 0
                        });
                        linked++;
                        resultMsg += $"\n  → 前置任务：{pred.Name}";
                    }
                }
                if (linked > 0) resultMsg += $"\n已建立 {linked} 条依赖关系。";
            }
        }

        return resultMsg;
    }

    private async Task<string> ExecuteUpdateTask(Dictionary<string, object> args)
    {
        var pid = GetArgInt(args, "projectId") ?? 0;
        if (pid <= 0)
        {
            var available = string.Join("、", _projectNameCache.Select(kv => $"ID={kv.Key}({kv.Value})"));
            if (string.IsNullOrEmpty(available))
            {
                try
                {
                    var allP = await ProjectService.GetAllProjectsAsync();
                    available = string.Join("、", allP.Select(p => $"ID={p.Id}({p.Name})"));
                }
                catch { }
            }
            return $"❌ 缺少 projectId 参数。可用项目：{available}";
        }

        if (!args.TryGetValue("taskName", out var taskNameObj) || taskNameObj == null)
            return "❌ 缺少 taskName 参数";

        var tasks = await ProjectService.GetTasksByProjectIdAsync(pid);
        var task = tasks.FirstOrDefault(t => t.Name.Contains(taskNameObj.ToString()!, StringComparison.OrdinalIgnoreCase));
        if (task == null)
            return $"❌ 未找到名称包含「{taskNameObj}」的任务";

        var changes = new List<string>();

        if (args.TryGetValue("newName", out var newName)) { task.Name = newName.ToString()!; changes.Add($"名称 → {newName}"); }
        if (args.TryGetValue("planDuration", out var dur)) { task.PlanDuration = Convert.ToInt32(dur); changes.Add($"工期 → {dur}天"); }
        if (args.TryGetValue("planStartDate", out var start) && DateTime.TryParse(start?.ToString(), out var sd)) { task.PlanStartDate = sd; changes.Add($"开始 → {sd:yyyy-MM-dd}"); }
        if (args.TryGetValue("planEndDate", out var end) && DateTime.TryParse(end?.ToString(), out var ed)) { task.PlanEndDate = ed; changes.Add($"结束 → {ed:yyyy-MM-dd}"); }
        if (args.TryGetValue("responsiblePerson", out var rp)) { task.ResponsiblePerson = rp.ToString(); changes.Add($"负责人 → {rp}"); }
        if (args.TryGetValue("completionPercent", out var cp)) { task.CompletionPercentage = Convert.ToInt32(cp); changes.Add($"完成度 → {cp}%"); }

        await ProjectService.UpdateTaskAsync(task);

        return $"✅ 已更新任务「{task.Name}」：{string.Join("、", changes)}";
    }

    // ===== 参数获取辅助方法 =====

    private static string? GetArgString(Dictionary<string, object> args, string primaryKey)
    {
        var keys = new[] { primaryKey, ToSnakeCase(primaryKey), ToUnderscore(primaryKey) };
        foreach (var k in keys)
        {
            if (args.TryGetValue(k, out var v) && v != null)
            {
                var s = JsonElementToString(v);
                if (!string.IsNullOrEmpty(s)) return s;
            }
        }
        foreach (var kv in args)
        {
            if (string.Equals(kv.Key, primaryKey, StringComparison.OrdinalIgnoreCase) ||
                string.Equals(kv.Key, primaryKey.Replace("_", ""), StringComparison.OrdinalIgnoreCase))
            {
                var s = JsonElementToString(kv.Value);
                if (!string.IsNullOrEmpty(s)) return s;
            }
        }
        return null;
    }

    private static string? JsonElementToString(object? value)
    {
        if (value == null) return null;
        if (value is System.Text.Json.JsonElement je)
        {
            return je.ValueKind switch
            {
                System.Text.Json.JsonValueKind.String => je.GetString(),
                System.Text.Json.JsonValueKind.Number => je.GetRawText(),
                System.Text.Json.JsonValueKind.True => "true",
                System.Text.Json.JsonValueKind.False => "false",
                _ => je.GetRawText()
            };
        }
        return value.ToString();
    }

    private static DateTime? GetArgDate(Dictionary<string, object> args, string primaryKey)
    {
        var val = GetArgString(args, primaryKey);
        if (val == null) return null;
        val = val.Replace('－', '-').Replace('／', '/').Replace('．', '-');
        if (DateTime.TryParse(val, out var dt1)) return dt1;
        if (DateTime.TryParseExact(val, "yyyy-MM-dd", null, System.Globalization.DateTimeStyles.None, out var dt2)) return dt2;
        if (DateTime.TryParseExact(val, "yyyy/M/d", null, System.Globalization.DateTimeStyles.None, out var dt3)) return dt3;
        if (DateTime.TryParseExact(val, "yyyy-M-d", null, System.Globalization.DateTimeStyles.None, out var dt4)) return dt4;
        return null;
    }

    private static int? GetArgInt(Dictionary<string, object> args, string primaryKey)
    {
        var val = GetArgString(args, primaryKey);
        if (val == null)
        {
            var keys = new[] { primaryKey, ToSnakeCase(primaryKey) };
            foreach (var k in keys)
            {
                if (args.TryGetValue(k, out var v) && v is System.Text.Json.JsonElement je && je.ValueKind == System.Text.Json.JsonValueKind.Number)
                {
                    if (je.TryGetInt32(out var n)) return n;
                }
            }
            return null;
        }
        if (int.TryParse(val, out var i)) return i;
        return null;
    }

    private static string ToSnakeCase(string s) =>
        string.Concat(s.Select((c, i) => i > 0 && char.IsUpper(c) ? "_" + char.ToLower(c) : char.ToLower(c).ToString()));

    private static string ToUnderscore(string s) => s.Replace("-", "_");

    // ===== 项目创建上下文 =====

    private static bool IsCreationMessage(string msg)
    {
        if (string.IsNullOrWhiteSpace(msg)) return false;
        var lower = msg.ToLower();
        return lower.Contains("创建") || lower.Contains("新建") || lower.Contains("添加任务");
    }

    private string? BuildProjectCreationContext(string userMsg)
    {
        if (!IsCreationMessage(userMsg)) return null;

        var projectInfo = new Dictionary<string, string>();
        var rawDescriptions = new List<string>();

        for (int i = _sessionStartIndex; i < _chatMessages.Count; i++)
        {
            var m = _chatMessages[i];
            if (m.Role != "user" || m.Content == null) continue;
            var c = m.Content;

            var nameMatch = System.Text.RegularExpressions.Regex.Match(c, @"名称[：:]\s*(\S+)");
            if (nameMatch.Success) projectInfo["名称"] = nameMatch.Groups[1].Value;

            var dateMatch = System.Text.RegularExpressions.Regex.Match(c, @"(\d{4}[-/年]\d{1,2}[-/月]\d{1,2})");
            if (dateMatch.Success) projectInfo["开始日期"] = dateMatch.Groups[1].Value;

            var durMatch = System.Text.RegularExpressions.Regex.Match(c, @"(?:总)?工期[^0-9]*?(\d+)\s*天");
            if (durMatch.Success && !projectInfo.ContainsKey("工期"))
                projectInfo["工期"] = durMatch.Groups[1].Value + "天";

            if (c.Length > 5 && (c.Contains("天") || c.Contains("任务") || c.Contains("项目") || c.Contains("名称")))
                rawDescriptions.Add(c);
        }

        if (projectInfo.Count == 0 && rawDescriptions.Count == 0) return null;

        var summary = "【项目创建上下文 - 用户已提供的信息】\n";
        foreach (var kv in projectInfo)
            summary += $"- {kv.Key}: {kv.Value}\n";
        if (rawDescriptions.Count > 0)
        {
            summary += "\n【用户原始描述 — 请直接用 NLP 从中解析任务列表，不要人工计数】\n";
            foreach (var desc in rawDescriptions)
                summary += $"{desc}\n---\n";
        }
        summary += "上述是用户已经提供过的信息，不要再重复询问。如果信息齐全，请立即用 create_project_with_tasks 创建。";

        return summary;
    }

