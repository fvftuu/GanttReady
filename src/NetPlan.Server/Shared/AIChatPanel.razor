    private async Task<string> ExecuteFindProject(Dictionary<string, object> args)
    {
        if (!args.TryGetValue("name", out var nameObj) || nameObj == null)
            return "❌ 请提供要搜索的项目名称";

        var keyword = nameObj.ToString()!.Trim().ToLower();
        var allProjects = await ProjectService.GetAllProjectsAsync();
        var matches = allProjects
            .Where(p => p.Name.ToLower().Contains(keyword) || (p.Code?.ToLower().Contains(keyword) ?? false))
            .ToList();

        if (matches.Count == 0)
            return $"❌ 未找到名称包含「{nameObj}」的项目";

        foreach (var p in matches)
            _projectNameCache[p.Id] = p.Name;

        var sb = new System.Text.StringBuilder();
        sb.AppendLine($"找到 {matches.Count} 个匹配的项目：");
        foreach (var p in matches)
            sb.AppendLine($"  📁 ID={p.Id} {p.Name}（{p.Code}） | {p.PlanStartDate:yyyy-MM-dd} → {p.PlanEndDate:yyyy-MM-dd}");
        sb.Append("\n");
        return sb.ToString();
    }

    private async Task<string> ExecuteGetAllProjects()
    {
        var allProjects = await ProjectService.GetAllProjectsAsync();
        _projectNameCache = allProjects.ToDictionary(p => p.Id, p => p.Name);
        var sb = new System.Text.StringBuilder();
        sb.AppendLine($"共 {allProjects.Count} 个项目：");
        foreach (var p in allProjects.OrderBy(p => p.PlanStartDate))
            sb.AppendLine($"  📁 ID={p.Id} {p.Name}（{p.Code}） | {p.PlanStartDate:yyyy-MM-dd} → {p.PlanEndDate:yyyy-MM-dd}");
        return sb.ToString();
    }

    private async Task<string> ExecuteCreateProjectWithTasks(Dictionary<string, object> args)
    {
        var name = GetArgString(args, "name") ?? "新项目";
        var code = GetArgString(args, "code") ?? "PROJ-" + DateTime.Now.ToString("MMddHHmmss");
        var desc = GetArgString(args, "description");
        var planStart = GetArgDate(args, "planStartDate") ?? DateTime.Today;
        var planEnd = GetArgDate(args, "planEndDate") ?? planStart.AddMonths(1);

        var duration = GetArgInt(args, "duration") ?? GetArgInt(args, "planDuration");
        if (!args.ContainsKey("planEndDate") && duration.HasValue)
            planEnd = planStart.AddDays(duration.Value - 1);

        var project = new Project
        {
            Name = name,
            Code = code,
            Description = desc,
            PlanStartDate = planStart,
            PlanEndDate = planEnd,
            CreatedAt = DateTime.Now,
            UpdatedAt = DateTime.Now
        };
        var created = await ProjectService.CreateProjectAsync(project);
        var pid = created.Id;

        var tasksArg = args.GetValueOrDefault("tasks");
        if (tasksArg == null)
            return $"✅ 已创建项目「{created.Name}」ID={pid}，但未提供任务列表。";

        var tasksJson = System.Text.Json.JsonSerializer.Serialize(tasksArg);
        var taskDefs = System.Text.Json.JsonSerializer.Deserialize<List<Dictionary<string, object>>>(tasksJson);
        if (taskDefs == null || taskDefs.Count == 0)
            return $"✅ 已创建项目「{created.Name}」ID={pid}，但未提供任务列表。";

        var taskDefList = new List<(string Name, int Duration, string? Resp, bool IsMs, DateTime? Start, DateTime? End)>();
        var parentMap = new Dictionary<string, string>();
        var predMap = new Dictionary<string, List<string>>();

        foreach (var td in taskDefs)
        {
            var tName = GetArgString(td, "name") ?? "未命名任务";
            var tDur = GetArgInt(td, "planDuration") ?? GetArgInt(td, "duration") ?? 1;
            var tCode = GetArgString(td, "code") ?? $"T-{taskDefList.Count + 1}";
            var tResp = GetArgString(td, "responsiblePerson");
            var tStart = GetArgDate(td, "planStartDate") ?? GetArgDate(td, "startDate");
            var tEnd = GetArgDate(td, "planEndDate") ?? GetArgDate(td, "endDate");
            var tIsMs = GetArgString(td, "isMilestone")?.ToLower() == "true";

            taskDefList.Add((tName, tDur, tResp, tIsMs, tStart, tEnd));

            var ptName = GetArgString(td, "parentTaskName");
            if (ptName != null) parentMap[tName] = ptName;
            if (td.TryGetValue("predecessorNames", out var pr) && pr != null)
            {
                var prJson = System.Text.Json.JsonSerializer.Serialize(pr);
                var prList = System.Text.Json.JsonSerializer.Deserialize<List<string>>(prJson);
                if (prList?.Count > 0)
                    predMap[tName] = prList;
            }
        }

        var taskMap = new Dictionary<string, Models.TaskItem>();
        var lastEndDate = planStart;

        foreach (var (tName, tDur, tResp, tIsMs, tStart, tEnd) in taskDefList)
        {
            DateTime taskStart, taskEnd;

            if (tStart.HasValue && tEnd.HasValue)
            {
                taskStart = tStart.Value;
                taskEnd = tEnd.Value;
                lastEndDate = taskEnd.AddDays(1);
            }
            else if (tStart.HasValue)
            {
                taskStart = tStart.Value;
                taskEnd = tStart.Value.AddDays(tDur - 1);
                lastEndDate = taskEnd.AddDays(1);
            }
            else
            {
                taskStart = lastEndDate;
                taskEnd = lastEndDate.AddDays(tDur - 1);
                lastEndDate = taskEnd.AddDays(1);
            }

            if (predMap.TryGetValue(tName, out var predNames) && predNames.Count > 0)
            {
                var maxPredEnd = taskStart;
                foreach (var pn in predNames)
                {
                    if (taskMap.TryGetValue(pn, out var predTask) && predTask.PlanEndDate > maxPredEnd)
                        maxPredEnd = predTask.PlanEndDate.AddDays(1);
                }
                if (maxPredEnd > taskStart)
                {
                    taskStart = maxPredEnd;
                    taskEnd = taskStart.AddDays(tDur - 1);
                }
            }

            var task = new Models.TaskItem
            {
                ProjectId = pid,
                Name = tName,
                Code = $"T-{taskMap.Count + 1}",
                PlanDuration = tDur,
                PlanStartDate = taskStart,
                PlanEndDate = taskEnd,
                ResponsiblePerson = tResp,
                IsMilestone = tIsMs,
                CompletionPercentage = 0,
                CreatedAt = DateTime.Now
            };

            var createdTask = await ProjectService.CreateTaskAsync(task);
            taskMap[tName] = createdTask;
            lastEndDate = taskEnd.AddDays(1);

            if (taskEnd > planEnd)
                planEnd = taskEnd;
        }

        foreach (var kv in parentMap)
        {
            if (taskMap.TryGetValue(kv.Key, out var childTask) && taskMap.TryGetValue(kv.Value, out var parentTask))
            {
                childTask.ParentTaskId = parentTask.Id;
                childTask.OutlineLevel = parentTask.OutlineLevel + 1;
                await ProjectService.UpdateTaskAsync(childTask);
            }
        }

        foreach (var kv in predMap)
        {
            if (!taskMap.TryGetValue(kv.Key, out var successorTask)) continue;
            foreach (var predName in kv.Value)
            {
                if (taskMap.TryGetValue(predName, out var predecessorTask))
                {
                    try
                    {
                        await ProjectService.CreateRelationAsync(new Models.TaskRelation
                        {
                            ProjectId = pid,
                            SuccessorTaskId = successorTask.Id,
                            PredecessorTaskId = predecessorTask.Id,
                            Type = Models.RelationType.FS,
                            Lag = 0
                        });
                    }
                    catch { }
                }
            }
        }

        created.PlanEndDate = planEnd;
        await ProjectService.UpdateProjectAsync(created);

        var milestoneCount = taskDefList.Count(t => t.IsMs);
        var totalDur = taskDefList.Sum(t => t.Duration);

        return $"✅ 已创建项目「{created.Name}」ID={pid}\n" +
               $"   📋 共 {taskDefList.Count} 个任务 | 总工时 {totalDur}天 | 里程碑 {milestoneCount}个\n" +
               $"   🔗 父子关系 {parentMap.Count}条 | 依赖关系 {predMap.Sum(kv => kv.Value.Count)}条\n" +
               $"   📅 {planStart:yyyy-MM-dd} → {planEnd:yyyy-MM-dd}";
    }

    private async Task<string> ExecuteCreateProject(Dictionary<string, object> args)
    {
        var name = GetArgString(args, "name") ?? "新项目";
        var code = GetArgString(args, "code") ?? "PROJ-" + DateTime.Now.ToString("MMddHHmmss");
        var desc = GetArgString(args, "description");
        var planStart = GetArgDate(args, "planStartDate") ?? DateTime.Today;
        var planEnd = GetArgDate(args, "planEndDate") ?? planStart.AddMonths(1);

        var duration = GetArgInt(args, "duration") ?? GetArgInt(args, "planDuration");
        if (!args.ContainsKey("planEndDate") && duration.HasValue)
            planEnd = planStart.AddDays(duration.Value - 1);

        var project = new Project
        {
            Name = name,
