    private async Task<string> ExecuteGetProjectOverview(Dictionary<string, object> args)
    {
        var pid = GetArgInt(args, "projectId") ?? 0;
        if (pid <= 0) return "❌ 缺少 projectId 参数";
        try
        {
            var overview = await AnalysisService.GetProjectOverviewAsync(pid);
            var tasks = await ProjectService.GetTasksByProjectIdAsync(pid);
            var total = tasks.Count;
            var done = tasks.Count(t => t.CompletionPercentage >= 100);
            var overallPct = total > 0 ? Math.Round(done * 100.0 / total, 1) : 0;
            if (overview == null) return $"❌ 项目 ID={pid} 无概况数据";
            var sb = new System.Text.StringBuilder();
            sb.AppendLine($"📊 **项目概况：{overview.ProjectName}**");
            sb.AppendLine($"- 总任务数：{overview.TotalTasks}");
            sb.AppendLine($"- 关键路径任务：{overview.CriticalTasks}（总时差 {overview.TotalFloat ?? 0}天）");
            sb.AppendLine($"- 项目工期：{overview.CriticalPathLength:F0}天");
            sb.AppendLine($"- 计划工期：{overview.PlanStartDate:yyyy-MM-dd} → {overview.PlanEndDate:yyyy-MM-dd}");
            sb.AppendLine($"- 整体进度：{overallPct}%（{done}/{total}任务已完成）");
            sb.AppendLine($"- 延迟任务：{overview.DelayedTasks}个 ／ 提前任务：{overview.AcceleratedTasks}个");
            return sb.ToString();
        }
        catch (Exception ex) { return $"❌ 获取概况失败：{ex.Message}"; }
    }

    private async Task<string> ExecuteGetEvmAnalysis(Dictionary<string, object> args)
    {
        var pid = GetArgInt(args, "projectId") ?? 0;
        if (pid <= 0) return "❌ 缺少 projectId 参数";
        try
        {
            var evm = await AnalysisService.GetEarnedValueAsync(pid);
            if (evm == null) return $"❌ 项目 ID={pid} 无 EVM 数据";
            var sb = new System.Text.StringBuilder();
            var spiStatus = evm.SchedulePerformanceIndex >= 1.0 ? "🟢 正常" : evm.SchedulePerformanceIndex >= 0.9 ? "🟡 预警" : "🔴 滞后";
            var cpiStatus = evm.CostPerformanceIndex >= 1.0 ? "🟢 正常" : evm.CostPerformanceIndex >= 0.9 ? "🟡 预警" : "🔴 超支";
            sb.AppendLine($"💰 **挣值分析（EVM）**");
            sb.AppendLine($"- 计划价值 PV：{evm.PlannedValue:N0} | 挣值 EV：{evm.EarnedValue:N0} | 实际成本 AC：{evm.ActualCost:N0}");
            sb.AppendLine($"- **SPI（进度绩效）**：{evm.SchedulePerformanceIndex:F2}（{spiStatus}）");
            sb.AppendLine($"- **CPI（成本绩效）**：{evm.CostPerformanceIndex:F2}（{cpiStatus}）");
            sb.AppendLine($"- **CSI（综合绩效）**：{evm.CostScheduleIndex:F2}（{(evm.CostScheduleIndex >= 0.9 ? "✅ 可控" : "⚠️ 关注")}）");
            sb.AppendLine($"- 进度偏差 SV：{evm.ScheduleVariance:F0} | 成本偏差 CV：{evm.CostVariance:F0}");
            sb.AppendLine($"- 总预算 BAC：{evm.BudgetAtCompletion:N0} | 估算完工 EAC：{evm.EstimateAtCompletion:N0}");
            if (evm.MonthlyTrend.Count > 1)
            {
                var trend = evm.MonthlyTrend.OrderByDescending(m => m.Month).Take(3).ToList();
                sb.AppendLine($"- SPI 近期趋势：{string.Join(" → ", trend.Select(m => $"{m.Month}({m.SPI:F2})"))}");
            }
            return sb.ToString();
        }
        catch (Exception ex) { return $"❌ 获取 EVM 分析失败：{ex.Message}"; }
    }

    private async Task<string> ExecuteGetStageCompletion(Dictionary<string, object> args)
    {
        var pid = GetArgInt(args, "projectId") ?? 0;
        if (pid <= 0) return "❌ 缺少 projectId 参数";
        try
        {
            var sc = await AnalysisService.GetStageCompletionAsync(pid);
            if (sc == null) return $"❌ 项目 ID={pid} 无阶段数据";
            var sb = new System.Text.StringBuilder();
            sb.AppendLine($"📋 **阶段/分组完成率（{sc.DetectionMethod}）**");
            sb.AppendLine($"- ⚠️ 注意：以下每个阶段包含多个任务，百分比和计数为阶段总统计，非单个任务数据");
            sb.AppendLine($"- 整体：{sc.CompletedStages}/{sc.TotalStages} 阶段完成，完成率 {sc.OverallPct:F1}%");
            foreach (var s in sc.Stages.Take(8))
            {
                var icon = s.Status == "completed" ? "✅" : s.Status == "in_progress" ? "🔄" : s.Status == "delayed" ? "🔴" : "⏳";
                var delay = s.DelayDays.HasValue && s.DelayDays != 0 ? $"，偏差 {s.DelayDays}天" : "";
                sb.AppendLine($"  {icon} 【阶段】{s.StageName}：计划 {s.PlannedCompletionPct}% / 实际 {s.ActualCompletionPct}%（阶段内 {s.CompletedTasks}/{s.TotalTasks}任务已完成）{delay}");
            }
            return sb.ToString();
        }
        catch (Exception ex) { return $"❌ 获取阶段完成率失败：{ex.Message}"; }
    }

    private async Task<string> ExecuteGetScheduleVariance(Dictionary<string, object> args)
    {
        var pid = GetArgInt(args, "projectId") ?? 0;
        if (pid <= 0) return "❌ 缺少 projectId 参数";
        try
        {
            var sv = await AnalysisService.GetScheduleVarianceAsync(pid);
            if (sv == null) return $"❌ 项目 ID={pid} 无偏差数据";
            var sb = new System.Text.StringBuilder();
            sb.AppendLine($"⏱ **工期偏差分析**");
            sb.AppendLine($"- ✅ 提前完成：{sv.AheadCount}个 | ⏱ 按时完成：{sv.OnTimeCount}个 | 🔴 延后完成：{sv.BehindCount}个 | ⏳ 进行中：{sv.InProgressCount}个 | 📋 未开始：{sv.NotStartedCount}个");
            if (sv.TotalDelayDays > 0)
                sb.AppendLine($"- 累计延后天数：{sv.TotalDelayDays}天");
            if (sv.TotalAheadDays > 0)
                sb.AppendLine($"- 累计提前天数：{sv.TotalAheadDays}天");
            if (sv.Items.Any(i => i.Status == "behind"))
            {
                sb.AppendLine($"\n**延后任务 TOP5：**");
                foreach (var item in sv.Items.Where(i => i.Status == "behind").OrderByDescending(i => Math.Abs(i.VarianceDays ?? 0)).Take(5))
                {
                    var planEnd = item.PlanEnd.ToString("MM/dd");
                    var actualEnd = item.ActualEnd?.ToString("MM/dd") ?? "未完成";
                    var delayDays = Math.Abs(item.VarianceDays ?? 0);
                    sb.AppendLine($"  🔴 {item.TaskCode} {item.TaskName}：计划 {planEnd}，实际 {actualEnd}，延后 {delayDays}天{(item.IsCritical ? " ⚠️ 关键路径" : "")}");
                }
            }
            return sb.ToString();
        }
        catch (Exception ex) { return $"❌ 获取工期偏差失败：{ex.Message}"; }
    }

    private async Task<string> ExecuteGetCriticalPath(Dictionary<string, object> args)
    {
        var pid = GetArgInt(args, "projectId") ?? 0;
        if (pid <= 0) return "❌ 缺少 projectId 参数";
        try
        {
            var project = await ProjectService.GetProjectByIdAsync(pid);
            if (project == null) return $"❌ 项目 ID={pid} 不存在";
            var tasks = await ProjectService.GetTasksByProjectIdAsync(pid);
            var analysis = AnalysisService.AnalyzeProject(project, tasks);
            if (analysis == null || !analysis.CriticalPathTasks.Any())
                return $"项目 ID={pid} 无关键路径数据";
            var sb = new System.Text.StringBuilder();
            sb.AppendLine($"🔴 **关键路径（共 {analysis.CriticalPathTasks.Count} 个任务）**");
            foreach (var t in analysis.CriticalPathTasks.Take(10))
            {
                var floatStr = t.TotalFloat.HasValue ? $"时差={t.TotalFloat}天" : "";
                var respStr = string.IsNullOrEmpty(t.ResponsiblePerson) ? "" : $"负责人={t.ResponsiblePerson}";
                sb.AppendLine($"  🔴 {t.Code} {t.Name}：{t.PlanStartDate:MM/dd}→{t.PlanEndDate:MM/dd}（{t.PlanDuration}天）{floatStr} {respStr}");
            }
            if (analysis.CriticalPathTasks.Count > 10)
                sb.AppendLine($"  ... 还有 {analysis.CriticalPathTasks.Count - 10} 个关键任务");
            sb.AppendLine($"\n- 项目工期：{analysis.ProjectDurationDays}天");
            sb.AppendLine($"- 关键路径长度：{analysis.CriticalPathTasks.Count}个任务");
            return sb.ToString();
        }
        catch (Exception ex) { return $"❌ 获取关键路径失败：{ex.Message}"; }
    }

    // ===== JSON 解析容错 =====

    private static Dictionary<string, object>? TryDeserializeArgs(string json)
    {
        if (string.IsNullOrWhiteSpace(json)) return null;
        try
        {
            // 1. 标准解析
            return System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, object>>(json);
        }
        catch
        {
            try
            {
                // 2. 宽松解析：将未加引号的键名加引号
                var fixedJson = System.Text.RegularExpressions.Regex.Replace(json,
                    @"(?<=[\{\,])\s*([a-zA-Z_][a-zA-Z0-9_]*)\s*:", m => $"\"{m.Groups[1].Value}\":");
                return System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, object>>(fixedJson);
            }
            catch
            {
                try
                {
                    // 3. 进一步宽松：处理单引号键名
                    var fixedJson2 = System.Text.RegularExpressions.Regex.Replace(json,
                        @"'([^']+)'\s*:", m => $"\"{m.Groups[1].Value}\":");
                    return System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, object>>(fixedJson2);
                }
                catch { return null; }
            }
        }
    }

    // ===== 参数获取辅助方法 =====

    private static string? GetArgString(Dictionary<string, object> args, string primaryKey)
    {
        var keys = new[] { primaryKey, ToSnakeCase(primaryKey), ToUnderscore(primaryKey) };
        foreach (var k in keys)
        {
            if (args.TryGetValue(k, out var v) && v != null)
            {
                var s = JsonElementToString(v);
                if (!string.IsNullOrEmpty(s)) return s;
            }
        }
        foreach (var kv in args)
        {
            if (string.Equals(kv.Key, primaryKey, StringComparison.OrdinalIgnoreCase) ||
                string.Equals(kv.Key, primaryKey.Replace("_", ""), StringComparison.OrdinalIgnoreCase))
            {
                var s = JsonElementToString(kv.Value);
                if (!string.IsNullOrEmpty(s)) return s;
            }
        }
        return null;
    }

    private static string? JsonElementToString(object? value)
    {
        if (value == null) return null;
        if (value is System.Text.Json.JsonElement je)
        {
            return je.ValueKind switch
            {
                System.Text.Json.JsonValueKind.String => je.GetString(),
                System.Text.Json.JsonValueKind.Number => je.GetRawText(),
                System.Text.Json.JsonValueKind.True => "true",
                System.Text.Json.JsonValueKind.False => "false",
                _ => je.GetRawText()
            };
        }
        return value.ToString();
    }

    private static DateTime? GetArgDate(Dictionary<string, object> args, string primaryKey)
    {
        var val = GetArgString(args, primaryKey);
        if (val == null) return null;
        val = val.Replace('－', '-').Replace('／', '/').Replace('．', '-');
        if (DateTime.TryParse(val, out var dt1)) return dt1;
        if (DateTime.TryParseExact(val, "yyyy-MM-dd", null, System.Globalization.DateTimeStyles.None, out var dt2)) return dt2;
        if (DateTime.TryParseExact(val, "yyyy/M/d", null, System.Globalization.DateTimeStyles.None, out var dt3)) return dt3;
        if (DateTime.TryParseExact(val, "yyyy-M-d", null, System.Globalization.DateTimeStyles.None, out var dt4)) return dt4;
        return null;
    }

    private static int? GetArgInt(Dictionary<string, object> args, string primaryKey)
    {
        var val = GetArgString(args, primaryKey);
        if (val == null)
        {
            var keys = new[] { primaryKey, ToSnakeCase(primaryKey) };
            foreach (var k in keys)
            {
                if (args.TryGetValue(k, out var v) && v is System.Text.Json.JsonElement je && je.ValueKind == System.Text.Json.JsonValueKind.Number)
                {
                    if (je.TryGetInt32(out var n)) return n;
                }
            }
            return null;
        }
        if (int.TryParse(val, out var i)) return i;
        return null;
    }

    private static string ToSnakeCase(string s) =>
        string.Concat(s.Select((c, i) => i > 0 && char.IsUpper(c) ? "_" + char.ToLower(c) : char.ToLower(c).ToString()));

    private static string ToUnderscore(string s) => s.Replace("-", "_");

    // ===== 项目创建上下文 =====

    private static bool IsCreationMessage(string msg)
    {
        if (string.IsNullOrWhiteSpace(msg)) return false;
        var lower = msg.ToLower();
        if (lower.Contains("创建") || lower.Contains("新建") || lower.Contains("添加任务")) return true;
        // 长文本带工程关键词也视为创建意图
        if (msg.Length > 60)
        {
            var projKeywords = new[] { "工程", "施工", "工地", "项目", "工期", "开工", "挖泥", "抛石", "浇筑", "预制", "安装", "防波堤", "沉箱", "胸墙", "装修", "建设" };
            if (projKeywords.Any(k => msg.Contains(k))) return true;
        }
        return false;
    }

    private static bool IsNaturalLanguageProject(string msg)
    {
        if (string.IsNullOrWhiteSpace(msg)) return false;
        if (msg.Length < 80 || msg.Length > 5000) return false;
        var keywords = new[] { "工程", "施工", "工期", "开工", "天", "挖泥", "抛石", "浇筑", "预制", "安装", "设备", "船", "防波堤", "沉箱", "胸墙", "装修" };
        return keywords.Any(k => msg.Contains(k));
    }

    private string? BuildProjectCreationContext(string userMsg)
    {
        if (!IsCreationMessage(userMsg)) return null;

        var projectInfo = new Dictionary<string, string>();
        var rawDescriptions = new List<string>();

        for (int i = _sessionStartIndex; i < _chatMessages.Count; i++)
        {
            var m = _chatMessages[i];
            if (m.Role != "user" || m.Content == null) continue;
            var c = m.Content;

            var nameMatch = System.Text.RegularExpressions.Regex.Match(c, @"名称[：:]\s*(\S+)");
            if (nameMatch.Success) projectInfo["名称"] = nameMatch.Groups[1].Value;

            var dateMatch = System.Text.RegularExpressions.Regex.Match(c, @"(\d{4}[-/年]\d{1,2}[-/月]\d{1,2})");
            if (dateMatch.Success) projectInfo["开始日期"] = dateMatch.Groups[1].Value;

            var durMatch = System.Text.RegularExpressions.Regex.Match(c, @"(?:总)?工期[^0-9]*?(\d+)\s*天");
            if (durMatch.Success && !projectInfo.ContainsKey("工期"))
                projectInfo["工期"] = durMatch.Groups[1].Value + "天";

            if (c.Length > 5 && (c.Contains("天") || c.Contains("任务") || c.Contains("项目") || c.Contains("名称")))
                rawDescriptions.Add(c);
        }

        if (projectInfo.Count == 0 && rawDescriptions.Count == 0) return null;

        var summary = "【项目创建上下文 - 用户已提供的信息】\n";
        foreach (var kv in projectInfo)
            summary += $"- {kv.Key}: {kv.Value}\n";
        if (rawDescriptions.Count > 0)
        {
            summary += "\n【用户原始描述 — 请直接用 NLP 从中解析任务列表，不要人工计数】\n";
            foreach (var desc in rawDescriptions)
                summary += $"{desc}\n---\n";
        }
        summary += "上述是用户已经提供过的信息，不要再重复询问。如果信息齐全，请立即用 create_project_with_tasks 创建。";

        return summary;
    }

