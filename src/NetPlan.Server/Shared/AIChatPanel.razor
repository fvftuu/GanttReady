    private List<AiToolCall>? TryParseToolCallsFromText(string? text)
    {
        if (string.IsNullOrWhiteSpace(text)) return null;
        var calls = new List<AiToolCall>();

        // Pattern 1: XML <invoke name="xxx">...</invoke>
        try
        {
            var tcMatch = System.Text.RegularExpressions.Regex.Match(text,
                @"<\s*tool_calls\s*>(.*?)<\s*/\s*tool_calls\s*>",
                System.Text.RegularExpressions.RegexOptions.Singleline);
            var innerXml = tcMatch.Success ? tcMatch.Groups[1].Value : text;

            var invokeRegex = new System.Text.RegularExpressions.Regex(
                @"<\s*invoke\s+name\s*=\s*""(\w+)""\s*>(.*?)<\s*/\s*invoke\s*>",
                System.Text.RegularExpressions.RegexOptions.Singleline);
            var invokeMatch = invokeRegex.Match(innerXml);
            if (invokeMatch.Success)
            {
                var rawName = invokeMatch.Groups[1].Value;
                if (_toolNameMap.TryGetValue(rawName, out var mappedName))
                {
                    var paramsXml = invokeMatch.Groups[2].Value;
                    var args = new Dictionary<string, object>();
                    var paramRegex = new System.Text.RegularExpressions.Regex(
                        @"<\s*parameter\s+name\s*=\s*""(\w+)""[^>]*>(.*?)<\s*/\s*parameter\s*>",
                        System.Text.RegularExpressions.RegexOptions.Singleline);
                    foreach (System.Text.RegularExpressions.Match m in paramRegex.Matches(paramsXml))
                    {
                        var rawParam = m.Groups[1].Value;
                        var val = m.Groups[2].Value.Trim();
                        if (_paramNameMap.TryGetValue(rawParam, out var mappedParam))
                        {
                            if (int.TryParse(val, out var intVal)) args[mappedParam] = intVal;
                            else if (bool.TryParse(val, out var boolVal)) args[mappedParam] = boolVal;
                            else args[mappedParam] = val;
                        }
                    }
                    calls.Add(new AiToolCall
                    {
                        Id = $"call_txt_{Guid.NewGuid():N}",
                        FunctionName = mappedName,
                        FunctionArguments = System.Text.Json.JsonSerializer.Serialize(args)
                    });
                    return calls;
                }
            }
        }
        catch { }

        // Pattern 2: function_name(param1: val1, param2: val2)
        try
        {
            var fnRegex = new System.Text.RegularExpressions.Regex(
                @"(\w+)\s*\(\s*([^)]*)\s*\)");
            foreach (System.Text.RegularExpressions.Match m in fnRegex.Matches(text))
            {
                var rawName = m.Groups[1].Value;
                if (_toolNameMap.TryGetValue(rawName, out var mappedName))
                {
                    var args = new Dictionary<string, object>();
                    var paramText = m.Groups[2].Value;
                    var pairs = paramText.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
                    foreach (var pair in pairs)
                    {
                        var eqIdx = pair.IndexOf(':');
                        if (eqIdx < 0) eqIdx = pair.IndexOf('=');
                        if (eqIdx > 0)
                        {
                            var k = pair[..eqIdx].Trim();
                            var v = pair[(eqIdx + 1)..].Trim().Trim('"').Trim('\'');
                            if (_paramNameMap.TryGetValue(k, out var mappedK))
                            {
                                if (int.TryParse(v, out var intVal)) args[mappedK] = intVal;
                                else if (bool.TryParse(v, out var boolVal)) args[mappedK] = boolVal;
                                else args[mappedK] = v;
                            }
                        }
                    }
                    calls.Add(new AiToolCall
                    {
                        Id = $"call_txt_{Guid.NewGuid():N}",
                        FunctionName = mappedName,
                        FunctionArguments = System.Text.Json.JsonSerializer.Serialize(args)
                    });
                }
            }
            if (calls.Count > 0) return calls;
        }
        catch { }

        return null;
    }

    private string? StripToolCallText(string? text)
    {
        if (string.IsNullOrWhiteSpace(text)) return text;
        text = System.Text.RegularExpressions.Regex.Replace(
            text,
            @"<\s*invoke\s+name\s*=\s*""(\w+)""\s*>.*?<\s*/\s*invoke\s*>",
            "",
            System.Text.RegularExpressions.RegexOptions.Singleline);
        text = System.Text.RegularExpressions.Regex.Replace(
            text,
            @"(\w+)\s*\([^)]*\)\s*",
            m =>
            {
                var name = m.Groups[1].Value;
                return _toolNameMap.ContainsKey(name) ? "" : m.Value;
            });
        return text.Trim();
    }

    // ===== 自然语言→施工计划 =====

    private async Task<string> ExecuteCreateProjectFromJson(Dictionary<string, object> args)
    {
        var json = GetArgString(args, "project_json");
        if (string.IsNullOrEmpty(json)) return "❌ 参数 project_json 为空";

        try
        {
            using var doc = JsonDocument.Parse(json);
            var root = doc.RootElement;

            _previewProject = new PreviewProject
            {
                ProjectName = root.TryGetProperty("projectName", out var pn) ? pn.GetString() ?? "未命名项目" : "未命名项目",
                ProjectDescription = root.TryGetProperty("projectDescription", out var pd) ? pd.GetString() ?? "" : "",
                PlanStartDate = (root.TryGetProperty("planStartDate", out var psEl) && DateTime.TryParse(psEl.GetString(), out var parsedDt)) ? parsedDt : DateTime.Today,
                TotalDuration = root.TryGetProperty("totalDuration", out var td) && td.TryGetInt32(out var dur) ? dur : 0,
                Tasks = new List<PreviewTask>(),
                Resources = new List<PreviewResource>()
            };

            if (root.TryGetProperty("tasks", out var tasksEl))
            {
                foreach (var t in tasksEl.EnumerateArray())
                {
                    var task = new PreviewTask
                    {
                        Code = t.TryGetProperty("code", out var c) ? c.GetString() ?? "" : "",
                        Name = t.TryGetProperty("name", out var n) ? n.GetString() ?? "" : "",
                        Duration = t.TryGetProperty("duration", out var d) && d.TryGetInt32(out var durVal) ? durVal : 1,
                        ParentCode = t.TryGetProperty("parentCode", out var pc) && pc.ValueKind == System.Text.Json.JsonValueKind.String ? pc.GetString() : null,
                        TaskStartDate = t.TryGetProperty("planStartDate", out var ps) && DateTime.TryParse(ps.GetString(), out var parsedDate) ? parsedDate : (t.TryGetProperty("startDate", out var sd) && DateTime.TryParse(sd.GetString(), out var parsedSd) ? parsedSd : (DateTime?)null),
                        WorkType = t.TryGetProperty("workType", out var wt) ? wt.GetString() ?? "land" : "land",
                        Assignee = t.TryGetProperty("assignee", out var a) ? a.GetString() ?? "" : "",
                        Predecessors = new List<string>(),
                        Resources = new List<string>()
                    };
                    if (t.TryGetProperty("predecessors", out var preds))
                    {
                        foreach (var p in preds.EnumerateArray())
                            task.Predecessors.Add(p.GetString() ?? "");
                    }
                    if (t.TryGetProperty("resources", out var res))
                    {
                        foreach (var r in res.EnumerateArray())
                            task.Resources.Add(r.GetString() ?? "");
                    }
                    _previewProject.Tasks.Add(task);
                }
            }

            if (root.TryGetProperty("resources", out var resEl))
            {
                foreach (var r in resEl.EnumerateArray())
                {
                    _previewProject.Resources.Add(new PreviewResource
                    {
                        Name = r.TryGetProperty("name", out var rn) ? rn.GetString() ?? "" : "",
                        Type = r.TryGetProperty("type", out var rt) ? rt.GetString() ?? "equipment" : "equipment",
                        Quantity = r.TryGetProperty("quantity", out var q) && q.TryGetInt32(out var qv) ? qv : 1
                    });
                }
            }

            _showPreview = true;
            StateHasChanged();

            return $"📋 已解析 {_previewProject.Tasks.Count} 个任务、{_previewProject.Resources.Count} 项资源，请确认后创建。";
        }
        catch (Exception ex)
        {
            return $"❌ JSON 解析失败：{ex.Message}";
        }
    }

    private async Task ConfirmCreateProject()
    {
        if (_previewProject == null) return;
        try
        {
            // 创建项目
            var proj = new Project
            {
                Name = _previewProject.ProjectName,
                Description = _previewProject.ProjectDescription,
                Code = "PROJ-" + DateTime.Now.ToString("MMddHHmmss"),
                PlanStartDate = _previewProject.PlanStartDate,
                PlanEndDate = _previewProject.PlanStartDate.AddDays(Math.Max(1, _previewProject.TotalDuration)),
                WorkingHoursPerDay = 8
            };
            proj = await ProjectService.CreateProjectAsync(proj);
            var projectId = proj.Id;

            // 创建任务（第一遍：全部创建，记录 ID）
            var taskCodeToId = new Dictionary<string, int>();
            foreach (var t in _previewProject.Tasks)
            {
                var task = new TaskItem
                {
                    ProjectId = projectId,
                    Code = string.IsNullOrEmpty(t.Code) ? $"T{_previewProject.Tasks.IndexOf(t) + 1}" : t.Code,
                    Name = t.Name,
                    PlanDuration = t.Duration,
                    PlanStartDate = t.TaskStartDate ?? _previewProject.PlanStartDate,
                    PlanEndDate = (t.TaskStartDate ?? _previewProject.PlanStartDate).AddDays(t.Duration - 1),
                    SortOrder = _previewProject.Tasks.IndexOf(t) + 1
                };
                task = await ProjectService.CreateTaskAsync(task);
                taskCodeToId[t.Code] = task.Id;
            }

            // 设置父任务（第二遍：有 parentCode 的设 ParentTaskId）
            foreach (var t in _previewProject.Tasks.Where(t => !string.IsNullOrEmpty(t.ParentCode)))
            {
                if (!taskCodeToId.TryGetValue(t.Code, out var childId)) continue;
                if (!taskCodeToId.TryGetValue(t.ParentCode!, out var parentId)) continue;
                var child = await ProjectService.GetTaskByIdAsync(childId);
                if (child != null)
                {
                    child.ParentTaskId = parentId;
                    await ProjectService.UpdateTaskAsync(child);
                }
            }

            // 创建前置关系
            foreach (var t in _previewProject.Tasks.Where(t => t.Predecessors.Any()))
            {
                if (!taskCodeToId.TryGetValue(t.Code, out var succId)) continue;
                foreach (var predCode in t.Predecessors)
                {
                    if (!taskCodeToId.TryGetValue(predCode, out var predId)) continue;
                    await ProjectService.CreateRelationAsync(new TaskRelation
                    {
                        ProjectId = projectId,
                        PredecessorTaskId = predId,
                        SuccessorTaskId = succId,
                        Type = RelationType.FS,
                        Lag = 0
                    });
                }
            }

            // 创建资源
            var resourceNameToId = new Dictionary<string, int>();
            foreach (var r in _previewProject.Resources)
            {
                var res = await ResourceService.CreateResourceAsync(new Resource
                {
                    ProjectId = projectId,
                    Name = r.Name,
                    Code = "R" + (_previewProject.Resources.IndexOf(r) + 1).ToString("D2"),
                    Type = r.Type == "labor" ? ResourceType.Labor : r.Type == "material" ? ResourceType.Material : ResourceType.Equipment,
                    Quantity = r.Quantity
                });
                resourceNameToId[r.Name] = res.Id;
            }

            // 创建资源分配（任务→资源匹配）
            foreach (var t in _previewProject.Tasks.Where(t => t.Resources.Any()))
            {
                if (!taskCodeToId.TryGetValue(t.Code, out var taskId)) continue;
                foreach (var rName in t.Resources)
                {
                    if (!resourceNameToId.TryGetValue(rName, out var resId)) continue;
                    await ResourceService.CreateAssignmentAsync(new ResourceAssignment
                    {
                        TaskId = taskId,
                        ResourceId = resId,
                        Quantity = 1
                    });
                }
            }

            // 重算 CPM
            await ProjectService.CalculateScheduleAsync(projectId);

            _showPreview = false;
            _previewProject = null;

            // 导航到甘特图
            Nav.NavigateTo($"/project/{projectId}/gantt");

            return; // 导航后将不会执行后续代码
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"创建失败：{ex.Message}");
        }
    }

    private void CancelCreateProject()
    {
