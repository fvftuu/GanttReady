@inject IJSRuntime JS
@inject NavigationManager Nav
@inject IProjectService ProjectService
@inject IAnalysisService AnalysisService
@inject IResourceService ResourceService
@inject IAiService AiService

@* ===== AI 聊天面板（右侧滑出）===== *@
@if (Visible)
{
    <div style="position:fixed;top:0;right:0;bottom:0;width:380px;background:#fff;border-left:1px solid #e8e8e8;box-shadow:-4px 0 24px rgba(0,0,0,0.1);z-index:1000;display:flex;flex-direction:column;animation:slideIn 0.25s ease;">
        @* 标题栏 *@
        <div style="padding:14px 16px;background:#4f6ef7;color:#fff;display:flex;align-items:center;gap:8px;">
            <span style="font-size:18px;">🤖</span>
            <span style="font-weight:600;">AI 助手</span>
            @if (!string.IsNullOrEmpty(_currentModelName))
            {
                <span style="font-size:11px;background:rgba(255,255,255,0.2);padding:2px 8px;border-radius:8px;flex-shrink:0;">@_currentModelName</span>
            }
            <div style="flex:1;"></div>
            <button class="btn btn-sm" style="color:#fff;border:none;background:transparent;font-size:18px;cursor:pointer;" @onclick="Close">✕</button>
        </div>
        @* 快捷问题 *@
        @if (_suggestedQuestions.Any() && !_chatMessages.Skip(1).Any())
        {
            <div style="padding:0 12px 8px;display:flex;flex-wrap:wrap;gap:6px;">
                @foreach (var q in _suggestedQuestions)
                {
                    <button @onclick="() => AskQuickQuestion(q)"
                            style="border:1px solid #d6e4ff;background:#f6f8ff;color:#4f6ef7;border-radius:14px;padding:4px 12px;font-size:12px;cursor:pointer;white-space:nowrap;transition:all 0.15s;"
                            onmouseover="this.style.background='#e6f0ff'" onmouseout="this.style.background='#f6f8ff'">
                        @q
                    </button>
                }
            </div>
        }
        @* 消息列表 *@
        <div @ref="_messageContainer" style="flex:1;overflow-y:auto;padding:12px;display:flex;flex-direction:column;gap:8px;" id="chat-messages">
            @foreach (var msg in _chatMessages)
            {
                var isUser = msg.Role == "user";
                var isTool = msg.Role == "tool";
                <div style="display:flex;@(isUser ? "justify-content:flex-end;" : "")">
                    <div style="max-width:85%;padding:8px 12px;border-radius:10px;@(isUser ? "background:#4f6ef7;color:#fff;border-radius:10px 10px 2px 10px;" : "background:#f0f2f5;border-radius:10px 10px 10px 2px;")">
                        <div style="font-size:13px;line-height:1.6;white-space:pre-wrap;@(isTool ? "max-height:200px;overflow-y:auto;font-size:12px;color:#666;" : "")">@GetDisplayContent(msg)</div>
                        @if (msg.Role == "assistant" && msg.Content?.StartsWith("⚠️ 请先在分析页面") == true)
                        {
                            <button @onclick="GoToAiSettings"
                                style="margin-top:6px;border:none;background:#4f6ef7;color:#fff;border-radius:6px;padding:6px 16px;font-size:13px;cursor:pointer;">
                                ⚙️ 前往 AI 设置
                            </button>
                        }
                    </div>
                </div>
            }
            @if (_chatLoading)
            {
                <div style="display:flex;gap:6px;padding:12px;">
                    <span style="width:8px;height:8px;background:#999;border-radius:50%;animation:pulse 1s infinite;"> </span>
                    <span style="width:8px;height:8px;background:#999;border-radius:50%;animation:pulse 1s infinite 0.2s;"> </span>
                    <span style="width:8px;height:8px;background:#999;border-radius:50%;animation:pulse 1s infinite 0.4s;"> </span>
                </div>
            }
        </div>
        @* 工具调用确认区 *@
        @if (_pendingToolCalls?.Count > 0)
        {
            <div style="padding:8px 12px;border-top:1px solid #e8e8e8;background:#fffbe6;">
                @foreach (var tc in _pendingToolCalls)
                {
                    <div style="font-size:12px;margin-bottom:6px;">
                        <div style="font-weight:600;color:#d48806;margin-bottom:4px;">
                            📋 AI 建议操作：@(tc.FunctionName switch
                            {
                                "create_project" => "创建项目",
                                "create_project_with_tasks" => "创建项目（含任务列表）",
                                "create_task" => "创建任务",
                                "update_task" => "修改任务",
                                "get_tasks" => "查询任务列表",
                                "get_all_projects" => "查询项目列表",
                                _ => tc.FunctionName
                            })
                        </div>
                        <pre style="margin:0;font-size:11px;color:#555;white-space:pre-wrap;max-height:120px;overflow-y:auto;">@FormatToolCallArgs(tc)</pre>
                    </div>
                }
                <div style="display:flex;gap:8px;justify-content:flex-end;">
                    <button @onclick="RejectPendingToolCall" disabled="@_executingToolCall"
                            style="border:1px solid #d9d9d9;background:#fff;border-radius:6px;padding:4px 16px;font-size:13px;cursor:pointer;">✕ 拒绝</button>
                    <button @onclick="ExecutePendingToolCall" disabled="@_executingToolCall"
                            style="border:none;background:#4f6ef7;color:#fff;border-radius:6px;padding:4px 16px;font-size:13px;cursor:pointer;">
                        @if (_executingToolCall) { <span>⏳ 执行中...</span> } else { <span>✅ 确认执行</span> }
                    </button>
                </div>
            </div>
        }
        @* 输入区 *@
        <div style="padding:8px 10px;border-top:1px solid #e8e8e8;">
            <div style="display:flex;align-items:flex-end;gap:6px;border:1px solid #d9d9d9;border-radius:8px;padding:4px 4px 4px 12px;background:#fff;transition:border-color 0.15s;" id="chat-input-wrap">
                <textarea @bind="_chatInput" @bind:event="oninput" @onkeydown="OnChatKeyDown" id="chat-textarea"
                    placeholder="问点项目相关的问题..."
                    rows="1"
                    style="border:none;outline:none;box-shadow:none;resize:none;flex:1;font-size:13px;line-height:1.5;height:22px;min-height:22px;max-height:33vh;padding:6px 0;overflow-y:auto;background:transparent;font-family:inherit;"></textarea>
                <button @onclick="SendChatMessage" disabled="@(_chatLoading || string.IsNullOrWhiteSpace(_chatInput))"
                    style="border:none;background:@((_chatLoading || string.IsNullOrWhiteSpace(_chatInput)) ? "#d9d9d9" : "#4f6ef7");color:#fff;width:32px;height:32px;border-radius:6px;cursor:@((_chatLoading || string.IsNullOrWhiteSpace(_chatInput)) ? "not-allowed" : "pointer");display:flex;align-items:center;justify-content:center;font-size:16px;line-height:1;transition:all 0.15s;flex-shrink:0;">
                    ➤
                </button>
            </div>
        </div>
    </div>
}
else
{
    <button class="btn btn-primary" @onclick="ToggleOpen" style="position:fixed;bottom:24px;right:24px;z-index:1001;width:52px;height:52px;border-radius:50%;font-size:24px;padding:0;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 12px rgba(79,110,247,0.4);">
        💬
    </button>
}

<style>
    @@keyframes pulse { 0%,100% { opacity:0.4; } 50% { opacity:1; } }
    @@keyframes slideIn { from { transform:translateX(380px); } to { transform:translateX(0); } }
</style>

@code {
    // ===== 可见性 =====
    [Parameter]
    public bool Visible { get; set; }

    [Parameter]
    public EventCallback<bool> VisibleChanged { get; set; }

    private async Task ToggleOpen()
    {
        Visible = true;
        await VisibleChanged.InvokeAsync(true);
        _ = BuildSuggestedQuestions();
        _ = LoadCurrentModelName();
    }

    private async Task Close()
    {
        Visible = false;
        await VisibleChanged.InvokeAsync(false);
        await SaveChatMessages();
    }

    private void GoToAiSettings()
    {
        Nav.NavigateTo("/analysis");
    }

    // ===== AI 聊天状态 =====
    private string _chatInput = "";
    private bool _chatLoading = false;
    private bool _chatLoaded = false;
    private string _currentModelName = "";
    private List<AiMessage> _chatMessages = new();
    private int _sessionStartIndex = 0;
    private Dictionary<int, string> _projectNameCache = new();
    private ElementReference _messageContainer;
    private List<string> _suggestedQuestions = new();

    // 工具调用
    private List<AiToolCall>? _pendingToolCalls;
    private string? _pendingToolCallMessage;
    private int _chainDepth = 0;
    private bool _executingToolCall = false;
    private int _consecutiveParamErrors = 0;

    // 项目上下文缓存（10 秒 TTL）
    private (string Data, DateTime CachedAt)? _projectContextCache;
    private static readonly TimeSpan _contextCacheTtl = TimeSpan.FromSeconds(10);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_chatLoaded)
        {
            _chatLoaded = true;
            try
            {
                var storedVersion = await JS.InvokeAsync<string>("localStorage.getItem", "chat_msg_v");
                if (storedVersion != "2")
                {
                    await JS.InvokeVoidAsync("localStorage.removeItem", "ai_chat_messages");
                }
                else
                {
                    var json = await JS.InvokeAsync<string>("localStorage.getItem", "ai_chat_messages");
                    if (!string.IsNullOrEmpty(json))
                    {
                        try
                        {
                            var saved = System.Text.Json.JsonSerializer.Deserialize<List<AiMessage>>(json);
                            if (saved != null && saved.Count > 0) _chatMessages = saved;
                        }
                        catch
                        {
                            // 反序列化失败，保留 localStorage 数据，从空白开始
                        }
                    }
                }
            }
            catch { }
            if (_chatMessages.Count == 0)
            {
                _chatMessages.Add(new() { Role = "assistant", Content = "你好！我是 AI 助手，可以问我关于项目进度、资源、任务等方面的问题。" });
            }
            _sessionStartIndex = _chatMessages.Count;
            StateHasChanged();
        }
        // 自动增高输入框 + 聚焦 + 滚到底部
        if (Visible)
        {
            await JS.InvokeVoidAsync("eval", $@"
                (function(){{
                    var ta = document.getElementById('chat-textarea');
                    if(ta){{
                        if(document.activeElement !== ta) setTimeout(()=>ta.focus(),100);
                        ta.style.height='22px';
                        var h=Math.min(ta.scrollHeight,Math.round(window.innerHeight*0.33));
                        ta.style.height=h+'px';
                        if(!ta.hasAttribute('data-chat-bound')){{
                            ta.setAttribute('data-chat-bound','1');
                            ta.addEventListener('keydown',function(ev){{
                                if(ev.key==='Enter'&&!ev.shiftKey){{
                                    ev.preventDefault();
                                }}
                            }});
                        }}
                    }}
                    var mc = document.getElementById('chat-messages');
                    if(mc) mc.scrollTop = mc.scrollHeight;
                }})();
            ");
        }
    }

    private async Task SaveChatMessages()
    {
        try
        {
            // 滑动窗口裁剪：保留最多 25 条对话消息 + 起始索引前的 system 消息
            TrimChatHistory();

            var json = System.Text.Json.JsonSerializer.Serialize(_chatMessages);
            await JS.InvokeVoidAsync("localStorage.setItem", "ai_chat_messages", json);
            await JS.InvokeVoidAsync("localStorage.setItem", "chat_msg_v", "2");
        }
        catch { }
    }

    private void TrimChatHistory()
    {
        const int maxMessages = 30;
        if (_chatMessages.Count <= maxMessages) return;

        // 保留起始索引之前的 system 消息
        var systemBeforeStart = _chatMessages
            .Take(_sessionStartIndex)
            .Where(m => m.Role == "system")
            .ToList();

        // 保留最近的 (maxMessages - systemBeforeStart.Count) 条
        var keepCount = maxMessages - systemBeforeStart.Count;
        if (keepCount < 10) keepCount = 10; // 至少保留 10 条

        var recentMessages = _chatMessages
            .Skip(_sessionStartIndex)
            .Reverse()
            .Take(keepCount)
            .Reverse()
            .ToList();

        _chatMessages = systemBeforeStart
            .Concat(recentMessages)
            .ToList();

        // 更新起始索引
        _sessionStartIndex = systemBeforeStart.Count;
    }

    private async Task LoadCurrentModelName()
    {
        try
        {
            var json = await JS.InvokeAsync<string>("localStorage.getItem", "ai_connections");
            if (string.IsNullOrEmpty(json)) { _currentModelName = ""; return; }
            var list = System.Text.Json.JsonSerializer.Deserialize<List<AiConnection>>(json);
            var active = list?.FirstOrDefault(c => c.IsActive) ?? list?.FirstOrDefault();
            _currentModelName = active?.Model ?? "";
        }
        catch { _currentModelName = ""; }
        StateHasChanged();
    }

    private async Task BuildSuggestedQuestions()
    {
        var qs = new List<string>();
        try
        {
            var uri = new Uri(Nav.Uri);
            var path = uri.AbsolutePath.ToLower();

            if (path.Contains("analysis"))
            {
                try
                {
                    var roleJson = await JS.InvokeAsync<string>("localStorage.getItem", "ai_role");
                    if (roleJson == "operator")
                    {
                        qs.Add("我今天需要关注哪些任务？");
                        qs.Add("哪些任务延后了？原因是什么？");
                        qs.Add("我负责的资源到位了吗？");
                    }
                    else if (roleJson == "investor")
                    {
                        qs.Add("里程碑达成情况怎么样？");
                        qs.Add("预算执行率和超支风险");
                        qs.Add("关键路径有没有偏移？");
                    }
                    else if (roleJson == "executive")
                    {
                        qs.Add("项目健康度简报");
                        qs.Add("需要我决策的事项");
                        qs.Add("预算和进度是否可控？");
                    }
                    else
                    {
                        qs.Add("项目整体状况怎么样？");
                        qs.Add("关键路径有什么风险？");
                        qs.Add("哪些资源存在冲突？");
                        qs.Add("当前最需要处理的问题");
                    }
                }
                catch { }
            }
            else if (path.Contains("gantt"))
            {
                qs.Add("关键路径在哪里？");
                qs.Add("哪些任务延后了？");
                qs.Add("资源分配有没有问题？");
            }
            else if (path.Contains("resources"))
            {
                qs.Add("哪些资源使用最紧张？");
                qs.Add("有没有超额的资源？");
            }
            else
            {
                try
                {
                    var allProjects = await ProjectService.GetAllProjectsAsync();
                    if (allProjects.Count > 0)
                    {
                        qs.Add("所有项目整体情况怎么样？");
                        qs.Add("哪个项目存在问题？");
                    }
                }
                catch { }
            }

            if (qs.Count == 0)
            {
                qs.Add("项目整体进度怎么样？");
                qs.Add("有哪些延后的任务？");
                qs.Add("资源使用情况如何？");
            }
        }
        catch { }
        _suggestedQuestions = qs;
    }

    private async Task AskQuickQuestion(string question)
    {
        _chatInput = question;
        await SendChatMessage();
    }

    private async Task OnChatKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SendChatMessage();
        }
    }

    private async Task<AiOptions?> GetChatAiOptions()
    {
        try
        {
            var json = await JS.InvokeAsync<string>("localStorage.getItem", "ai_connections");
            if (string.IsNullOrEmpty(json)) return null;
            var list = System.Text.Json.JsonSerializer.Deserialize<List<AiConnection>>(json);
            var active = list?.FirstOrDefault(c => c.IsActive) ?? list?.FirstOrDefault();
            if (active == null || string.IsNullOrEmpty(active.Endpoint)) return null;
            return new AiOptions
            {
                Endpoint = active.Endpoint,
                ApiKey = active.ApiKey,
                Model = string.IsNullOrEmpty(active.Model) ? "deepseek-v4-flash" : active.Model,
                ApiFormat = string.IsNullOrEmpty(active.ApiFormat) ? "openai" : active.ApiFormat
            };
        }
        catch { return null; }
    }

    private async Task<string> BuildProjectContext()
    {
        // 缓存命中且在 TTL 内则直接返回
        if (_projectContextCache.HasValue &&
            (DateTime.Now - _projectContextCache.Value.CachedAt) < _contextCacheTtl)
        {
            return _projectContextCache.Value.Data;
        }

        var ctx = new System.Text.StringBuilder();
        try
        {
            var allProjects = await ProjectService.GetAllProjectsAsync();
            ctx.AppendLine($"【项目列表】共 {allProjects.Count} 个项目：");
            foreach (var p in allProjects)
                ctx.AppendLine($"  · ID={p.Id} {p.Name}（{p.Code}） | {p.PlanStartDate:yyyy-MM-dd} → {p.PlanEndDate:yyyy-MM-dd}");
            ctx.AppendLine();

            var totalTasks = 0;
            var completedTasks = 0;
            var grandBudget = 0m;
            var grandActual = 0m;
            foreach (var p in allProjects)
            {
                var tasks = await ProjectService.GetTasksByProjectIdAsync(p.Id);
                totalTasks += tasks.Count;
                var done = tasks.Count(t => t.CompletionPercentage >= 100);
                completedTasks += done;
                var pct = tasks.Count > 0 ? tasks.Average(t => t.CompletionPercentage) : 0;
                var budget = tasks.Sum(t => t.BudgetCost);
                var actual = tasks.Sum(t => t.ActualCost ?? 0);
                grandBudget += budget;
                grandActual += actual;
                var costInfo = budget > 0 ? $" 预算¥{budget:N0}" : "";
                if (actual > 0) costInfo += $" 实际¥{actual:N0}";
                ctx.AppendLine($"  · ID={p.Id} {p.Name}：{tasks.Count}个任务，完成 {done}/{tasks.Count}，平均完成率 {pct:F1}%{costInfo}");
            }
            ctx.AppendLine();
            ctx.AppendLine($"【汇总】共 {allProjects.Count} 个项目，{totalTasks} 个任务，已完成 {completedTasks}/{totalTasks}，总完成率 {(totalTasks > 0 ? 100.0 * completedTasks / totalTasks : 0):F1}%");
            if (grandBudget > 0)
                ctx.AppendLine($"总预算 ¥{grandBudget:N0}，实际录入成本 ¥{grandActual:N0}");
            ctx.AppendLine();
        }
        catch { }

        try
        {
            var analysisJson = await JS.InvokeAsync<string>("localStorage.getItem", "ai_latest_analysis");
            if (!string.IsNullOrEmpty(analysisJson))
                ctx.AppendLine($"【最新 AI 分析报告】\n{analysisJson}\n");
        }
        catch { }

        try
        {
            var uri = new Uri(Nav.Uri);
            var segments = uri.AbsolutePath.Split('/', StringSplitOptions.RemoveEmptyEntries);
            if (segments.Length >= 2 && segments[0] == "project" && int.TryParse(segments[1], out var pid))
            {
                var project = await ProjectService.GetProjectByIdAsync(pid);
                if (project != null)
                {
                    ctx.AppendLine($"【当前项目】{project.Name}（{project.Code}）计划工期 {project.PlanStartDate:yyyy-MM-dd} → {project.PlanEndDate:yyyy-MM-dd}");
                    var tasks = await ProjectService.GetTasksByProjectIdAsync(pid);
                    var result = AnalysisService.AnalyzeProject(project, tasks);
                    if (result != null)
                    {
                        ctx.AppendLine($"【进度概况】总工期 {result.ProjectDurationDays}天 | 总任务 {result.TotalTasks}个 | 按时 {result.OnTimeTasks.Count} / 提前 {result.EarlyStartTasks.Count} / 延后 {result.LateStartTasks.Count}");
                        ctx.AppendLine($"关键路径 {result.CriticalPathTasks.Count}个任务 | 里程碑 {result.Milestones.Count}个");
                        if (result.CriticalPathTasks.Any())
                            ctx.AppendLine($"关键路径：{string.Join(" → ", result.CriticalPathTasks.Take(8).Select(t => t.Name))}");
                        ctx.AppendLine();

                        try
                        {
                            var resSum = await AnalysisService.GetResourceSummaryAsync(pid);
                            if (resSum != null)
                                ctx.AppendLine($"【资源概况】人工 {resSum.LaborCount} / 材料 {resSum.MaterialCount} / 设备 {resSum.EquipmentCount} | 总预算 {resSum.TotalCost:N0}元");
                        }
                        catch { }

                        try
                        {
                            var evm = await AnalysisService.GetEarnedValueAsync(pid);
                            if (evm != null)
                            {
                                var spiIcon = evm.SchedulePerformanceIndex >= 1.0 ? "✅" : evm.SchedulePerformanceIndex >= 0.9 ? "⚠️" : "🔴";
                                var cpiIcon = evm.CostPerformanceIndex >= 1.0 ? "✅" : evm.CostPerformanceIndex >= 0.9 ? "⚠️" : "🔴";
                                ctx.AppendLine($"【挣值分析】SPI {evm.SchedulePerformanceIndex:F2} {spiIcon} | CPI {evm.CostPerformanceIndex:F2} {cpiIcon} | BAC {evm.BudgetAtCompletion:N0}元 | EAC {evm.EstimateAtCompletion:N0}元");
                            }
                        }
                        catch { }

                        try
                        {
                            var assignments = await ResourceService.GetAssignmentsByProjectAsync(pid);
                            var resources = await ResourceService.GetResourcesByProjectAsync(pid);
                            if (resources.Any())
                            {
                                var byRes = assignments.GroupBy(a => a.ResourceId);
                                var conflictCount = 0;
                                foreach (var g in byRes)
                                {
                                    var res = resources.FirstOrDefault(r => r.Id == g.Key);
                                    if (res != null && g.Sum(a => a.Quantity) > res.Quantity)
                                        conflictCount++;
                                }
                                ctx.AppendLine($"资源冲突项目数：{conflictCount} / {resources.Count}");
                            }
                        }
                        catch { }
                    }
                    ctx.AppendLine();
                }
            }
        }
        catch { }
        var contextData = ctx.ToString();
        _projectContextCache = (contextData, DateTime.Now);
        return contextData;
    }

    private int? GetCurrentProjectId()
    {
        try
        {
            var uri = new Uri(Nav.Uri);
            var segments = uri.AbsolutePath.Split('/', StringSplitOptions.RemoveEmptyEntries);
            if (segments.Length >= 2 && segments[0] == "project" && int.TryParse(segments[1], out var pid))
                return pid;
        }
        catch { }
        return null;
    }

    private string GetDisplayContent(AiMessage msg)
    {
        if (msg.Role != "tool") return msg.Content;
        var lines = (msg.Content ?? "").Split('\n', StringSplitOptions.None);
        if (lines.Length <= 8) return msg.Content;
        var truncated = string.Join("\n", lines.Take(8));
        return truncated + $"\n… 还有 {lines.Length - 8} 行（完整数据已提供给 AI）";
    }

    private string FormatToolCallArgs(AiToolCall tc)
    {
        try
        {
            var args = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, object>>(tc.FunctionArguments);
            if (args == null) return tc.FunctionArguments;

            if (tc.FunctionName == "create_project_with_tasks")
            {
                return FormatProjectWithTasksArgs(args);
            }

            var lines = new List<string>();
            foreach (var kv in args)
            {
                if (kv.Key == "tasks") continue;
                var val = kv.Value?.ToString() ?? "";
                if (val.Length > 50) val = val[..50] + "…";

                if ((kv.Key == "projectId" || kv.Key == "project_id") && int.TryParse(val, out var pid) && _projectNameCache.TryGetValue(pid, out var pname))
                {
                    lines.Add($"  📁 项目: {pname}（ID={pid}）");
                }
                else
                {
                    lines.Add($"  {kv.Key}: {val}");
                }
            }
            return string.Join("\n", lines);
        }
        catch
        {
            return tc.FunctionArguments;
        }
    }

    private string FormatProjectWithTasksArgs(Dictionary<string, object> args)
    {
        var lines = new List<string>();
        foreach (var kv in args)
        {
            if (kv.Key == "tasks") continue;
            var val = kv.Value?.ToString() ?? "";
            if (val.Length > 60) val = val[..60] + "…";
            lines.Add($"  {kv.Key}: {val}");
        }
        if (args.TryGetValue("tasks", out var tasksObj) && tasksObj != null)
        {
            try
            {
                var tasksJson = tasksObj.ToString()!;
                var tasks = System.Text.Json.JsonSerializer.Deserialize<List<Dictionary<string, object>>>(tasksJson);
                if (tasks != null && tasks.Count > 0)
                {
                    var totalDays = 0;
                    var milestones = 0;
                    var hasSub = false;
                    foreach (var t in tasks)
                    {
                        if (t.TryGetValue("planDuration", out var d)) totalDays += Convert.ToInt32(d);
                        if (t.TryGetValue("isMilestone", out var m) && (m?.ToString() == "True" || m?.ToString() == "true")) milestones++;
                        if (t.TryGetValue("parentTaskName", out var p) && p != null && !string.IsNullOrEmpty(p.ToString())) hasSub = true;
                    }
                    lines.Add($"  📋 共 {tasks.Count} 个任务 | 总工时 {totalDays}天 | 里程碑 {milestones}个" + (hasSub ? " | 含WBS层级" : ""));
                    lines.Add("");
                    var previewCount = Math.Min(tasks.Count, 12);
                    for (int i = 0; i < previewCount; i++)
                    {
                        var t = tasks[i];
                        var tName = t.GetValueOrDefault("name")?.ToString() ?? "-";
                        var tDur = t.TryGetValue("planDuration", out var td) ? $"{td}天" : "";
                        var tResp = t.TryGetValue("responsiblePerson", out var tr) ? tr?.ToString() : null;
                        var tIcon = t.TryGetValue("isMilestone", out var tm) && (tm?.ToString() == "True" || tm?.ToString() == "true") ? "◆ " : "  ";
                        lines.Add($"  {tIcon}{tName} {(string.IsNullOrEmpty(tDur) ? "" : $"({tDur})")}{(tResp != null ? $" — {tResp}" : "")}");
                    }
                    if (tasks.Count > 12)
                        lines.Add($"  … 还有 {tasks.Count - 12} 个任务");
                }
            }
            catch { }
        }
        return string.Join("\n", lines);
    }

    // ===== 消息发送与 AI 交互 =====

    private async Task SendChatMessage()
    {
        if (string.IsNullOrWhiteSpace(_chatInput) || _chatLoading) return;
        var userMsg = _chatInput.Trim();
        _chatInput = "";
        await JS.InvokeVoidAsync("eval", @"document.getElementById('chat-textarea') && (function(t){t.style.height='22px'})(document.getElementById('chat-textarea'));");
        _chatMessages.Add(new AiMessage { Role = "user", Content = userMsg });

        var creationContext = BuildProjectCreationContext(userMsg);

        await SaveChatMessages();
        _chatLoading = true;
        StateHasChanged();

        try
        {
            var opts = await GetChatAiOptions();
            if (opts == null)
            {
                _chatMessages.Add(new AiMessage { Role = "assistant", Content = "⚠️ 请先在分析页面的「AI 设置」中配置并保存 API 连接。" });
                await SaveChatMessages();
                _chatLoading = false;
                StateHasChanged();
                return;
            }

            var context = await BuildProjectContext();
            var projectInfo = string.IsNullOrEmpty(context) ? "" : $"\n【项目背景数据】\n{context}\n";
            var pid = GetCurrentProjectId() ?? 0;
            var isCreation = IsCreationMessage(userMsg);
            var sysPrompt = isCreation
                ? ChatPromptBuilder.BuildCreationPrompt(projectInfo, pid)
                : ChatPromptBuilder.BuildQueryPrompt(projectInfo, pid);

            _pendingToolCalls = null;
            _pendingToolCallMessage = null;
            _chainDepth = 0;
            _consecutiveParamErrors = 0;

            var tools = AiToolDefinitions.GetAllChainTools();
            var messages = new List<AiMessage>
            {
                new() { Role = "system", Content = sysPrompt }
            };
            Console.Error.WriteLine($"===== Initial request ({messages.Count} base msgs) =====");
            if (!string.IsNullOrEmpty(creationContext))
            {
                messages.Add(new() { Role = "system", Content = creationContext });
            }
            messages.Add(new() { Role = "user", Content = userMsg });

            // 添加占位消息用于流式更新
            var streamMsg = new AiMessage { Role = "assistant", Content = "" };
            _chatMessages.Add(streamMsg);
            StateHasChanged();

            var streamingText = new System.Text.StringBuilder();
            var result = await AiService.ChatWithToolsStreamAsync(messages, tools, chunk =>
            {
                streamingText.Append(chunk);
                streamMsg.Content = streamingText.ToString();
                // Blazor Server 通过 InvokeAsync 确保在正确上下文中更新
                _ = InvokeAsync(StateHasChanged);
            }, temperature: 0.3, overrideOptions: opts);

            if (result.IsToolCall)
            {
                // 流式结束后仍有工具调用 → 替换占位消息为完整结果
                streamMsg.Content = result.Text ?? "";
                streamMsg.ToolCalls = result.ToolCalls;
                streamMsg.ReasoningContent = result.ReasoningContent;
                _pendingToolCalls = result.ToolCalls;
                _pendingToolCallMessage = result.Text;
            }
            else
            {
                var textCalls = TryParseToolCallsFromText(result.Text);
                if (textCalls?.Count > 0)
                {
                    result.ToolCalls = textCalls;
                    streamMsg.Content = StripToolCallText(result.Text) ?? "";
                    streamMsg.ToolCalls = textCalls;
                    _pendingToolCalls = textCalls;
                    _pendingToolCallMessage = result.Text;
                }
                else
                {
                    // 流式已经更新了 content，只需确保最终文本
                    if (string.IsNullOrEmpty(streamMsg.Content))
                        streamMsg.Content = result.Text ?? "";
                }
            }
        }
        catch (Exception ex)
        {
            _chatMessages.Add(new AiMessage { Role = "assistant", Content = $"❌ 出错了：{ex.Message}" });
        }
        await SaveChatMessages();
        _chatLoading = false;
        StateHasChanged();
    }

    // ===== 工具执行 =====

    private async Task ExecutePendingToolCall()
    {
        if (_pendingToolCalls == null || _pendingToolCalls.Count == 0) return;
        _executingToolCall = true;
        StateHasChanged();

        try
        {
            // 并行执行所有工具调用（读写不冲突，各工具操作独立）
            var toolTasks = _pendingToolCalls.Select(tc => ExecuteToolCall(tc)).ToList();
            var toolResults = await Task.WhenAll(toolTasks);

            // 串行处理结果（按调用顺序添加到对话历史）
            _consecutiveParamErrors = 0;
            for (int i = 0; i < _pendingToolCalls.Count; i++)
            {
                var tc = _pendingToolCalls[i];
                var result = toolResults[i];

                if (result.StartsWith("❌ 缺少"))
                    _consecutiveParamErrors++;
                else
                    _consecutiveParamErrors = 0;

                _chatMessages.Add(new AiMessage
                {
                    Role = "tool",
                    ToolCallId = tc.Id,
                    Content = result
                });
            }

            // 连续参数错误检测（批量检查）
            if (_consecutiveParamErrors >= 3)
            {
                var lastTc = _pendingToolCalls[^1];
                _chatMessages.Add(new AiMessage
                {
                    Role = "tool",
                    ToolCallId = lastTc.Id,
                    Content = $"{toolResults[^1]}\n\n（检测到连续参数错误，已停止工具调用。请直接用已有数据回答。）"
                });
                var fallbackResult = await AiService.ChatAsync(_chatMessages, temperature: 0.3, overrideOptions: await GetChatAiOptions());
                _chatMessages.Add(new AiMessage { Role = "assistant", Content = fallbackResult ?? "操作已完成。" });
                _chainDepth = 999;
                _consecutiveParamErrors = 0;
                return;
            }

            _pendingToolCalls = null;

            _chainDepth++;
            var opts = await GetChatAiOptions();
            if (opts != null)
            {
                // 清理孤儿 tool_calls
                CleanupOrphanToolCalls();

                if (_chainDepth >= 20)
                {
                    // 强制文本总结
                    await ForceSummaryAndFinish(opts);
                }
                else
                {
                    var chainTools = AiToolDefinitions.GetAllChainTools();

                    // 流式响应链式调用结果
                    var streamMsg = new AiMessage { Role = "assistant", Content = "" };
                    _chatMessages.Add(streamMsg);
                    StateHasChanged();

                    var streamText = new System.Text.StringBuilder();
                    var result = await AiService.ChatWithToolsStreamAsync(_chatMessages, chainTools, chunk =>
                    {
                        streamText.Append(chunk);
                        streamMsg.Content = streamText.ToString();
                        _ = InvokeAsync(StateHasChanged);
                    }, temperature: 0.3, overrideOptions: opts);

                    if (result.IsToolCall)
                    {
                        streamMsg.Content = result.Text ?? "";
                        streamMsg.ToolCalls = result.ToolCalls;
                        streamMsg.ReasoningContent = result.ReasoningContent;
                        _pendingToolCalls = result.ToolCalls;
                        _executingToolCall = false;
                        await ExecutePendingToolCall();
                    }
                    else
                    {
                        if (string.IsNullOrEmpty(streamMsg.Content))
                            streamMsg.Content = result.Text ?? "操作已完成。";
                    }
                }
            }
        }
        catch (Exception ex)
        {
            _chatMessages.Add(new AiMessage { Role = "assistant", Content = $"❌ 执行操作时出错：{ex.Message}" });
        }

        _executingToolCall = false;
        await SaveChatMessages();
        StateHasChanged();
    }

    private async Task ForceSummaryAndFinish(AiOptions opts)
    {
        _chatMessages.Add(new AiMessage
        {
            Role = "system",
            Content = "注意：已经连续执行了多步工具调用，现在请直接总结最终结果，不要再调用任何工具。"
        });
        var finalResult = await AiService.ChatWithToolsAsync(_chatMessages, new List<AiToolDefinition>(), temperature: 0.3, overrideOptions: opts);
        _chatMessages.Add(new AiMessage { Role = "assistant", Content = finalResult.Text ?? "操作已完成。" });
    }

    private void CleanupOrphanToolCalls()
    {
        var toolCallIdsInHistory = new HashSet<string>();
        for (int di = _sessionStartIndex; di < _chatMessages.Count; di++)
        {
            if (_chatMessages[di].Role == "tool" && !string.IsNullOrEmpty(_chatMessages[di].ToolCallId))
                toolCallIdsInHistory.Add(_chatMessages[di].ToolCallId);
        }

        var orphanIndices = new List<int>();
        for (int di = _chatMessages.Count - 1; di >= _sessionStartIndex; di--)
        {
            var m = _chatMessages[di];
            if (m.Role == "assistant" && m.ToolCalls?.Count > 0)
            {
                foreach (var tc in m.ToolCalls)
                {
                    if (!toolCallIdsInHistory.Contains(tc.Id))
                    {
                        orphanIndices.Add(di);
                        break;
                    }
                }
            }
        }

        foreach (var idx in orphanIndices.OrderByDescending(i => i))
        {
            Console.Error.WriteLine($"[CLEANUP] 删除孤儿 assistant {idx}（tool_calls 无匹配 tool 响应）");
            _chatMessages.RemoveAt(idx);
        }
    }

    private async Task RejectPendingToolCall()
    {
        if (_pendingToolCalls == null) return;

        foreach (var tc in _pendingToolCalls)
        {
            _chatMessages.Add(new AiMessage
            {
                Role = "tool",
                ToolCallId = tc.Id,
                Content = "用户拒绝了此操作。请不要再建议相同的操作，也不要再调用任何工具。简短回复「好的」或「已取消」即可。"
            });
        }

        _pendingToolCalls = null;

        var opts = await GetChatAiOptions();
        if (opts != null)
        {
            var cleanMessages = new List<AiMessage>();
            for (int i = _sessionStartIndex; i < _chatMessages.Count; i++)
            {
                var m = _chatMessages[i];
                if (m.Role == "system") continue;
                if (m.Role == "assistant" && m.ToolCalls?.Count > 0) continue;
                cleanMessages.Add(m);
            }

            var result = await AiService.ChatAsync(cleanMessages, temperature: 0.3, overrideOptions: opts);
            _chatMessages.Add(new AiMessage { Role = "assistant", Content = result ?? "已取消操作。" });
        }

        await SaveChatMessages();
        StateHasChanged();
    }

    private async Task<string> ExecuteToolCall(AiToolCall tc)
    {
        try
        {
            var args = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, object>>(tc.FunctionArguments);
            if (args == null) return $"❌ 无法解析参数：{tc.FunctionArguments}";

            return tc.FunctionName switch
            {
                "find_project" => await ExecuteFindProject(args),
                "get_all_projects" => await ExecuteGetAllProjects(),
                "create_project_with_tasks" => await ExecuteCreateProjectWithTasks(args),
                "create_project" => await ExecuteCreateProject(args),
                "get_tasks" => await ExecuteGetTasks(args),
                "create_task" => await ExecuteCreateTask(args),
                "update_task" => await ExecuteUpdateTask(args),
                _ => $"❌ 未知操作：{tc.FunctionName}"
            };
        }
        catch (Exception ex)
        {
            return $"❌ 执行 {tc.FunctionName} 时出错：{ex.Message}";
        }
    }

