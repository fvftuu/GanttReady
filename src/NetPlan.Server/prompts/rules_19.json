[{"Id":1,"Name":"\u5206\u6790\u89C4\u5219\u6A21\u677F_\u5347\u7EA7\u7248","Content":"\u3010AI \u8FDB\u5EA6\u5206\u6790\u62A5\u544A \u2014 \u81EA\u5B9A\u4E49\u89C4\u5219\u6A21\u677F\u3011\n========================================\n\u4F7F\u7528\u65B9\u6CD5\uFF1A\n1. \u7528\u8BB0\u4E8B\u672C\u6253\u5F00\u672C\u6587\u4EF6\n2. \u4FEE\u6539\u4E0B\u9762\u5404\u7AE0\u8282\u7684\u5185\u5BB9\u8981\u6C42\n3. \u5728\u7CFB\u7EDF\u7684 AI \u8BBE\u7F6E\u4E2D\u4E0A\u4F20\u6B64\u6587\u4EF6\n4. \u70B9\u0022AI \u5206\u6790\u0022\u5373\u53EF\u6309\u4F60\u7684\u89C4\u5219\u751F\u6210\u62A5\u544A\n\n\u6CE8\u610F\u4E8B\u9879\uFF1A\n- \u6BCF\u884C\u5F00\u5934\u7684 # \u548C \u3010\u3011\u662F\u6CE8\u91CA\u8BF4\u660E\uFF0C\u53EF\u4EE5\u4FDD\u7559\u6216\u5220\u9664\n- \u300C\u8F93\u51FA\u8981\u6C42\u300D\u548C\u300C\u8BED\u8A00\u8981\u6C42\u300D\u5EFA\u8BAE\u4FDD\u7559\n- \u6BCF\u4E2A \u003Ch2\u003E \u662F\u4E00\u5927\u7AE0\uFF0C\u003Ch3\u003E \u662F\u5C0F\u8282\n- \u003Cul\u003E\u003Cli\u003E \u662F\u5217\u8868\uFF0C\u003Cp\u003E \u662F\u6BB5\u843D\n- \u8868\u683C\u7528 \u003Ctable\u003E\u003Ctr\u003E\u003Cth\u003E\u003Ctd\u003E \u6807\u7B7E\n- \uD83D\uDFE2\uD83D\uDFE1\uD83D\uDD34 \u662F\u72B6\u6001\u6807\u8BB0\n\n========================================\n# ==== \u4EE5\u4E0B\u662F AI \u5B9E\u9645\u6267\u884C\u7684\u89C4\u5219 ====\n\n## \u8F93\u51FA\u8981\u6C42\n\u8F93\u51FA HTML\uFF0C\u4E0D\u8981\u7528 markdown\u3002\u5141\u8BB8\u7684\u6807\u7B7E\uFF1A\n- \u003Ch2\u003E \u003Ch3\u003E \u505A\u7AE0\u8282\u6807\u9898\n- \u003Ctable\u003E \u003Ctr\u003E \u003Cth\u003E \u003Ctd\u003E \u505A\u8868\u683C\n- \u003Cul\u003E\u003Cli\u003E \u505A\u5217\u8868\n- \u003Cp\u003E \u003Cdiv\u003E \u505A\u6BB5\u843D\n- \u003Cspan style=\u0022color:green\u0022\u003E\uD83D\uDFE2\u003C/span\u003E / \u003Cspan class=\u0022text-warning\u0022\u003E\uD83D\uDFE1\u003C/span\u003E / \u003Cspan style=\u0022color:red\u0022\u003E\uD83D\uDD34\u003C/span\u003E \u6807\u6CE8\u72B6\u6001\n\n# ==== \u4E0B\u9762\u662F\u62A5\u544A\u5927\u7EB2\uFF0C\u4F60\u53EF\u4EE5\u968F\u610F\u589E\u5220\u6539 ====\n\n# \u3010\u7B2C\u4E00\u7AE0 \u9879\u76EE\u603B\u89C8\u3011\u2014 \u6574\u4F53\u6982\u51B5\n\u003Ch2\u003E\u4E00\u3001\u9879\u76EE\u603B\u89C8\u003C/h2\u003E\n\n# \u30101.1 \u6838\u5FC3\u7ED3\u8BBA\u3011\u4E00\u53E5\u8BDD\u8BF4\u660E\u9879\u76EE\u6574\u4F53\u72B6\u6001\n\u003Ch3\u003E1.1 \u6838\u5FC3\u7ED3\u8BBA\u003C/h3\u003E\n\u003Cp\u003E\u4E00\u53E5\u8BDD\u8BF4\u660E\u9879\u76EE\u6574\u4F53\u72B6\u6001\uFF0C\u603B\u8FDB\u5EA6\u504F\u5DEE\uFF0C\u662F\u5426\u53EF\u63A7\u3002\u003C/p\u003E\n\n\u003Ch3\u003E1.2 \u6267\u884C\u5C42\u6458\u8981\u003C/h3\u003E\n\u003Cp\u003E\u672C\u5468\u672A\u5B8C\u6210\u4EFB\u52A1\u3001\u4E0B\u5468\u4EFB\u52A1\u6E05\u5355\u3001\u6574\u6539\u8981\u6C42\u3002\u003C/p\u003E\n\n\u003Ch3\u003E1.3 \u7BA1\u7406\u5C42\u6458\u8981\u003C/h3\u003E\n\u003Cp\u003E\u9879\u76EE\u6574\u4F53\u72B6\u6001\u3001\u4E3B\u8981\u95EE\u9898\u3001\u9700\u8981\u534F\u8C03\u7684\u4E8B\u9879\u3002\u003C/p\u003E\n\n\u003Ch3\u003E1.4\u51B3\u7B56\u5C42\u6458\u8981\u003C/h3\u003E\n\u003Cp\u003E\u4E00\u53E5\u8BDD\u7ED3\u8BBA\u3001\u6838\u5FC3\u98CE\u9669\u3001\u662F\u5426\u9700\u8981\u5347\u7EA7\u5E72\u9884\u3002\u003C/p\u003E\n\n# \u30101.5 \u6838\u5FC3\u6307\u6807\u3011\u7528\u5217\u8868\u5C55\u793A\u5173\u952E\u6570\u5B57\n\u003Ch3\u003E1.2 \u6838\u5FC3\u6307\u6807\u003C/h3\u003E\n\u003Cul\u003E\n\u003Cli\u003E\u6574\u4F53\u5B8C\u6210\u5EA6\uFF1AXX%\u003C/li\u003E\n\u003Cli\u003E\u5173\u952E\u4EFB\u52A1\u5B8C\u6210\u7387\uFF1AXX%\u003C/li\u003E\n\u003Cli\u003E\u91CC\u7A0B\u7891\u8FBE\u6210\u7387\uFF1AXX%\u003C/li\u003E\n\u003Cli\u003E\u5173\u952E\u8DEF\u5F84\u504F\u5DEE\uFF1A\u00B1X\u5929\u003C/li\u003E\n\u003Cli\u003E\u9884\u6D4B\u4EA4\u4ED8\u65E5\u671F\u504F\u5DEE\uFF1A\u00B1X\u5929\u003C/li\u003E\n\u003C/ul\u003E\n\n# \u30101.6 \u4EFB\u52A1\u72B6\u6001\u5206\u7C7B\u3011\u5DF2\u5B8C\u6210/\u8FDB\u884C\u4E2D/\u672A\u5F00\u59CB/\u6EDE\u540E\u7684\u6570\u91CF\u548C\u5360\u6BD4\n\u003Ch3\u003E1.6 \u4EFB\u52A1\u72B6\u6001\u5206\u7C7B\u003C/h3\u003E\n\u003Cp\u003E\u5DF2\u5B8C\u6210/\u8FDB\u884C\u4E2D/\u672A\u5F00\u59CB/\u6EDE\u540E\u4EFB\u52A1\u7684\u6570\u91CF\u548C\u5360\u6BD4\u3002\u003C/p\u003E\n\n# \u3010\u7B2C\u4E8C\u7AE0 \u8BE6\u7EC6\u8FDB\u5EA6\u5BF9\u6BD4\u3011\u2014 \u5173\u952E\u4EFB\u52A1\u548C\u91CC\u7A0B\u7891\n\u003Ch2\u003E\u4E8C\u3001\u8BE6\u7EC6\u8FDB\u5EA6\u5BF9\u6BD4\u5206\u6790\u003C/h2\u003E\n\n# \u30102.1 \u5173\u952E\u4EFB\u52A1\u8DDF\u8E2A\u3011\n\u003Ch3\u003E2.1 \u5173\u952E\u4EFB\u52A1\u8DDF\u8E2A\u003C/h3\u003E\n\u003Cp\u003E\u5217\u51FA\u5173\u952E\u4EFB\u52A1\u7684\u5B8C\u6210\u60C5\u51B5\uFF0C\u6807\u6CE8\u504F\u5DEE\uFF0C\u5173\u6CE8\u5373\u5C06\u5230\u671F\u7684\u4EFB\u52A1\u3002\u003C/p\u003E\n\n# \u30102.2 \u91CC\u7A0B\u7891\u8FBE\u6210\u60C5\u51B5\u3011\n\u003Ch3\u003E2.2 \u91CC\u7A0B\u7891\u8FBE\u6210\u60C5\u51B5\u003C/h3\u003E\n\u003Cp\u003E\u5217\u51FA\u91CC\u7A0B\u7891\u7684\u8BA1\u5212\u548C\u5B9E\u9645\u65E5\u671F\uFF0C\u6807\u6CE8\u72B6\u6001\uFF0C\u5173\u6CE8\u4E0B\u4E00\u4E2A\u5373\u5C06\u5230\u6765\u7684\u91CC\u7A0B\u7891\u3002\u003C/p\u003E\n\n# \u30102.3 \u6700\u7EC8\u4EA4\u4ED8\u5F71\u54CD\u8BC4\u4F30\u3011\n\u003Ch3\u003E2.3 \u6700\u7EC8\u4EA4\u4ED8\u5F71\u54CD\u8BC4\u4F30\u003C/h3\u003E\n\u003Cp\u003E\u57FA\u4E8E\u5F53\u524D\u8FDB\u5EA6\u548C\u5173\u952E\u8DEF\u5F84\u5206\u6790\uFF0C\u8BC4\u4F30\u5BF9\u9879\u76EE\u6700\u7EC8\u4EA4\u4ED8\u65E5\u671F\u7684\u5F71\u54CD\uFF1A\u003C/p\u003E\n\u003Cul\u003E\n\u003Cli\u003E\u5F53\u524D\u6240\u6709\u6EDE\u540E\u4EFB\u52A1\u7D2F\u8BA1\u5C06\u5BFC\u81F4\u6700\u7EC8\u4EA4\u4ED8\u65E5\u671F \u63D0\u524D/\u5EF6\u8BEF X \u5929\u003C/li\u003E\n\u003Cli\u003E\u54EA\u4E9B\u6EDE\u540E\u4EFB\u52A1\u4F1A\u5F71\u54CD\u6700\u7EC8\u4EA4\u4ED8\uFF0C\u54EA\u4E9B\u4E0D\u4F1A\u003C/li\u003E\n\u003Cli\u003E\u9884\u6D4B\u9879\u76EE\u6700\u7EC8\u4EA4\u4ED8\u65E5\u671F\uFF1AYYYY\u5E74MM\u6708DD\u65E5\u003C/li\u003E\n\u003C/ul\u003E\n\n# \u3010\u7B2C\u4E09\u7AE0 \u95EE\u9898\u4E0E\u98CE\u9669\u5206\u6790\u3011\u2014 \u6EDE\u540E\u4EFB\u52A1\u548C\u98CE\u9669\n\u003Ch2\u003E\u4E09\u3001\u95EE\u9898\u4E0E\u98CE\u9669\u5206\u6790\u003C/h2\u003E\n\n# \u30103.1 \u6EDE\u540E\u4EFB\u52A1\u6E05\u5355\u3011\n\u003Ch3\u003E3.1 \u5173\u952E\u6EDE\u540E\u4EFB\u52A1\u6E05\u5355\uFF08\u4EC5\u663E\u793A\u5F71\u54CD\u6700\u7EC8\u4EA4\u4ED8\u7684\u4EFB\u52A1\uFF09\u003C/h3\u003E\n\u003Cp\u003E\u6309\u5BF9\u6700\u7EC8\u4EA4\u4ED8\u7684\u5F71\u54CD\u7A0B\u5EA6\u6392\u5E8F\uFF1A\u003C/p\u003E\n\u003Ctable\u003E\n  \u003Ctr\u003E\n    \u003Cth\u003E\u4EFB\u52A1\u540D\u79F0\u003C/th\u003E\n    \u003Cth\u003E\u6EDE\u540E\u5929\u6570\u003C/th\u003E\n    \u003Cth\u003E\u5BF9\u6700\u7EC8\u4EA4\u4ED8\u7684\u5F71\u54CD\u003C/th\u003E\n    \u003Cth\u003E\u521D\u6B65\u539F\u56E0\u63A8\u65AD\u003C/th\u003E\n  \u003C/tr\u003E\n\u003C/table\u003E\n\n# \u30103.2 \u4E3B\u8981\u95EE\u9898\u8BF4\u660E\u3011\n\u003Ch3\u003E3.2 \u4E3B\u8981\u95EE\u9898\u8BF4\u660E\u003C/h3\u003E\n\u003Cp\u003E\u8BF4\u660E\u6700\u4E25\u91CD\u7684 2-3 \u4E2A\u95EE\u9898\u53CA\u5176\u5F71\u54CD\u7A0B\u5EA6\u3002\u003C/p\u003E\n\n# \u30103.3 \u98CE\u9669\u8BC4\u4F30\u3011\n\u003Ch3\u003E3.3 \u98CE\u9669\u8BC4\u4F30\u003C/h3\u003E\n\u003Cp\u003E\u5F53\u524D\u4E3B\u8981\u98CE\u9669\u3001\u98CE\u9669\u7B49\u7EA7\u3001\u5E94\u5BF9\u63AA\u65BD\u3002\u003C/p\u003E\n\n# \u3010\u7B2C\u56DB\u7AE0 \u4E0B\u4E00\u6B65\u884C\u52A8\u8BA1\u5212\u3011\u2014 \u6574\u6539\u63AA\u65BD\n\u003Ch2\u003E\u56DB\u3001\u4E0B\u4E00\u6B65\u884C\u52A8\u8BA1\u5212\u003C/h2\u003E\n\n# \u30104.1 \u6838\u5FC3\u76EE\u6807\u3011\n\u003Ch3\u003E4.1 \u6838\u5FC3\u76EE\u6807\u003C/h3\u003E\n\u003Cp\u003E\u4E0B\u5468\u8BA1\u5212\u5B8C\u6210\u4EC0\u4E48\uFF0C\u8FBE\u5230\u4EC0\u4E48\u8FDB\u5EA6\u3002\u003C/p\u003E\n\n# \u30104.2 \u91CD\u70B9\u5DE5\u4F5C\u5B89\u6392\u3011\n\u003Ch3\u003E4.2 \u91CD\u70B9\u5DE5\u4F5C\u5B89\u6392\u003C/h3\u003E\n\u003Cp\u003E\u5177\u4F53\u4EFB\u52A1\u3001\u8D23\u4EFB\u4EBA\u3001\u65F6\u95F4\u3002\u003C/p\u003E\n\n# \u30104.3 \u95EE\u9898\u6574\u6539\u8BA1\u5212\u3011\n\u003Ch3\u003E4.3 \u95EE\u9898\u6574\u6539\u8BA1\u5212\u003C/h3\u003E\n\u003Cp\u003E\u9488\u5BF9\u6EDE\u540E\u4EFB\u52A1\u7684\u5177\u4F53\u6574\u6539\u63AA\u65BD\u3002\u003C/p\u003E\n\n\n\n## \u8BED\u8A00\u8981\u6C42\n- \u7528\u4E2D\u6587\n- \u7ED3\u8BBA\u5148\u884C\uFF0C\u5148\u8BB2\u6838\u5FC3\u518D\u8BB2\u7EC6\u8282\n- \u6BCF\u6761\u5EFA\u8BAE\u90FD\u8981\u5177\u4F53\u53EF\u6267\u884C\n- \u9002\u5F53\u4F7F\u7528 \uD83D\uDFE2\uD83D\uDFE1\uD83D\uDD34 \u6807\u6CE8\u72B6\u6001\n\n**\u53EA\u8F93\u51FA HTML \u5185\u5BB9\uFF0C\u4E0D\u8981\u7528 \u0060\u0060\u0060html \u5305\u88F9\u3002\u4E0D\u8981\u6709 html/head/body \u6807\u7B7E\u3002**\n","IsActive":true}]