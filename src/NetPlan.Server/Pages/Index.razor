@page "/"
@inject IProjectService ProjectService
@inject NavigationManager Navigation

<PageTitle>NetPlan - 项目列表</PageTitle>

<div class="page-header">
    <h1>📊 NetPlan 进度计划</h1>
</div>

<div class="page-body">
    <div class="page-main" style="padding:20px;">
        <div class="toolbar">
            <button class="btn btn-primary" @onclick="ShowCreateDialog">➕ 新建项目</button>
        </div>

        @if (isLoading)
        {
            <div class="loading">加载中...</div>
        }
        else if (Projects.Count == 0)
        {
            <div class="empty-state">
                <div style="font-size:48px; margin-bottom:16px;">📁</div>
                <p>暂无项目</p>
                <button class="btn btn-primary" @onclick="ShowCreateDialog">创建第一个项目</button>
            </div>
        }
        else
        {
            <table class="table">
                <thead>
                    <tr>
                        <th>项目代码</th>
                        <th>项目名称</th>
                        <th>计划开始</th>
                        <th>计划结束</th>
                        <th>工期(天)</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Projects)
                    {
                        <tr>
                            <td><span class="badge primary">@p.Code</span></td>
                            <td>
                                <strong>@p.Name</strong>
                                @if (!string.IsNullOrEmpty(p.Description))
                                {
                                    <div style="font-size:12px; color:#999; margin-top:2px;">@p.Description</div>
                                }
                            </td>
                            <td>@p.PlanStartDate.ToString("yyyy-MM-dd")</td>
                            <td>@p.PlanEndDate.ToString("yyyy-MM-dd")</td>
                            <td>@(p.PlanEndDate - p.PlanStartDate).Days 天</td>
                            <td>
                                <a href="/project/@p.Id/gantt">📅 甘特图</a> |
                                <a href="/project/@p.Id/network">🔗 网络图</a> |
                                <a href="/project/@p.Id/resources">👥 资源</a> |
                                <a href="/project/@p.Id/analysis">📊 分析</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@if (showDialog && editingProject != null)
{
    <div class="modal-overlay" @onclick="CloseDialog">
        <div class="modal-content" @onclick:stopPropagation>
            <h3>新建项目</h3>

            <div class="form-group">
                <label>项目代码 *</label>
                <input type="text" @bind="editingProject.Code" placeholder="例如: HP-2026-001" />
            </div>

            <div class="form-group">
                <label>项目名称 *</label>
                <input type="text" @bind="editingProject.Name" placeholder="项目名称" />
            </div>

            <div class="form-group">
                <label>项目描述</label>
                <textarea @bind="editingProject.Description" rows="2" placeholder="简要描述"></textarea>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>计划开始</label>
                    <input type="date" @bind="editingProject.PlanStartDate" />
                </div>
                <div class="form-group">
                    <label>计划结束</label>
                    <input type="date" @bind="editingProject.PlanEndDate" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>每天工时</label>
                    <input type="number" @bind="editingProject.WorkingHoursPerDay" min="1" max="24" />
                </div>
                <div class="form-group">
                    <label>每周工作天数</label>
                    <input type="number" @bind="editingProject.WorkdaysPerWeek" min="1" max="7" />
                </div>
            </div>

            <div class="dialog-actions">
                <button class="btn btn-secondary" @onclick="CloseDialog">取消</button>
                <button class="btn btn-primary" @onclick="SaveProject">保存</button>
            </div>
        </div>
    </div>
}

@code {
    private List<Models.Project> Projects = new();
    private Models.Project? editingProject;
    private bool isLoading = true;
    private bool showDialog = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadProjects();
    }

    private async Task LoadProjects()
    {
        isLoading = true;
        try
        {
            Projects = await ProjectService.GetAllProjectsAsync();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ShowCreateDialog()
    {
        editingProject = new Models.Project
        {
            PlanStartDate = DateTime.Today,
            PlanEndDate = DateTime.Today.AddMonths(6),
            WorkingHoursPerDay = 8,
            WorkdaysPerWeek = 5
        };
        showDialog = true;
    }

    private async Task SaveProject()
    {
        if (editingProject == null) return;
        if (string.IsNullOrWhiteSpace(editingProject.Code) ||
            string.IsNullOrWhiteSpace(editingProject.Name))
            return;

        await ProjectService.CreateProjectAsync(editingProject);
        CloseDialog();
        await LoadProjects();
    }

    private void CloseDialog()
    {
        showDialog = false;
        editingProject = null;
    }
}
