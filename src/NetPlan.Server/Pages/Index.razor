@page "/"
@inject IProjectService ProjectService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>NetPlan - 项目总览</PageTitle>

<div class="page-body">
    <div class="page-main" style="padding:20px;">

        @* 工具栏 *@
        <div class="toolbar">
            <button class="btn btn-primary" @onclick="ShowCreateDialog">
                <span class="oi oi-plus"></span> 新建项目
            </button>
            <button class="btn btn-outline" @onclick="DownloadBlankTemplate">
                <span class="oi oi-file"></span> 下载模板
            </button>
            <button class="btn btn-outline" @onclick="TriggerImport">
                <span class="oi oi-data-upload"></span> 导入Excel
            </button>
            @if (selectedProject != null)
            {
                <button class="btn btn-success" @onclick="ExportTemplate">
                    <span class="oi oi-data-download"></span> 导出数据模板
                </button>
                <button class="btn btn-danger" @onclick="DeleteSelectedProject">
                    <span class="oi oi-trash"></span> 删除项目
                </button>
            }
            <InputFile id="fileInput" OnChange="HandleFileSelected" accept=".xlsx,.xls" style="display:none" />
        </div>

        @if (isLoading)
        {
            <div class="loading" style="text-align:center;padding:60px 0;color:#999;">加载中...</div>
        }
        else if (summaries.Count == 0)
        {
            <div class="empty-state">
                <div style="font-size:56px; margin-bottom:16px;">📋</div>
                <p style="font-size:18px;color:#666;">暂无项目</p>
                <p style="color:#999;margin-bottom:20px;">创建第一个项目开始管理您的工程计划</p>
                <button class="btn btn-primary btn-lg" @onclick="ShowCreateDialog">创建第一个项目</button>
            </div>
        }
        else
        {
            @* 统计卡片 *@
            <div class="dashboard-cards">
                <div class="dash-card">
                    <div class="dash-card-icon" style="background:#eef1ff;color:#4f6ef7;">📊</div>
                    <div class="dash-card-body">
                        <div class="dash-card-value">@summaries.Count</div>
                        <div class="dash-card-label">项目总数</div>
                    </div>
                </div>
                <div class="dash-card">
                    <div class="dash-card-icon" style="background:#e6fff2;color:#3ecf8e;">🔄</div>
                    <div class="dash-card-body">
                        <div class="dash-card-value">@summaries.Count(s => s.Status == 1)</div>
                        <div class="dash-card-label">进行中</div>
                    </div>
                </div>
                <div class="dash-card">
                    <div class="dash-card-icon" style="background:#fff0e6;color:#f5a623;">⏳</div>
                    <div class="dash-card-body">
                        <div class="dash-card-value">@summaries.Count(s => s.Status == 0)</div>
                        <div class="dash-card-label">未开始</div>
                    </div>
                </div>
                <div class="dash-card">
                    <div class="dash-card-icon" style="background:#ffeaea;color:#ff5a5f;">❗</div>
                    <div class="dash-card-body">
                        <div class="dash-card-value">@summaries.Count(s => s.Status == 2)</div>
                        <div class="dash-card-label">已超期</div>
                    </div>
                </div>
                <div class="dash-card">
                    <div class="dash-card-icon" style="background:#f0f0ff;color:#7c5cfc;">💰</div>
                    <div class="dash-card-body">
                        <div class="dash-card-value">¥@(summaries.Sum(s => s.TotalPlanCost).ToString("N0"))</div>
                        <div class="dash-card-label">总预算</div>
                    </div>
                </div>
                <div class="dash-card">
                    <div class="dash-card-icon" style="background:#fef6e6;color:#e8a317;">📌</div>
                    <div class="dash-card-body">
                        <div class="dash-card-value">@summaries.Sum(s => s.TaskCount)</div>
                        <div class="dash-card-label">总任务数</div>
                    </div>
                </div>
            </div>

            @* 项目卡片网格 *@
            <div class="project-cards">
                @foreach (var p in summaries)
                {
                    var isSelected = selectedProject?.Id == p.Id;
                    <div class="project-card @(isSelected ? "selected" : "")" @onclick="() => SelectProject(p.Id)">
                        @* 顶部标识条 *@
                        <div class="card-accent @(p.Status == 2 ? "overdue" : p.Status == 0 ? "pending" : "active")"></div>
                        <div class="card-body">
                            @* 头行：代码 + 状态 *@
                            <div class="card-header-row">
                                <span class="badge primary">@p.Code</span>
                                <span class="status-badge @(p.Status == 2 ? "overdue" : p.Status == 0 ? "pending" : "active")">
                                    @(p.Status == 2 ? "🔴" : p.Status == 0 ? "⚪" : "🟢") @p.StatusLabel
                                </span>
                            </div>
                            @* 项目名称 *@
                            <h3 class="card-title">@p.Name</h3>
                            @* 描述 *@
                            @if (!string.IsNullOrEmpty(p.Description))
                            {
                                <p class="card-desc">@p.Description</p>
                            }
                            @* 进度条 *@
                            <div class="card-progress">
                                <div class="progress-bar">
                                    <div class="progress-fill @(p.CompletionPct >= 100 ? "done" : p.CompletionPct > 0 ? "ongoing" : "")"
                                         style="width:@(p.CompletionPct)%"></div>
                                </div>
                                <span class="progress-text">@p.CompletionPct%</span>
                            </div>
                            @* 元信息行 *@
                            <div class="card-meta">
                                <span title="计划周期">📅 @p.PlanStartDate.ToString("MM/dd") - @p.PlanEndDate.ToString("MM/dd")</span>
                                <span title="剩余天数">⏱ @(p.DaysRemaining >= 0 ? $"{p.DaysRemaining}天" : $"已超期{-p.DaysRemaining}天")</span>
                                <span title="任务数">📋 @p.TaskCount 任务</span>
                                <span title="资源数">👥 @p.ResourceCount 资源</span>
                            </div>
                            @* 操作按钮 *@
                            <div class="card-actions">
                                <a href="/project/@p.Id/gantt" class="btn btn-sm btn-primary" title="甘特图">📅 甘特图</a>
                                <a href="/project/@p.Id/analysis" class="btn btn-sm btn-outline" title="分析">📊 分析</a>
                                <a href="/project/@p.Id/resources" class="btn btn-sm btn-outline" title="资源">👥 资源</a>
                                <a href="/project/@p.Id/network" class="btn btn-sm btn-outline disabled" title="网络图" style="opacity:0.35;pointer-events:none;">🔗 网络图</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@* 新建/编辑对话框 *@
@if (showDialog && editingProject != null)
{
    <div class="modal-overlay" @onclick="CloseDialog">
        <div class="modal-content" @onclick:stopPropagation>
            <h3>新建项目</h3>

            <div class="form-group">
                <label>项目代码 *</label>
                <input type="text" @bind="editingProject.Code" placeholder="例如: HP-2026-001" />
            </div>

            <div class="form-group">
                <label>项目名称 *</label>
                <input type="text" @bind="editingProject.Name" placeholder="项目名称" />
            </div>

            <div class="form-group">
                <label>项目描述</label>
                <textarea @bind="editingProject.Description" rows="2" placeholder="简要描述"></textarea>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>计划开始</label>
                    <input type="date" @bind="editingProject.PlanStartDate" />
                </div>
                <div class="form-group">
                    <label>计划结束</label>
                    <input type="date" @bind="editingProject.PlanEndDate" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>每天工时</label>
                    <input type="number" @bind="editingProject.WorkingHoursPerDay" min="1" max="24" />
                </div>
                <div class="form-group">
                    <label>每周工作天数</label>
                    <input type="number" @bind="editingProject.WorkdaysPerWeek" min="1" max="7" />
                </div>
            </div>

            <div class="dialog-actions">
                <button class="btn btn-secondary" @onclick="CloseDialog">取消</button>
                <button class="btn btn-primary" @onclick="SaveProject">保存</button>
            </div>
        </div>
    </div>
}

@code {
    private List<ProjectSummary> summaries = new();
    private Models.Project? editingProject;
    private Models.Project? selectedProject;
    private bool isLoading = true;
    private bool showDialog = false;
    private IBrowserFile? pendingFile;
    private int checkedProjectId = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadSummaries();
        await LoadCheckedState();
    }

    private async Task LoadSummaries()
    {
        isLoading = true;
        try
        {
            summaries = await ProjectService.GetProjectSummariesAsync();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadCheckedState()
    {
        try
        {
            checkedProjectId = await JS.InvokeAsync<int>("getCheckedProject");
            if (checkedProjectId > 0 && !summaries.Any(p => p.Id == checkedProjectId))
                checkedProjectId = 0;
        }
        catch { checkedProjectId = 0; }
    }

    private void ShowCreateDialog()
    {
        editingProject = new Models.Project
        {
            PlanStartDate = DateTime.Today,
            PlanEndDate = DateTime.Today.AddMonths(6),
            WorkingHoursPerDay = 8,
            WorkdaysPerWeek = 5
        };
        showDialog = true;
    }

    private async Task SaveProject()
    {
        if (editingProject == null) return;
        if (string.IsNullOrWhiteSpace(editingProject.Code) || string.IsNullOrWhiteSpace(editingProject.Name))
            return;

        await ProjectService.CreateProjectAsync(editingProject);
        CloseDialog();
        await LoadSummaries();
    }

    private void CloseDialog()
    {
        showDialog = false;
        editingProject = null;
    }

    private void SelectProject(int projectId)
    {
        if (selectedProject?.Id == projectId)
        {
            selectedProject = null;
        }
        else
        {
            var s = summaries.FirstOrDefault(s => s.Id == projectId);
            selectedProject = s != null ? new Models.Project { Id = s.Id, Code = s.Code, Name = s.Name } : null;
        }
    }

    private async Task DeleteSelectedProject()
    {
        if (selectedProject == null) return;
        try
        {
            await ProjectService.DeleteProjectAsync(selectedProject.Id);
            selectedProject = null;
            await LoadSummaries();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"删除失败: {ex.Message}");
        }
    }

    private async Task DownloadBlankTemplate()
    {
        try
        {
            await JS.InvokeVoidAsync("window.open", "/download/blank-template", "_blank");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"下载模板失败: {ex.Message}");
        }
    }

    private async Task ExportTemplate()
    {
        if (selectedProject == null) return;
        try
        {
            await JS.InvokeVoidAsync("window.open", $"/download/template/{selectedProject.Id}", "_blank");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"导出模板失败: {ex.Message}");
        }
    }

    private async Task TriggerImport()
    {
        if (selectedProject == null)
        {
            await JS.InvokeVoidAsync("alert", "请先选择一个项目");
            return;
        }
        await JS.InvokeVoidAsync("eval", "document.getElementById('fileInput').click()");
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        if (selectedProject == null || e.File == null) return;
        pendingFile = e.File;
        var result = await UploadAndImport(e.File, selectedProject.Id);

        if (result != null)
        {
            if (result.Success)
            {
                await JS.InvokeVoidAsync("alert", $"导入成功！\n任务: {result.TasksImported}\n资源: {result.ResourcesImported}\n分配: {result.AssignmentsImported}");
                Navigation.NavigateTo($"/project/{selectedProject.Id}/gantt", forceLoad: true);
            }
            else
            {
                var errorMsg = result.Errors.Count > 0 ? string.Join("\n", result.Errors.Take(5)) : result.Message;
                await JS.InvokeVoidAsync("alert", $"导入完成但有错误:\n{errorMsg}");
            }
        }
    }

    private async Task<ExcelImportResult?> UploadAndImport(IBrowserFile file, int projectId)
    {
        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);

            var content = new MultipartFormDataContent();
            content.Add(new ByteArrayContent(memoryStream.ToArray()), "file", file.Name);

            var baseUri = new Uri(Navigation.BaseUri);
            var response = await HttpClient.PostAsync(new Uri(baseUri, $"/api/excel/import/{projectId}"), content);
            if (response.IsSuccessStatusCode)
            {
                return await response.Content.ReadFromJsonAsync<ExcelImportResult>();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                await JS.InvokeVoidAsync("alert", $"导入失败: {error}");
                return null;
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"导入出错: {ex.Message}");
            return null;
        }
    }

    [Inject] private HttpClient HttpClient { get; set; } = default!;
}
