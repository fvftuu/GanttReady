@page "/"
@namespace NetPlan.Server.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>NetPlan - 进度计划管理系统</title>
    <base href="~/" />
    <link href="css/site.css" rel="stylesheet" />
    <link href="css/open-iconic/font/css/open-iconic-bootstrap.min.css" rel="stylesheet" />
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
    </style>
    <!-- Index page globals: must load before Blazor render to avoid race -->
    <script>
        window.setCheckedProject = function(id) { localStorage.setItem('netplan_checked', id); };
        window.getCheckedProject = function() { return localStorage.getItem('netplan_checked') || 0; };
        window.navToChecked = function(page) {
            var checked = localStorage.getItem('netplan_checked');
            if (checked > 0) { window.location.href = '/project/' + checked + '/' + page; }
            else { window.location.href = '/'; }
        };
    </script>
</head>
<body>
    <app>
        <component type="typeof(App)" render-mode="Server" />
    </app>

    <div id="blazor-error-ui" style="display:none; background:#fff2f0; padding:16px; border:1px solid #ffccc7; border-radius:4px;">
        <span style="color:#ff4d4f;">发生错误，页面可能无响应。</span>
        <a href="" class="reload" style="margin-left:16px;">重新加载</a>
    </div>

    <script src="_framework/blazor.server.js"></script>
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <!-- Cytoscape.js -->
    <script src="https://unpkg.com/cytoscape@3.28.1/dist/cytoscape.min.js"></script>
    <!-- Dagre + Cytoscape-Dagre layout -->
    <script src="https://unpkg.com/dagre@0.8.5/dist/dagre.min.js"></script>
    <script src="https://unpkg.com/cytoscape-dagre@2.5.0/cytoscape-dagre.js"></script>
    <!-- NetPlan scripts -->
    <script src="js/netplan.js?v=20260511b"></script>
</body>
</html>
