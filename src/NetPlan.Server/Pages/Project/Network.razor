    // ======= C1 新增工作(拖拽节点)=======
    [JSInvokable]
    public async Task SyncNodeDrag(int[] taskIds, double dxDays, string nodeRole = "end")
    {
        if (taskIds == null || taskIds.Length == 0) return;
        if (Math.Abs(dxDays) < 0.5) return; // 没实质拖动,跳过
        // 防止残留编辑状态干扰
        editingTask = null;
        dxDays = Math.Clamp(dxDays, -3650, 3650);
        var allTasks = await ProjectService.GetTasksByProjectIdAsync(currentProjectId);

        foreach (var taskId in taskIds)
        {
            var task = allTasks.FirstOrDefault(t => t.Id == taskId);
            if (task == null) continue;

            if (nodeRole == "start")
            {
                var newStart = task.PlanStartDate.AddDays(dxDays);
                task.PlanStartDate = newStart;
                task.PlanEndDate = newStart.AddDays(task.PlanDuration - 1);
            }
            else
            {
                var newDuration = task.PlanDuration + (int)dxDays;
                if (newDuration < 1) newDuration = 1;
                task.PlanDuration = newDuration;
                task.PlanEndDate = task.PlanStartDate.AddDays(newDuration - 1);
            }
            task.IsManualSchedule = true;
            await ProjectService.UpdateTaskAsync(task);
        }

        // 不重算 CPM,不显示 loading,只刷新 options + graphJson
        await JS.InvokeVoidAsync("clearNetworkOffsets");
        statusMessage = null;
        await BuildDataInternal(skipLoading: true);
    }

