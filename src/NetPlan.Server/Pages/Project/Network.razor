    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // 每次渲染都确保 dotnet 引用已设置(预渲染时 JS 不存在会失败,后续渲染重试)
        if (dotNetRef == null)
        {
            dotNetRef = DotNetObjectReference.Create(this);
        }
        try
        {
            await JS.InvokeVoidAsync("setNetworkDotNet", dotNetRef);
        }
        catch
        {
            // 预渲染时无 JS 引擎,忽略;浏览器渲染时有效
        }
    }

