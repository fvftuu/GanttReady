    [JSInvokable]
    public async Task ShowAddTaskModal(int sourceTaskId, int dayOffset = 0)
    {
        if (currentProjectId == 0) return;
        tasks = await ProjectService.GetTasksByProjectIdAsync(currentProjectId);
        projectResources = await ResourceService.GetResourcesByProjectAsync(currentProjectId);

        var maxNum = 0;
        foreach (var t in tasks)
            if (t.Code.StartsWith("W") && int.TryParse(t.Code[1..], out var n))
                maxNum = Math.Max(maxNum, n);
        var code = "W" + (maxNum + 1);
        var planStart = DateTime.Today;
        if (dayOffset > 0) planStart = planStart.AddDays(dayOffset);

        editingTask = new TaskItem
        {
            ProjectId = currentProjectId,
            Code = code,
            Name = "",
            PlanStartDate = planStart,
            PlanEndDate = planStart.AddDays(4),
            PlanDuration = 5,
            CompletionPercentage = 0
        };
        selectedResourceId = 0;
        assignQuantity = 1;
        taskAssignments = new List<ResourceAssignment>();
        editingPredecessors = new List<TaskRelation>();
        editingSuccessors = new List<TaskRelation>();
        availTasks = tasks.ToList();

        // 如果双击了任务,自动建立 FS 前置关系
        if (sourceTaskId > 0)
        {
            editingPredecessors.Add(new TaskRelation
            {
                ProjectId = currentProjectId,
                PredecessorTaskId = sourceTaskId,
                SuccessorTaskId = 0,
                Type = RelationType.FS,
                Lag = 0
            });
