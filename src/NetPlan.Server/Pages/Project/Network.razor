@page "/project/{ProjectId:int}/network"
@inject IProjectService ProjectService
@inject IJSRuntime JS
@implements IDisposable

<div class="page-header">
    <div class="header-left">
        <select class="form-control" @bind="currentProjectId" @bind:after="OnProjectChanged">
            <option value="0">选择项目</option>
            @foreach (var project in projects)
            {
                <option value="@project.Id">@project.Name</option>
            }
        </select>
        <span class="page-title">双代号网络图</span>
    </div>
</div>

<div style="display:flex;align-items:center;justify-content:center;min-height:calc(100vh - 200px);flex-direction:column;gap:16px;color:#999;">
    <div style="font-size:64px;">🔄</div>
    <div style="font-size:18px;font-weight:600;color:#555;">网络图功能重构中</div>
    <div style="font-size:14px;max-width:400px;text-align:center;line-height:1.8;">
        当前版本暂不包含网络图渲染功能，正在按照 GB/T 13400.2-2009 标准重新设计绘图引擎。
    </div>
    <div style="font-size:13px;margin-top:8px;">
        预计完成功能：时标双代号网络图 · 逻辑双代号网络图 · 交叉弧检测 · 自由时差波浪线 · 虚工作连接
    </div>
    <div style="font-size:12px;margin-top:12px;color:#bbb;">
        其他功能（甘特图、资源管理、分析）正常可用
    </div>
    <div style="margin-top:20px;">
        <a href="javascript:navToChecked('gantt')" style="display:inline-block;padding:8px 24px;background:#1890ff;color:#fff;border-radius:6px;text-decoration:none;font-size:14px;">前往甘特图</a>
        <a href="javascript:navToChecked('resources')" style="display:inline-block;padding:8px 24px;background:#52c41a;color:#fff;border-radius:6px;text-decoration:none;font-size:14px;margin-left:8px;">前往资源管理</a>
    </div>
</div>

@code {
    private int currentProjectId;
    private List<Project> projects = new();

    protected override async Task OnInitializedAsync()
    {
        projects = await ProjectService.GetAllProjectsAsync();
        var routeId = ProjectId;
        if (routeId > 0 && projects.Any(p => p.Id == routeId))
            currentProjectId = routeId;
    }

    [Parameter]
    public int ProjectId { get; set; }

    private async Task OnProjectChanged()
    {
        if (currentProjectId > 0)
            await JS.InvokeVoidAsync("setCheckedProject", currentProjectId);
    }

    public void Dispose()
    {
        // 无需清理 JS 资源
    }
}
