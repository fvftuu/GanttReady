    private async Task RerenderGraph()
    {
        if (string.IsNullOrEmpty(graphJson)) return;
        var project = projects.FirstOrDefault(p => p.Id == currentProjectId);
        var tasks = await ProjectService.GetTasksByProjectIdAsync(currentProjectId);
        var maxES = tasks.Any() ? tasks.Max(t => t.EarlyStart ?? 0) : 0;
        var maxEF = tasks.Any() ? tasks.Max(t => t.EarlyFinish ?? (t.EarlyStart ?? 0) + t.PlanDuration) : 90;
        var totalDays = Math.Max(maxEF + 30, 90);
        var totalDuration = tasks.Any() ? (tasks.Max(t => t.PlanEndDate) - tasks.Min(t => t.PlanStartDate)).Days + 1 : 0;
        var dayWidth = 40.0 * (zoomLevel / 100.0); // 缩放

        optionsJson = System.Text.Json.JsonSerializer.Serialize(new
        {
            showCritical = showCriticalHighlight,
            showFloat = showFloatLabels,
            showTodayLine = showTodayLine,
            showProgressLine = showProgressLine,
            showDummyArrows = showDummyArrows,
            showProgressCurve = showProgressCurve,
            projectStartDate = (project?.PlanStartDate ?? DateTime.Today).ToString("yyyy-MM-dd"),
            totalDays = totalDays,
            totalDuration = totalDuration,
            dayWidth = dayWidth,
            projectName = project?.Name ?? "",
            mode = netMode,
            labelFields = GetLabelFields(),
            rowLabels = new object[] { },
            layerHeight = graphLayerHeight,
            nodeRadius = graphNodeRadius,
            labelFontSize = graphLabelFontSize,
            restDayPattern = showRestDayPattern,
            criticalColor = "#e63946",
            normalColor = "#1890ff",
            dummyColor = "#1890ff",
            criticalWidth = 3,
            normalWidth = 1.5
        });
        renderToken++;
        StateHasChanged();
        // 直接调用 JS 渲染,替换旧轮询机制
        try { await JS.InvokeVoidAsync("renderNetwork", graphJson, optionsJson); } catch { }
    }

    private void ZoomIn()
    {
        zoomLevel = Math.Min(3000, zoomLevel + 5); // 同甘特图:±5%
        _ = RerenderGraph();
    }

    private void ZoomOut()
    {
        zoomLevel = Math.Max(1, zoomLevel - 5);
        _ = RerenderGraph();
    }

    private async Task ZoomToFitAsync()
    {
        if (string.IsNullOrEmpty(graphJson) || currentProjectId == 0) return;
        var tasks = await ProjectService.GetTasksByProjectIdAsync(currentProjectId);
        if (!tasks.Any()) return;
        var maxEF = tasks.Max(t => t.EarlyFinish ?? (t.EarlyStart ?? 0 + t.PlanDuration));
        var totalDays = Math.Max(maxEF + 30, 90);
        var bodyWidth = await JS.InvokeAsync<double>("eval",
            "document.getElementById('network-body')?.clientWidth || 800");
        var targetDayW = (bodyWidth - 80 - 100) / Math.Max(1, totalDays); // P2-3: 减去 MARGIN_LEFT(80)
        var newZoom = targetDayW / 40.0 * 100.0;
        zoomLevel = Math.Max(1, Math.Min(3000, (int)Math.Round(newZoom)));
        await RerenderGraph();
    }

