    // 内部方法:可跳过 loading 状态
    private async Task BuildDataInternal(bool skipLoading)
    {
        if (currentProjectId == 0) { graphJson = null; return; }
        if (!skipLoading) { isLoading = true; StateHasChanged(); }

        tasks = await ProjectService.GetTasksByProjectIdAsync(currentProjectId);
        taskRelations = await ProjectService.GetRelationsByProjectIdAsync(currentProjectId);
        var project = projects.FirstOrDefault(p => p.Id == currentProjectId);

        if (!tasks.Any()) { graphJson = null; isLoading = false; return; }

        if (!skipLoading && tasks.All(t => t.EarlyStart == null))
        {
            await ProjectService.CalculateScheduleAsync(currentProjectId);
            tasks = await ProjectService.GetTasksByProjectIdAsync(currentProjectId);
        }

        var projectStartDate = project?.PlanStartDate ?? DateTime.Today;
        var maxES = tasks.Max(t => t.EarlyStart ?? 0);
        var maxEF = tasks.Max(t => t.EarlyFinish ?? (t.EarlyStart ?? 0) + t.PlanDuration);
        var totalDays = Math.Max(maxEF + 30, 90);
        var dayWidth = 40.0 * (zoomLevel / 100.0);

        var sb = new System.Text.StringBuilder("[");
        int eventNum = 1;
        foreach (var t in tasks)
        {
            var es = t.EarlyStart ?? 0;
            var ef = t.EarlyFinish ?? (es + t.PlanDuration);
            var ls = t.LateStart ?? es;
            var lf = t.LateFinish ?? ef;
            var tf = t.TotalFloat ?? (ls - es);
            var ff = t.FreeFloat ?? tf;
            var nameSafe = t.Name.Replace("\"", "\\\"").Replace("\n", " ");
            var codeSafe = t.Code.Replace("\"", "\\\"");

            sb.Append("{\"data\":{")
              .Append("\"id\":\"").Append(t.Id).Append("\",")
              .Append("\"label\":\"").Append(codeSafe).Append("\",")
              .Append("\"name\":\"").Append(nameSafe).Append("\",")
              .Append("\"eventNum\":").Append(eventNum++).Append(",")
              .Append("\"duration\":").Append(t.PlanDuration).Append(",")
              .Append("\"es\":").Append(es).Append(",")
              .Append("\"ef\":").Append(ef).Append(",")
              .Append("\"ls\":").Append(ls).Append(",")
              .Append("\"lf\":").Append(lf).Append(",")
              .Append("\"tf\":").Append(tf).Append(",")
              .Append("\"ff\":").Append(ff).Append(",")
              .Append("\"completion\":").Append(t.CompletionPercentage).Append(",")
              .Append("\"isCritical\":").Append(t.IsCritical ? "true" : "false").Append(",")
              .Append("\"isMilestone\":").Append(t.IsMilestone ? "true" : "false")
              .Append("}},");
        }

        foreach (var r in taskRelations)
        {
            var predTask = tasks.FirstOrDefault(t => t.Id == r.PredecessorTaskId);
            var succTask = tasks.FirstOrDefault(t => t.Id == r.SuccessorTaskId);
            bool isCriticalEdge = (predTask?.IsCritical ?? false) && (succTask?.IsCritical ?? false);

            sb.Append("{\"data\":{")
              .Append("\"source\":\"").Append(r.PredecessorTaskId).Append("\",")
              .Append("\"target\":\"").Append(r.SuccessorTaskId).Append("\",")
              .Append("\"relType\":\"").Append(r.Type).Append("\",")
              .Append("\"lag\":").Append(r.Lag).Append(",")
              .Append("\"isCritical\":").Append(isCriticalEdge ? "true" : "false")
              .Append("}},");
        }

        if (sb.Length > 1 && sb[^1] == ',') sb.Length--;
        sb.Append(']');

        graphJson = sb.ToString();
        var totalDuration = tasks.Any() ? (tasks.Max(t => t.PlanEndDate) - tasks.Min(t => t.PlanStartDate)).Days + 1 : 0;
        optionsJson = System.Text.Json.JsonSerializer.Serialize(new
        {
            showCritical = showCriticalHighlight,
            showFloat = showFloatLabels,
            showTodayLine = showTodayLine,
            showProgressLine = showProgressLine,
            showDummyArrows = showDummyArrows,
            showProgressCurve = showProgressCurve,
            projectStartDate = projectStartDate.ToString("yyyy-MM-dd"),
            totalDays = totalDays,
            totalDuration = totalDuration,
            dayWidth = dayWidth,
            projectName = project?.Name ?? "",
            mode = netMode,
            labelFields = GetLabelFields(),
            rowLabels = new object[] { },
            layerHeight = graphLayerHeight,
            nodeRadius = graphNodeRadius,
            labelFontSize = graphLabelFontSize,
            restDayPattern = showRestDayPattern,
            criticalColor = "#e63946",
            normalColor = "#1890ff",
            dummyColor = "#1890ff",
            criticalWidth = 3,
            normalWidth = 1.5
        });
        renderToken++;
        if (!skipLoading) statusMessage = $"共 {tasks.Count} 任务,{taskRelations.Count} 关系,总工期 {totalDuration} 天";
        isLoading = false;
        StateHasChanged();
        // 直接调用 JS 渲染(替换旧轮询机制)
        try { await JS.InvokeVoidAsync("renderNetwork", graphJson, optionsJson); } catch { }
    }

