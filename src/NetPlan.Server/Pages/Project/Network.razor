        selectedPredTaskId = 0; selectedPredLag = 0; selectedPredType = RelationType.FS;
        selectedSuccTaskId = 0; selectedSuccLag = 0; selectedSuccType = RelationType.FS;
        editingPredRelationIndex = -1;
