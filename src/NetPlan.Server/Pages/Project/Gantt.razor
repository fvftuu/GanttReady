    private void AddOrUpdatePredecessor()
    {
        if (editingTask == null || selectedPredTaskId == 0) return;
        if (editingPredRelationIndex >= 0)
        {
            // 更新已有关系
            editingPredecessors[editingPredRelationIndex].PredecessorTaskId = selectedPredTaskId;
            editingPredecessors[editingPredRelationIndex].Type = selectedPredType;
            editingPredecessors[editingPredRelationIndex].Lag = selectedPredLag;
            editingPredRelationIndex = -1;
        }
        else
        {
            var existing = editingPredecessors.FirstOrDefault(r => r.PredecessorTaskId == selectedPredTaskId);
            if (existing != null) return;
            editingPredecessors.Add(new TaskRelation
            {
                ProjectId = currentProjectId,
                PredecessorTaskId = selectedPredTaskId,
                SuccessorTaskId = editingTask.Id,
                Type = selectedPredType,
                Lag = selectedPredLag
            });
        }
        selectedPredTaskId = 0;
        selectedPredLag = 0;
        selectedPredType = RelationType.FS;
    }

    private void EditPredecessor(TaskRelation rel)
    {
        var idx = editingPredecessors.IndexOf(rel);
        if (idx < 0) return;
        editingPredRelationIndex = idx;
        selectedPredTaskId = rel.PredecessorTaskId;
        selectedPredType = rel.Type;
        selectedPredLag = rel.Lag;
    }

    private void RemovePredecessor(TaskRelation rel)
    {
        editingPredecessors.Remove(rel);
        editingPredRelationIndex = -1;
    }

