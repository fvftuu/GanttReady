    {
        if (currentProjectId == 0)
        {
            await JS.InvokeVoidAsync("alert", "请先选择项目");
            return;
        }
        await JS.InvokeVoidAsync("eval", "document.getElementById('projectXmlInput').click()");
    }

    private async Task HandleProjectXmlSelected(InputFileChangeEventArgs e)
    {
        if (e.File == null || currentProjectId == 0) return;

        try
        {
            using var stream = e.File.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);

            var content = new MultipartFormDataContent();
            content.Add(new ByteArrayContent(memoryStream.ToArray()), "file", e.File.Name);

            var baseUri = new Uri(NavManager.BaseUri);
            var response = await HttpClient.PostAsync(
                new Uri(baseUri, $"/api/projectxml/import/{currentProjectId}"), content);
            var result = await response.Content.ReadFromJsonAsync<ProjectImportResult>();

            if (result != null)
            {
                if (result.Success)
                {
                    await JS.InvokeVoidAsync("alert",
                        $"Project 导入成功！\n任务: {result.TasksImported}\n关系: {result.RelationsImported}");
                    projects = await ProjectService.GetAllProjectsAsync();
                    await LoadTasks();
                    StateHasChanged();
                }
                else
                {
                    var errorMsg = result.Errors.Count > 0
                        ? string.Join("\n", result.Errors.Take(5))
                        : result.Message;
                    await JS.InvokeVoidAsync("alert", $"导入失败:\n{errorMsg}");
                }
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Project 导入出错: {ex.Message}");
        }
    }

    // 需要 using NetPlan.Server.Services 引用 ProjectImportResult

    // ========== 多选任务 ==========
    private void ToggleSelectAll()
    {
        if (selectedTasks.Count == tasks.Count && tasks.Count > 0)
            selectedTasks.Clear();
        else
            selectedTasks = tasks.Select(t => t.Id).ToHashSet();
    }

    private void ToggleTaskSelect(int taskId, bool isChecked)
    {
        if (isChecked) selectedTasks.Add(taskId);
        else selectedTasks.Remove(taskId);
    }

    // ========== 降级/升级（层级管理）==========
    private async Task IndentSelected()
    {
        if (!selectedTasks.Any()) return;
        await IndentTasksAsync(selectedTasks.ToList());
        selectedTasks.Clear();
        await LoadTasks();
        StateHasChanged();
    }

    private async Task OutdentSelected()
    {
        if (!selectedTasks.Any()) return;
        await OutdentTasksAsync(selectedTasks.ToList());
        selectedTasks.Clear();
        await LoadTasks();
        StateHasChanged();
    }

    /// <summary>
    /// 降级：将选中的任务设为列表中上一个低层级任务的子任务
    /// </summary>
    private async Task IndentTasksAsync(List<int> taskIds)
    {
        var ordered = tasks.OrderBy(t => t.SortOrder).ToList();
        foreach (var tid in taskIds.OrderBy(id => tasks.FindIndex(t => t.Id == id)))
        {
            var task = tasks.FirstOrDefault(t => t.Id == tid);
            if (task == null || task.OutlineLevel >= 10) continue; // 最多10层
            var idx = ordered.FindIndex(t => t.Id == tid);
            // 找上一个更低层级（OutlineLevel < current）的任务作为父任务
            for (int i = idx - 1; i >= 0; i--)
            {
                if (ordered[i].OutlineLevel <= task.OutlineLevel)
                {
                    task.ParentTaskId = ordered[i].Id;
                    task.OutlineLevel = ordered[i].OutlineLevel + 1;
                    task.IsManualSchedule = false;
                    await ProjectService.UpdateTaskAsync(task);

                    // 递归更新子任务层级
                    await UpdateChildrenOutlineLevel(task);
                    break;
                }
            }
            // 重算父任务工期
            if (task.ParentTaskId.HasValue)
                await RecalcParentDurationAsync(task.ParentTaskId.Value);
        }
    }

    private async Task UpdateChildrenOutlineLevel(TaskItem parent)
    {
        var children = tasks.Where(t => t.ParentTaskId == parent.Id).ToList();
        foreach (var child in children)
        {
            child.OutlineLevel = parent.OutlineLevel + 1;
            await ProjectService.UpdateTaskAsync(child);
            await UpdateChildrenOutlineLevel(child);
        }
    }

    /// <summary>
    /// 升级：取消父任务关联，提升到父任务层级
    /// </summary>
    private async Task OutdentTasksAsync(List<int> taskIds)
    {
        foreach (var tid in taskIds)
        {
            var task = tasks.FirstOrDefault(t => t.Id == tid);
            if (task == null || !task.ParentTaskId.HasValue) continue;
            var oldParentId = task.ParentTaskId;
            var parent = tasks.FirstOrDefault(t => t.Id == task.ParentTaskId);
            if (parent != null)
            {
                task.ParentTaskId = parent.ParentTaskId; // 挂到祖父
                task.OutlineLevel = Math.Max(1, task.OutlineLevel - 1);
                task.IsManualSchedule = false;
                await ProjectService.UpdateTaskAsync(task);
                await UpdateChildrenOutlineLevel(task);
                await RecalcParentDurationAsync(oldParentId.Value);
                if (task.ParentTaskId.HasValue)
                    await RecalcParentDurationAsync(task.ParentTaskId.Value);
            }
        }
    }

    /// <summary>
    /// 重算父任务工期 = 所有子任务的总工期跨度
    /// </summary>
    private async Task RecalcParentDurationAsync(int parentId)
    {
        var children = tasks.Where(t => t.ParentTaskId == parentId).ToList();
        if (!children.Any()) return;

        var minStart = children.Min(c => c.PlanStartDate);
        var maxEnd = children.Max(c => c.PlanEndDate);
        var parent = tasks.FirstOrDefault(t => t.Id == parentId);
        if (parent != null && !parent.IsManualSchedule)
        {
            parent.PlanStartDate = minStart;
            parent.PlanEndDate = maxEnd;
            parent.PlanDuration = Math.Max(1, (maxEnd - minStart).Days + 1);
            parent.IsMilestone = children.All(c => c.IsMilestone);
            await ProjectService.UpdateTaskAsync(parent);
        }
    }

    [Inject] private HttpClient HttpClient { get; set; } = default!;
