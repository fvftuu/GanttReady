    private DotNetObjectReference<Gantt>? dotNetRef;
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try
        {
            if (firstRender)
            {
                dotNetRef = DotNetObjectReference.Create(this);
            }
            // RestoreGanttSettings 必须在 JS 可用时才执行（预渲染阶段 JS 不可用）
            if (!_ganttSettingsRestored)
            {
                await RestoreGanttSettings();
                _ganttSettingsRestored = true;
                StateHasChanged();
            }
            await JS.InvokeVoidAsync("setGanttDotNet", dotNetRef);
            await JS.InvokeVoidAsync("initGanttScroll");
            await JS.InvokeVoidAsync("initPanelResize");
            // 同步左右行高（延迟版：等浏览器 layout 完成后再执行）
            await JS.InvokeVoidAsync("syncGanttRowHeightsDeferred");
            await JS.InvokeVoidAsync("initBarActResize");
        }
        catch (Exception) { /* 预渲染阶段 JS 不可用，忽略 */ }
    }
    public void Dispose() => dotNetRef?.Dispose();

    private async Task LoadTasks()
    {
        if (currentProjectId == 0) return;

        loading = true;

        // 先重算预算金额（基于资源分配 × 工期，写入DB）
        await ProjectService.RecalculateAllTaskBudgetsAsync(currentProjectId);

        // 再加载任务数据（BudgetCost 已是最新值）
        tasks = await ProjectService.GetTasksByProjectIdAsync(currentProjectId);
        taskRelations = await ProjectService.GetRelationsByProjectIdAsync(currentProjectId);
        projectResources = await ResourceService.GetResourcesByProjectAsync(currentProjectId);
        taskAssignments = await ResourceService.GetAssignmentsByProjectAsync(currentProjectId);
        if (tasks.Any())
        {
            // 加载后刷新 tasks，确保名称/工期/代码等字段是最新的
            // 注意：LoadTasks 不再重复计算 CPM（调用者应自行决定是否重算）
            var project = projects.FirstOrDefault(p => p.Id == currentProjectId);
            if (project != null)
            {
                // 时间标尺起点：项目计划开始 vs 最早的任务计划/实际开始
                var chartStart = project.PlanStartDate;
                if (tasks.Any())
                {
                    var minTaskDate = tasks.Min(t => t.PlanStartDate);
                    var minDates = new List<DateTime> { chartStart, minTaskDate };
                    if (tasks.Any(t => t.ActualStartDate.HasValue))
                    {
                        var minActualDate = tasks.Where(t => t.ActualStartDate.HasValue).Min(t => t.ActualStartDate.Value);
                        minDates.Add(minActualDate);
                    }
                    chartStart = minDates.Min();
                }
                projectStartDate = chartStart;
                // 终点：项目计划完成 vs 最晚任务计划/实际完成
                var chartEnd = project.PlanEndDate;
                if (tasks.Any())
                {
                    var maxTaskDate = tasks.Max(t => t.PlanEndDate);
                    var maxDates = new List<DateTime> { chartEnd, maxTaskDate };
                    if (tasks.Any(t => t.ActualEndDate.HasValue))
                    {
                        var maxActualDate = tasks.Where(t => t.ActualEndDate.HasValue).Max(t => t.ActualEndDate.Value);
                        maxDates.Add(maxActualDate);
                    }
                    chartEnd = maxDates.Max();
                }
                totalDays = Math.Max(90, (chartEnd - chartStart).Days + 30);
            }
        }
        RefreshFloatWarnings();
        CalculateHistogram();
        loading = false;
        try { _ = JS.InvokeVoidAsync("initBarActResize"); } catch { }
    }

