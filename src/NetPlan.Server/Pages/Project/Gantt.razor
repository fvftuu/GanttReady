    private async Task HandleGanttFileSelected(InputFileChangeEventArgs e)
    {
        if (e.File == null || currentProjectId == 0) return;

        try
        {
            using var stream = e.File.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);

            var content = new MultipartFormDataContent();
            content.Add(new ByteArrayContent(memoryStream.ToArray()), "file", e.File.Name);

            var baseUri = new Uri(NavManager.BaseUri);
            var response = await HttpClient.PostAsync(new Uri(baseUri, $"/api/excel/import/{currentProjectId}"), content);
            var result = await response.Content.ReadFromJsonAsync<ExcelImportResult>();

            if (result != null)
            {
                if (result.Success)
                {
                    await JS.InvokeVoidAsync("alert", $"导入成功！\n任务: {result.TasksImported}\n资源: {result.ResourcesImported}\n分配: {result.AssignmentsImported}");
                    // 重新加载项目列表（获取最新的项目起止日期）
                    projects = await ProjectService.GetAllProjectsAsync();
                    await LoadTasks();
                    StateHasChanged();
                }
                else
                {
                    var errorMsg = result.Errors.Count > 0
                        ? string.Join("\n", result.Errors.Take(5))
                        : result.Message;
                    await JS.InvokeVoidAsync("alert", $"导入完成但有错误:\n{errorMsg}");
                }
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"导入出错: {ex.Message}");
        }
    }

