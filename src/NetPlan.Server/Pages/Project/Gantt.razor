@page "/project/{ProjectId:int}/gantt"
@inject IProjectService ProjectService
@inject IResourceService ResourceService
@inject IJSRuntime JS
@inject NavigationManager NavManager
@implements IDisposable

<div class="page-header">
    <div class="header-left">
        <select class="form-control" @bind="currentProjectId" @bind:after="LoadTasks">
            <option value="0">选择项目</option>
            @foreach (var project in projects)
            {
                <option value="@project.Id">@project.Name</option>
            }
        </select>
        <span class="page-title">甘特图</span>
        <div class="task-actions">
            <button class="btn btn-primary btn-icon" @onclick="ShowAddTaskModal" title="添加任务">
                <span class="oi oi-plus"></span>
            </button>
            <button class="btn btn-danger btn-icon" @onclick="DeleteSelectedTask" title="删除任务" disabled="@(selectedTaskId == null)">
                <span class="oi oi-trash"></span>
            </button>
            <button class="btn btn-default btn-icon" @onclick="MoveTaskUp" title="上移" disabled="@(selectedTaskId == null)">
                <span class="oi oi-caret-top"></span>
            </button>
            <button class="btn btn-default btn-icon" @onclick="MoveTaskDown" title="下移" disabled="@(selectedTaskId == null)">
                <span class="oi oi-caret-bottom"></span>
            </button>
            <div style="position:relative; display:inline-block;">
                <button class="btn btn-default btn-icon" @onclick="ToggleColumnPanel" title="列设置">
                    <span class="oi oi-list"></span>
                </button>
                @if (showColumnPanel)
                {
                    <div class="column-panel" @onclick:stopPropagation="true">
                        @for (int i = 0; i < columnTemp.Count; i++)
                        {
                            var idx = i;
                            var col = columnTemp[i];
                            var disabled = col.Key == "name";
                            <label class="column-check">
                                <input type="checkbox" checked="@col.Visible"
                                       disabled="@disabled"
                                       @onchange="(ChangeEventArgs e) => OnColumnCheckChange(idx, (bool)(e.Value ?? false))" />
                                <span>@col.Label</span>
                            </label>
                        }
                        <div style="display:flex; gap:6px; margin-top:8px; padding-top:8px; border-top:1px solid var(--border);">
                            <button class="btn btn-primary btn-sm" style="flex:1;" @onclick="ApplyColumnVisibility">确定</button>
                            <button class="btn btn-default btn-sm" style="flex:1;" @onclick="CancelColumnVisibility">取消</button>
                        </div>
                    </div>
                }
            </div>
        </div>
        <div class="display-toggles">
            <label class="toggle-switch" title="显示前锋线">
                <input type="checkbox" @bind="showProgressLine" />
                <span class="toggle-slider"></span>
            </label>
            <span class="toggle-label">前锋线</span>
            <label class="toggle-switch" title="显示今日线">
                <input type="checkbox" @bind="showTodayLine" />
                <span class="toggle-slider"></span>
            </label>
            <span class="toggle-label">今日线</span>
            <label class="toggle-switch" title="显示关系线">
                <input type="checkbox" @bind="showRelationLine" />
                <span class="toggle-slider"></span>
            </label>
            <span class="toggle-label">关系线</span>
            <label class="toggle-switch" title="资源投入直方图">
                <input type="checkbox" @bind="showResourceHistogram" @bind:after="OnHistogramToggled" />
                <span class="toggle-slider"></span>
            </label>
            <span class="toggle-label">资源投入</span>
        </div>
    </div>
    <div class="header-right">
        <button class="btn btn-default" @onclick="PrintPage" title="页面预览">
            <span class="oi oi-print"></span> 预览
        </button>
        <button class="btn btn-default" @onclick="ExportToExcel" title="导出Excel">
            <span class="oi oi-file"></span> 导出
        </button>
        <button class="btn btn-default" @onclick="DownloadTemplate" title="下载导入模板">
            <span class="oi oi-cloud-download"></span> 模板
        </button>
        <InputFile id="ganttFileInput" OnChange="HandleGanttFileSelected" accept=".xlsx,.xls" style="display:none" />
        <button class="btn btn-default" @onclick="TriggerGanttImport" title="从Excel导入">
            <span class="oi oi-cloud-upload"></span> 导入
        </button>
        <InputFile id="projectXmlInput" OnChange="HandleProjectXmlSelected" accept=".xml" style="display:none" />
        <button class="btn btn-default" @onclick="TriggerProjectXmlImport" title="从MS Project XML导入">
            <span class="oi oi-project"></span> Project
        </button>
        <div class="zoom-control">
            <button class="zoom-btn" @onclick="ZoomOut" title="缩小">
                <span class="oi oi-minus"></span>
            </button>
            <span class="zoom-label">@zoomLevel%</span>
            <button class="zoom-btn" @onclick="ZoomIn" title="放大">
                <span class="oi oi-plus"></span>
            </button>
        </div>
        <button class="btn btn-default btn-icon" @onclick="ZoomToFit" title="适应页面（全部显示）">
            <span class="oi oi-magnifying-glass"></span>
        </button>
        <button class="btn btn-default" @onclick="RecalculateSchedule">重算计划</button>
    </div>
</div>

@if (taskFloatWarnings.Any())
{
    var redCount = taskFloatWarnings.Count(w => w.Value > 365);
    var orangeCount = taskFloatWarnings.Count(w => w.Value > 200 && w.Value <= 365);
    var yellowCount = taskFloatWarnings.Count(w => w.Value > 100 && w.Value <= 200);
    <div class="float-warning-bar">
        <span class="float-warn-icon">⚠️</span>
        <span>时差异常：</span>
        @if (redCount > 0) { <span class="float-badge float-red">@redCount 个严重(&gt;365天)</span> }
        @if (orangeCount > 0) { <span class="float-badge float-orange">@orangeCount 个警告(&gt;200天)</span> }
        @if (yellowCount > 0) { <span class="float-badge float-yellow">@yellowCount 个可疑(&gt;100天)</span> }
        <span style="font-size:11px;color:var(--text-secondary);margin-left:8px;">— 请检查并手动调整对应任务</span>
    </div>
}

<div class="gantt-container">
    <div class="gantt-main">
    @* ========== 冻结窗格：左侧任务列表 ========== *@
    <GanttTable Tasks="tasks" SelectedTaskId="selectedTaskId" SelectedTaskIds="selectedTasks"
                Loading="loading" TaskRelations="taskRelations" ProjectResources="projectResources"
                ResourceAssignments="taskAssignments" IsColumnVisible="GetColumnVisible"
                OnTaskSelected="id => { selectedTaskId = id; ToggleTaskSelect(id, !selectedTasks.Contains(id)); }" OnTaskEdit="EditTask"
                OnTaskCheckChanged="args => ToggleTaskSelect(args.TaskId, args.Selected)"
                OnSelectAllToggle="sel => ToggleSelectAll()" OnIndent="IndentSelected" OnOutdent="OutdentSelected" />

    @* 拖拽调整宽度的分隔手柄 *@
    <div id="gantt-resize-handle" class="gantt-resize-handle"></div>

    @* ========== 右侧甘特图区域（可横向滚动） ========== *@
    <div class="gantt-right" id="gantt-right" onscroll="syncGanttScrollById()">
        <div class="gantt-chart" style="width: @chartWidth;" data-day-width="@dayWidth">
            @* 双层时间轴头部（sticky固定在顶部） *@
            @{
                // 计算年月跨度（上层显示）
                var months = new List<(DateTime date, int span)>();
                var currentMonth = projectStartDate;
                while (currentMonth < projectStartDate.AddDays(totalDays))
                {
                    var daysInMonth = DateTime.DaysInMonth(currentMonth.Year, currentMonth.Month);
                    var remainingDays = (projectStartDate.AddDays(totalDays) - currentMonth).Days;
                    var span = Math.Min(daysInMonth - currentMonth.Day + 1, remainingDays);
                    months.Add((currentMonth, span));
                    currentMonth = currentMonth.AddMonths(1);
                }
                
                // 计算周年跨度（周模式下使用）
                var weeks = new List<(int weekOfYear, int span, DateTime startDate)>();
                if (dayWidth >= 10 && dayWidth <= 20)
                {
                    var currentDay = projectStartDate;
                    while (currentDay < projectStartDate.AddDays(totalDays))
                    {
                        var weekOfYear = System.Globalization.ISOWeek.GetWeekOfYear(currentDay);
                        var weekStart = currentDay;
                        var weekSpan = 0;
                        while (currentDay < projectStartDate.AddDays(totalDays) &&
                               System.Globalization.ISOWeek.GetWeekOfYear(currentDay) == weekOfYear)
                        {
                            weekSpan++;
                            currentDay = currentDay.AddDays(1);
                        }
                        weeks.Add((weekOfYear, weekSpan, weekStart));
                    }
                }

                // 根据缩放级别判断显示精度
                // > 20px: yyyy/MM
                // 10-20px: yyyy
                // < 10px: yyyy
                var upperDisplayMode = dayWidth > 20 ? "full" : "year";
                
                // > 20px: 日模式(dd)
                // 10-20px: 周模式(第X周)
                // < 10px: 月模式(MM)
                var lowerDisplayMode = dayWidth > 20 ? "day" : (dayWidth >= 10 ? "week" : "month");
            }
            <div class="gantt-timeline-container">
                @* 上层：年月/年月/年 *@
                <div class="gantt-timeline-header gantt-timeline-upper">
                    @if (upperDisplayMode == "year")
                    {
                        @* 只显示年 *@
                        var years = months.GroupBy(m => m.date.Year).ToList();
                        foreach (var yearGroup in years)
                        {
                            var totalSpan = yearGroup.Sum(m => m.span);
                            <div class="timeline-month" style="width: @(totalSpan * dayWidth)px;">
                                <span>@yearGroup.Key</span>
                            </div>
                        }
                    }
                    else
                    {
                        @foreach (var month in months)
                        {
                            <div class="timeline-month" style="width: @(month.span * dayWidth)px;">
                                @if (upperDisplayMode == "full")
                                {
                                    <span>@month.date.ToString("yyyy/MM")</span>
                                }
                                else
                                {
                                    <span>@month.date.ToString("MM")</span>
                                }
                            </div>
                        }
                    }
                </div>
                @* 下层：日/周/月 *@
                <div class="gantt-timeline-header gantt-timeline-lower">
                    @if (lowerDisplayMode == "day")
                    {
                        @* 每日显示 *@
                        @for (int day = 0; day <= totalDays; day++)
                        {
                            var date = projectStartDate.AddDays(day);
                            var isWeekend = date.DayOfWeek == DayOfWeek.Saturday || date.DayOfWeek == DayOfWeek.Sunday;
                            <div class="timeline-day @(isWeekend ? "weekend" : "")"
                                 style="width: @(dayWidth)px;">
                                @date.ToString("dd")
                            </div>
                        }
                    }
                    else if (lowerDisplayMode == "week")
                    {
                        @* 周显示 - 显示本年度第X周 *@
                        var currentYear = 0;
                        @foreach (var week in weeks)
                        {
                            if (week.startDate.Year != currentYear)
                            {
                                currentYear = week.startDate.Year;
                            }
                            <div class="timeline-day" style="width: @(week.span * dayWidth)px;">
                                第@(week.weekOfYear)周
                            </div>
                        }
                    }
                    else
                    {
                        @* 月显示 *@
                        @foreach (var month in months)
                        {
                            <div class="timeline-day" style="width: @(month.span * dayWidth)px;">
                                @month.date.ToString("MM")
                            </div>
                        }
                    }
                </div>
            </div>
            @* 时间标尺竖线层 *@
            <div class="gantt-grid-lines" style="height: @(tasks.Count * rowHeight + 40)px;">
                @{
                    // 计算年份边界线位置
                    var yearBoundaries = new List<(DateTime date, int dayOffset, bool isYearStart)>(); 
                    for (int year = projectStartDate.Year; year <= projectStartDate.AddDays(totalDays).Year; year++)
                    {
                        var yearStart = new DateTime(year, 1, 1);
                        if (yearStart >= projectStartDate && yearStart <= projectStartDate.AddDays(totalDays))
                        {
                            var offset = (yearStart - projectStartDate).Days;
                            yearBoundaries.Add((yearStart, offset, true));
                        }
                    }
                }
                @* 年度粗实线 *@
                @foreach (var yb in yearBoundaries)
                {
                    <div class="grid-line year-line" style="left: @(yb.dayOffset * dayWidth)px;"></div>
                }
                @* 月度细实线（年度边界除外） *@
                @for (int i = 0; i < months.Count; i++)
                {
                    var monthStartOffset = (months[i].date - projectStartDate).Days;
                    var isYearStart = months[i].date.Month == 1;
                    @if (!isYearStart)
                    {
                        <div class="grid-line month-line" style="left: @(monthStartOffset * dayWidth)px;"></div>
                    }
                }
            </div>
            @* 前置关系线 SVG 层 *@
            <svg class="gantt-relation-lines" style="height: @(tasks.Count * rowHeight)px; width: @(totalDays * dayWidth)px;">
                <defs>
                    <marker id="arrowhead" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
                        <polygon points="0 0, 10 3.5, 0 7" fill="#666"/>
                    </marker>
                    <marker id="progress-arrow" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
                        <polygon points="0 0, 10 3.5, 0 7" fill="#ff6b00"/>
                    </marker>
                </defs>
                @* 今日线 *@
                @if (showTodayLine)
                {
                    var todayOffset = Math.Max(0, (DateTime.Today - projectStartDate).Days) * dayWidth;
                    var todayX = todayOffset + dayWidth / 2;
                    <line x1="@todayX" y1="0" x2="@todayX" y2="@(tasks.Count * rowHeight)" 
                          stroke="#e74c3c" stroke-width="2" stroke-dasharray="5,3"/>
                }
                @* 前锋线（基于任务完成率的进度前锋线） *@
                @if (showProgressLine)
                {
                    @* 计算每个任务的进度点位置 *@
                    var progressPoints = new List<(double x, double y)>();
                    foreach (var task in tasks)
                    {
                        var rowIndex = tasks.IndexOf(task);
                        var startOffset = Math.Max(0, (task.PlanStartDate - projectStartDate).Days) * dayWidth;
                        var barWidth = task.PlanDuration * dayWidth;
                        var progressX = startOffset + barWidth * task.CompletionPercentage / 100.0;
                        var progressY = rowIndex * rowHeight + 18; // 行中心
                        progressPoints.Add((progressX, progressY));
                    }
                    @* 折线连接所有进度点 *@
                    <polyline points="@string.Join(" ", progressPoints.Select(p => $"{p.x:F1},{p.y:F1}"))"
                              stroke="#ff6b00" stroke-width="1.5" fill="none" opacity="0.6" stroke-linejoin="round"/>
                    @* 在每个进度点画圆点标记 *@
                    foreach (var pt in progressPoints)
                    {
                        <circle cx="@pt.x" cy="@pt.y" r="3.5" fill="#ff6b00" opacity="0.8"/>
                    }
                }
                @* 前置关系线 *@
                @if (showRelationLine)
                {
                    @foreach (var rel in taskRelations)
                    {
                        var predTask = tasks.FirstOrDefault(t => t.Id == rel.PredecessorTaskId);
                        var succTask = tasks.FirstOrDefault(t => t.Id == rel.SuccessorTaskId);
                        @if (predTask != null && succTask != null)
                        {
                            var predRow = tasks.IndexOf(predTask);
                            var succRow = tasks.IndexOf(succTask);
                            var predEndOffset = Math.Max(0, (predTask.PlanEndDate - projectStartDate).Days) * dayWidth + dayWidth;
                            var succStartOffset = Math.Max(0, (succTask.PlanStartDate - projectStartDate).Days) * dayWidth;
                            var predTop = predRow * rowHeight + 18;
                            var succTop = succRow * rowHeight + 18;
                            
                            @if (predRow == succRow)
                            {
                                <line x1="@predEndOffset" y1="@predTop" x2="@succStartOffset" y2="@succTop" 
                                      stroke="#666" stroke-width="1.5" marker-end="url(#arrowhead)"/>
                            }
                            else
                            {
                                var midX = predEndOffset + Math.Max(20, (succStartOffset - predEndOffset) / 2);
                                <path d="M @predEndOffset @predTop L @midX @predTop L @midX @succTop L @succStartOffset @succTop" 
                                      stroke="#666" stroke-width="1.5" fill="none" marker-end="url(#arrowhead)"/>
                            }
                        }
                    }
                }
            </svg>
            @* 甘特条形图（重构：蓝上绿下 共享边框） *@
            <div class="gantt-bars" style="height: @(tasks.Count * rowHeight)px;">
                @foreach (var task in tasks)
                {
                    var rowIndex = tasks.IndexOf(task);
                    var planStart = Math.Max(0, (task.PlanStartDate - projectStartDate).Days) * dayWidth;
                    var planW = task.PlanDuration * dayWidth;
                    var actStart = 0.0; var actW = 0.0; var hasActual = false;
                    if (task.ActualStartDate.HasValue)
                    {
                        actStart = Math.Max(0, (task.ActualStartDate.Value - projectStartDate).Days) * dayWidth;
                        var actEnd = task.ActualEndDate ?? DateTime.Today;
                        if (actEnd < task.ActualStartDate.Value) actEnd = task.ActualStartDate.Value;
                        actW = Math.Max(2, (actEnd - task.ActualStartDate.Value).Days * dayWidth);
                        hasActual = true;
                    }
                    var barLeft = hasActual ? Math.Min(planStart, actStart) : planStart;
                    var barTotalW = hasActual ? Math.Max(planStart + planW, actStart + actW) - barLeft : planW;
                    var barHeight = rowHeight * 0.9; // 90%
                    var barTop = (rowHeight - barHeight) / 2;
                    var planLeft = planStart - barLeft;
                    var actLeft = hasActual ? (actStart - barLeft) : 0;
                    <div class="gantt-bar-frame @GetBarClass(task) @(selectedTaskId == task.Id ? "selected" : "")"
                         style="left: @(barLeft)px; width: @(barTotalW)px; top: @(rowIndex * rowHeight + barTop)px; height: @(barHeight)px;"
                         draggable="true"
                         @ondragstart="(e) => OnBarDragStart(e, task)"
                         @ondrag="OnBarDrag"
                         @ondragend="(e) => OnBarDragEnd(e, task)"
                         @ondblclick="() => EditTask(task)"
                         @onclick="() => SelectTask(task.Id)"
                         title="@task.Name"
                         data-task-id="@task.Id">
                        @* 计划进度（蓝色上半部） *@
                        <div class="bar-plan" style="left: @(planLeft)px; width: @(planW)px;"></div>
                        @* 实际进度（绿色下半部） *@
                        @if (hasActual)
                        {
                            <div class="bar-act" style="left: @(actLeft)px; width: @(actW)px;"></div>
                        }
                        <span class="bar-label">@task.Name @(task.CompletionPercentage > 0 ? $"({task.CompletionPercentage}%)" : "")</span>
                    </div>
                }
            </div>
        </div>
    </div>
    </div>@* end gantt-main *@

    @* ========== 资源投入折线图面板 ========== *@
    @if (showResourceHistogram)
    {
        <div class="histogram-panel">
            <div class="histogram-body">
                <div class="histogram-sidebar">
                    <span class="histogram-title">投入</span>
                    <button class="histogram-sort-btn @(resourceFilter == "all" ? "active" : "")" @onclick="FilterAll">全部</button>
                    <button class="histogram-sort-btn labor @(resourceFilter == "labor" ? "active" : "")" @onclick="FilterLabor">人</button>
                    <button class="histogram-sort-btn material @(resourceFilter == "material" ? "active" : "")" @onclick="FilterMaterial">材</button>
                    <button class="histogram-sort-btn equipment @(resourceFilter == "equipment" ? "active" : "")" @onclick="FilterEquipment">机</button>
                    <span class="histogram-title" style="margin-top:6px;">周期</span>
                    <button class="histogram-sort-btn @(histogramGranularity == "week" ? "active" : "")" @onclick="SetGranularityWeek">周</button>
                    <button class="histogram-sort-btn @(histogramGranularity == "month" ? "active" : "")" @onclick="SetGranularityMonth">月</button>
                    <button class="histogram-sort-btn @(histogramGranularity == "quarter" ? "active" : "")" @onclick="SetGranularityQuarter">季</button>
                    <button class="histogram-sort-btn @(histogramGranularity == "year" ? "active" : "")" @onclick="SetGranularityYear">年</button>
                </div>
                <div class="histogram-chart-area">
                    @if (chartError != null)
                    {
                        <div style="display:flex;align-items:center;justify-content:center;height:100%;color:#ff4d4f;font-size:13px;gap:6px;">
                            <span class="oi oi-warning"></span> @chartError
                        </div>
                    }
                    <canvas id="resource-chart" style="@(chartError != null ? "display:none" : "")"></canvas>
                </div>
            </div>
        </div>
    }
</div>

@* ========== 底部状态栏 ========== *@
<div class="gantt-statusbar">
    @if (projects.Any(p => p.Id == currentProjectId))
    {
        var proj = projects.First(p => p.Id == currentProjectId);
        <span class="status-item">📁 项目：@proj.Name</span>
        <span class="status-divider">|</span>
        <span class="status-item">📅 总工期：@(tasks.Any() ? (tasks.Max(t => t.PlanEndDate) - tasks.Min(t => t.PlanStartDate)).Days + 1 : 0) 天</span>
        <span class="status-divider">|</span>
        <span class="status-item">🔢 任务数：@tasks.Count</span>
        <span class="status-divider">|</span>
        <span class="status-item">🔑 关键任务：@tasks.Count(t => t.IsCritical)</span>
    }
</div>

@* ========== 任务编辑模态框 ========== *@
@if (taskModalVisible && editingTask != null)
{
    <div class="modal-overlay">
        <div class="modal-content modal-content-wide" @onclick:stopPropagation="true">
            <h3>@(editingTask.Id > 0 ? "编辑任务" : "添加任务")</h3>

            <div class="form-row">
                <div class="form-group">
                    <label>任务代码</label>
                    <input class="form-control" @bind="editingTask.Code" placeholder="如 A1" />
                </div>
                <div class="form-group">
                    <label>任务名称</label>
                    <input class="form-control" @bind="editingTask.Name" placeholder="如 项目立项与审批" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>负责人</label>
                    <input class="form-control" @bind="editingTask.ResponsiblePerson" placeholder="负责人姓名" />
                </div>
                <div class="form-group">
                    <label>完成率(%)</label>
                    <input type="number" class="form-control" @bind="editingTask.CompletionPercentage" min="0" max="100" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group form-checkbox">
                    <input type="checkbox" id="milestoneCheck" @bind="editingTask.IsMilestone" />
                    <label for="milestoneCheck" style="margin:0; font-weight:500;">里程碑任务</label>
                </div>
                <div class="form-group form-checkbox">
                    <input type="checkbox" id="manualScheduleCheck" @bind="editingTask.IsManualSchedule" />
                    <label for="manualScheduleCheck" style="margin:0; font-weight:500;" title="勾选后重算计划不会覆盖此任务的日期">
                        🔒 手动排程
                    </label>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>计划开始日期</label>
                    <input type="date" class="form-control" @bind="editingTask.PlanStartDate" @bind:after="OnPlanDatesChanged" />
                </div>
                <div class="form-group">
                    <label>计划完成日期</label>
                    <input type="date" class="form-control" @bind="editingTask.PlanEndDate" @bind:after="OnPlanEndDateChanged" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>计划工期（天）</label>
                    <input type="number" class="form-control" @bind="editingTask.PlanDuration" min="1" @bind:after="OnPlanDurationChanged" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>实际开始日期</label>
                    <input type="date" class="form-control" @bind="editingTask.ActualStartDate" @bind:after="OnActualDatesChanged" />
                </div>
                <div class="form-group">
                    <label>实际完成日期</label>
                    <input type="date" class="form-control" @bind="editingTask.ActualEndDate" @bind:after="OnActualDatesChanged" />
                </div>
            </div>

            <div class="form-group">
                <label>备注</label>
                <textarea class="form-control" @bind="editingTask.Notes" rows="2" placeholder="任务备注"></textarea>
            </div>

            @* ===== 资源分配区域 ===== *@
            <div class="resource-assignment-box">
                <label style="font-weight:600; display:block; margin-bottom:4px;">资源分配</label>
                <div class="resource-type-filter">
                    <button class="type-filter-btn @(resourceAssignFilter == "all" ? "active" : "")" @onclick="SetAssignFilterAll">全部</button>
                    <button class="type-filter-btn labor @(resourceAssignFilter == "labor" ? "active" : "")" @onclick="SetAssignFilterLabor">👤 人工</button>
                    <button class="type-filter-btn material @(resourceAssignFilter == "material" ? "active" : "")" @onclick="SetAssignFilterMaterial">📦 材料</button>
                    <button class="type-filter-btn equipment @(resourceAssignFilter == "equipment" ? "active" : "")" @onclick="SetAssignFilterEquipment">🔧 设备</button>
                </div>
                <div style="display:flex; align-items:end; gap:12px; margin-top:4px;">
                    <div class="form-group" style="flex:2;">
                        <label>资源</label>
                        <select class="form-control" @bind="selectedResourceId">
                            <option value="0">-- 选择资源 --</option>
                            @foreach (var r in filteredAssignResources)
                            {
                                <option value="@r.Id">@r.Name (@r.Unit)</option>
                            }
                        </select>
                    </div>
                    <div class="form-group" style="flex:1;">
                        <label>数量</label>
                        <input type="number" class="form-control" @bind="assignQuantity" min="0" step="0.5" />
                    </div>
                    <div class="form-group" style="flex:0; padding-bottom:2px;">
                        <button class="btn btn-primary" @onclick="AddResourceAssignment" disabled="@(selectedResourceId == 0)">添加</button>
                    </div>
                </div>

                @if (taskAssignments != null && taskAssignments.Count > 0)
                {
                    <table class="table table-compact">
                        <thead>
                            <tr>
                                <th>资源名称</th>
                                <th>类型</th>
                                <th>数量</th>
                                <th>单位</th>
                                <th>操作</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ra in taskAssignments)
                            {
                                <tr>
                                    <td>@ra.Resource?.Name</td>
                                    <td>@(ra.Resource?.Type.ToString() ?? "")</td>
                                    <td>@ra.Quantity</td>
                                    <td>@ra.Resource?.Unit</td>
                                    <td>
                                        <button class="btn btn-danger btn-sm" @onclick="() => RemoveResourceAssignment(ra)">删除</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div style="color:#999; font-size:13px; padding:8px 0;">暂未分配资源</div>
                }
            </div>

            @* ===== 前置任务区域 ===== *@
            <div class="resource-assignment-box">
                <label style="font-weight:600; display:block; margin-bottom:6px;">前置任务</label>
                <div style="display:flex; align-items:end; gap:8px;">
                    <select class="form-control" @bind="selectedPredTaskId" style="flex:2;">
                        <option value="0">-- 选择前置任务 --</option>
                        @foreach (var t in availTasks)
                        {
                            <option value="@t.Id">@t.Code - @t.Name</option>
                        }
                    </select>
                    <select class="form-control" @bind="selectedPredType" style="flex:0 0 80px;">
                        <option value="@RelationType.FS">FS</option>
                        <option value="@RelationType.SS">SS</option>
                        <option value="@RelationType.FF">FF</option>
                        <option value="@RelationType.SF">SF</option>
                    </select>
                    <input type="number" class="form-control" @bind="selectedPredLag" style="flex:0 0 60px;" placeholder="天" />
                    <button class="btn btn-primary btn-sm" @onclick="AddOrUpdatePredecessor" disabled="@(selectedPredTaskId == 0)">
                        @(editingPredRelationIndex >= 0 ? "更新" : "添加")
                    </button>
                </div>
                @if (editingPredecessors.Count > 0)
                {
                    <table class="table table-compact" style="margin-top:8px;">
                        <thead>
                            <tr><th>任务</th><th>关系</th><th>时差(天)</th><th>操作</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var rel in editingPredecessors)
                            {
                                var pt = tasks.FirstOrDefault(t => t.Id == rel.PredecessorTaskId);
                                <tr>
                                    <td>@(pt == null ? "?" : rel.Lag == 0 ? pt.Code : $"{pt.Code}{(rel.Lag>0?"+":"")}{rel.Lag}") - @(pt?.Name ?? "未知")</td>
                                    <td>@rel.Type</td>
                                    <td>@rel.Lag</td>
                                    <td>
                                        <button class="btn btn-sm" @onclick="() => EditPredecessor(rel)">修改</button>
                                        <button class="btn btn-danger btn-sm" @onclick="() => RemovePredecessor(rel)">删除</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div style="color:#999; font-size:13px; padding:8px 0;">暂无前置任务</div>
                }
            </div>

            @* ===== 后置任务区域 ===== *@
            <div class="resource-assignment-box">
                <label style="font-weight:600; display:block; margin-bottom:6px;">后置任务</label>
                <div style="display:flex; align-items:end; gap:8px;">
                    <select class="form-control" @bind="selectedSuccTaskId" style="flex:2;">
                        <option value="0">-- 选择后置任务 --</option>
                        @foreach (var t in availTasks)
                        {
                            <option value="@t.Id">@t.Code - @t.Name</option>
                        }
                    </select>
                    <select class="form-control" @bind="selectedSuccType" style="flex:0 0 80px;">
                        <option value="@RelationType.FS">FS</option>
                        <option value="@RelationType.SS">SS</option>
                        <option value="@RelationType.FF">FF</option>
                        <option value="@RelationType.SF">SF</option>
                    </select>
                    <input type="number" class="form-control" @bind="selectedSuccLag" style="flex:0 0 60px;" placeholder="天" />
                    <button class="btn btn-primary btn-sm" @onclick="AddOrUpdateSuccessor" disabled="@(selectedSuccTaskId == 0)">
                        @(editingSuccRelationIndex >= 0 ? "更新" : "添加")
                    </button>
                </div>
                @if (editingSuccessors.Count > 0)
                {
                    <table class="table table-compact" style="margin-top:8px;">
                        <thead>
                            <tr><th>任务</th><th>关系</th><th>时差(天)</th><th>操作</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var rel in editingSuccessors)
                            {
                                var st = tasks.FirstOrDefault(t => t.Id == rel.SuccessorTaskId);
                                <tr>
                                    <td>@(st == null ? "?" : rel.Lag == 0 ? st.Code : $"{st.Code}{(rel.Lag>0?"+":"")}{rel.Lag}") - @(st?.Name ?? "未知")</td>
                                    <td>@rel.Type</td>
                                    <td>@rel.Lag</td>
                                    <td>
                                        <button class="btn btn-sm" @onclick="() => EditSuccessor(rel)">修改</button>
                                        <button class="btn btn-danger btn-sm" @onclick="() => RemoveSuccessor(rel)">删除</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div style="color:#999; font-size:13px; padding:8px 0;">暂无后置任务</div>
                }
            </div>

            @if (editingTask.Id > 0)
            {
                <div class="form-group">
                    <label>调度信息</label>
                    <div class="task-info-box">
                        <p>创建时间: @editingTask.CreatedAt.ToString("yyyy-MM-dd HH:mm")</p>
                        <p>最早开始(ES): @editingTask.EarlyStart 天 | 最早完成(EF): @editingTask.EarlyFinish 天</p>
                        <p>最迟开始(LS): @editingTask.LateStart 天 | 最迟完成(LF): @editingTask.LateFinish 天</p>
                        <p>总时差: @editingTask.TotalFloat 天 | @(editingTask.IsCritical ? "关键任务" : "非关键任务")</p>
                    </div>
                </div>
            }

            <div class="dialog-actions">
                @if (editingTask.Id > 0)
                {
                    <button class="btn btn-danger" @onclick="DeleteCurrentTask">删除任务</button>
                }
                <div style="flex:1;"></div>
                <button class="btn btn-default" @onclick="() => taskModalVisible = false">取消</button>
                <button class="btn btn-primary" @onclick="HandleTaskOk">确定</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int? ProjectId { get; set; }

    private List<Models.Project> projects = new();
    private List<TaskItem> tasks = new();
    private List<TaskRelation> taskRelations = new();
    private int currentProjectId { get; set; }
    private bool loading = true;
    private List<(string Name, int Value)> taskFloatWarnings = new();  // 时差异常警告
    private TaskItem? editingTask;
    private bool taskModalVisible = false;
    private int? selectedTaskId;
    private HashSet<int> selectedTasks = new();               // 多选任务ID集合

    // 显示控制开关
    private bool showProgressLine = true;
    private bool showTodayLine = true;
    private bool showRelationLine = true;

    // 拖拽相关
    private bool isDragging = false;
    private TaskItem? draggingTask;
    private double dragStartX = 0;
    private double originalBarLeft = 0;

    // 甘特图参数
    private double zoomLevel = 100;
    private double dayWidth => 40 * (zoomLevel / 100);
    private double rowHeight = 36;  // 行高
    private int totalDays = 90;
    private DateTime projectStartDate = DateTime.Today;
    private string chartWidth => $"{totalDays * dayWidth}px";

    // 资源分配相关
    private List<Resource> projectResources = new();
    private List<ResourceAssignment> taskAssignments = new();
    private int selectedResourceId = 0;
    private decimal assignQuantity = 1;

    // 资源投入折线图
    private bool showResourceHistogram = false;
    private string? chartError;
    private string resourceFilter = "all";
    private string histogramGranularity = "month";
    private string resourceAssignFilter = "all";
    private IEnumerable<Resource> filteredAssignResources => projectResources.Where(r =>
        resourceAssignFilter == "all" ||
        (resourceAssignFilter == "labor" && r.Type == ResourceType.Labor) ||
        (resourceAssignFilter == "material" && r.Type == ResourceType.Material) ||
        (resourceAssignFilter == "equipment" && r.Type == ResourceType.Equipment)
    );
    private void SetAssignFilterAll() => resourceAssignFilter = "all";
    private void SetAssignFilterLabor() => resourceAssignFilter = "labor";
    private void SetAssignFilterMaterial() => resourceAssignFilter = "material";
    private void SetAssignFilterEquipment() => resourceAssignFilter = "equipment";

    // 图表数据（Chart.js）
    private record ChartLine(string Name, string Color, List<(int Bucket, double Value)> Points);
    private List<ChartLine> chartLines = new();
    private List<string> chartAllLabels = new();

    private async Task SetResourceFilterAsync(string f) { resourceFilter = f; CalculateHistogram(); await RenderChartAsync(); }
    private async Task FilterAll() => await SetResourceFilterAsync("all");
    private async Task FilterLabor() => await SetResourceFilterAsync("labor");
    private async Task FilterMaterial() => await SetResourceFilterAsync("material");
    private async Task FilterEquipment() => await SetResourceFilterAsync("equipment");

    private async Task SetGranularityWeek() { histogramGranularity = "week"; CalculateHistogram(); await RenderChartAsync(); }
    private async Task SetGranularityMonth() { histogramGranularity = "month"; CalculateHistogram(); await RenderChartAsync(); }
    private async Task SetGranularityQuarter() { histogramGranularity = "quarter"; CalculateHistogram(); await RenderChartAsync(); }
    private async Task SetGranularityYear() { histogramGranularity = "year"; CalculateHistogram(); await RenderChartAsync(); }

    private async Task OnHistogramToggled()
    {
        if (showResourceHistogram) { CalculateHistogram(); await RenderChartAsync(); }
    }

    private async Task RenderChartAsync()
    {
        if (chartLines.Count == 0 || chartAllLabels.Count == 0) return;
        await Task.Delay(50); // 等待 DOM 渲染 canvas
        var chartData = new
        {
            labels = chartAllLabels,
            lines = chartLines.Select(l => new
            {
                name = l.Name,
                color = l.Color,
                points = l.Points.Select(p => p.Value).ToList()
            }).ToList()
        };
        try { await JS.InvokeVoidAsync("initResourceChart", chartData); chartError = null; }
        catch (Exception ex) { chartError = $"图表加载失败: {ex.Message}"; Console.WriteLine($"[Chart] Error: {ex.Message}"); }
    }

    private void CalculateHistogram()
    {
        chartLines = new();
        chartAllLabels = new();
        if (!tasks.Any() || !projectResources.Any()) return;

        var startDate = tasks.Min(t => t.PlanStartDate);
        var endDate = tasks.Max(t => t.PlanEndDate);
        if (endDate <= startDate) return;

        var buckets = new List<(DateTime Start, DateTime End, string Label)>();
        var current = startDate;
        while (current <= endDate)
        {
            DateTime bucketEnd;
            string label;
            switch (histogramGranularity)
            {
                case "week":
                    bucketEnd = current.AddDays(6);
                    label = current.AddDays(3).ToString("MM/dd");
                    break;
                case "quarter":
                    label = $"{current.Year}Q{(current.Month - 1) / 3 + 1}";
                    bucketEnd = new DateTime(current.Year, ((current.Month - 1) / 3) * 3 + 1, 1).AddMonths(3).AddDays(-1);
                    break;
                case "year":
                    label = current.ToString("yyyy");
                    bucketEnd = new DateTime(current.Year, 12, 31);
                    break;
                default: // month
                    label = current.ToString("yy/MM");
                    bucketEnd = new DateTime(current.Year, current.Month, DateTime.DaysInMonth(current.Year, current.Month));
                    break;
            }
            if (bucketEnd > endDate) bucketEnd = endDate;
            buckets.Add((current, bucketEnd, label));
            current = bucketEnd.AddDays(1);
        }

        chartAllLabels = buckets.Select(b => b.Label).ToList();

        var typesToCalc = resourceFilter switch
        {
            "labor" => new[] { (ResourceType.Labor, "人工", "#1890ff") },
            "material" => new[] { (ResourceType.Material, "材料", "#722ed1") },
            "equipment" => new[] { (ResourceType.Equipment, "设备", "#52c41a") },
            _ => new[] { (ResourceType.Labor, "人工", "#1890ff"), (ResourceType.Material, "材料", "#722ed1"), (ResourceType.Equipment, "设备", "#52c41a") }
        };

        var taskAssignMap = new Dictionary<int, List<(Resource Resource, decimal Qty)>>();
        foreach (var t in tasks)
        {
            var assigns = t.ResourceAssignments as List<ResourceAssignment> ?? new List<ResourceAssignment>();
            taskAssignMap[t.Id] = assigns.Where(a => a.Resource != null).Select(a => (a.Resource, a.Quantity)).ToList();
        }

        foreach (var (resType, name, color) in typesToCalc)
        {
            var points = new List<(int Bucket, double Value)>();
            for (int b = 0; b < buckets.Count; b++)
            {
                var bs = buckets[b].Start;
                var be = buckets[b].End;
                double total = 0;
                foreach (var t in tasks)
                {
                    if (!taskAssignMap.TryGetValue(t.Id, out var assigns)) continue;
                    var oStart = t.PlanStartDate > bs ? t.PlanStartDate : bs;
                    var oEnd = t.PlanEndDate < be ? t.PlanEndDate : be;
                    if (oStart > oEnd) continue;
                    foreach (var (r, qty) in assigns)
                        if (r.Type == resType) total += (double)qty;
                }
                points.Add((b, total));
            }
            chartLines.Add(new ChartLine(name, color, points));
        }
    }

    // 前后置任务关系相关
    private List<TaskItem> availTasks = new();
    private List<TaskRelation> editingPredecessors = new();
    private List<TaskRelation> editingSuccessors = new();
    private int selectedPredTaskId = 0;
    private RelationType selectedPredType = RelationType.FS;
    private int selectedPredLag = 0;
    private int selectedSuccTaskId = 0;
    private RelationType selectedSuccType = RelationType.FS;
    private int selectedSuccLag = 0;
    private int editingPredRelationIndex = -1;
    private int editingSuccRelationIndex = -1;

    // 列显示控制 — 使用可绑定的对象列表替代 Dictionary
    private class ColumnInfo
    {
        public string Key { get; set; } = "";
        public string Label { get; set; } = "";
        public bool Visible { get; set; } = true;
    }

    private bool showColumnPanel = false;
    private List<ColumnInfo> columnDefs = new()
    {
        new() { Key = "status", Label = "状态" },
        new() { Key = "code", Label = "任务代码" },
        new() { Key = "name", Label = "任务名称" },
        new() { Key = "person", Label = "负责人" },
        new() { Key = "planStart", Label = "计划开始" },
        new() { Key = "planEnd", Label = "计划完成" },
        new() { Key = "duration", Label = "工期" },
        new() { Key = "actStart", Label = "实际开始" },
        new() { Key = "actEnd", Label = "实际完成" },
        new() { Key = "actDur", Label = "实工" },
        new() { Key = "pred", Label = "前置任务" },
        new() { Key = "succ", Label = "后置任务" },
        new() { Key = "pct", Label = "完成率" },
        new() { Key = "float", Label = "总时差" },
        new() { Key = "freeFloat", Label = "自由时差" },
        new() { Key = "res", Label = "资源" },
    };
    private List<ColumnInfo> columnTemp = new(); // 临时编辑副本

    private bool GetColumnVisible(string key)
    {
        var col = columnDefs.FirstOrDefault(c => c.Key == key);
        return col?.Visible ?? true;
    }

    /// <summary>时差值 → 颜色样式</summary>
    private string GetFloatColorStyle(int? value)
    {
        if (value == null) return "";
        var v = Math.Abs(value.Value);
        if (v == 0) return "color:red;font-weight:bold";           // 关键路径
        if (v <= 100) return "color:inherit";                       // 正常
        if (v <= 200) return "color:#f0ad4e;font-weight:bold";      // 🟡 可疑
        if (v <= 365) return "color:#fd7e14;font-weight:bold";      // 🟠 警告
        return "color:#dc3545;font-weight:bold";                    // 🔴 严重
    }

    /// <summary>加载任务后刷新时差警告列表</summary>
    private void RefreshFloatWarnings()
    {
        taskFloatWarnings.Clear();
        foreach (var t in tasks)
        {
            if (t.TotalFloat.HasValue && Math.Abs(t.TotalFloat.Value) > 100)
                taskFloatWarnings.Add(($"{t.Name} (TF)", Math.Abs(t.TotalFloat.Value)));
            if (t.FreeFloat.HasValue && Math.Abs(t.FreeFloat.Value) > 100)
                taskFloatWarnings.Add(($"{t.Name} (FF)", Math.Abs(t.FreeFloat.Value)));
        }
    }

    private void ToggleColumnPanel()
    {
        showColumnPanel = !showColumnPanel;
        if (showColumnPanel)
        {
            // 深拷贝当前列可见状态到临时列表
            columnTemp = columnDefs.Select(c => new ColumnInfo { Key = c.Key, Label = c.Label, Visible = c.Visible }).ToList();
        }
    }

    private void ApplyColumnVisibility()
    {
        // 将临时状态写回正式列定义
        foreach (var ct in columnTemp)
        {
            var cd = columnDefs.FirstOrDefault(c => c.Key == ct.Key);
            if (cd != null) cd.Visible = ct.Visible;
        }
        showColumnPanel = false;
    }

    private void CancelColumnVisibility()
    {
        showColumnPanel = false;
    }

    /// <summary>列复选框变更处理 — 直接操作 List 对象属性，Blazor 能正确检测变更</summary>
    private void OnColumnCheckChange(int index, bool value)
    {
        if (index >= 0 && index < columnTemp.Count)
            columnTemp[index].Visible = value;
    }

    protected override async Task OnInitializedAsync()
    {
        projects = await ProjectService.GetAllProjectsAsync();
        loading = false;
        if (currentProjectId > 0)
        {
            await LoadTasks();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (ProjectId.HasValue)
        {
            currentProjectId = ProjectId.Value;
            await LoadTasks();
        }
    }

    private DotNetObjectReference<Gantt>? dotNetRef;
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try
        {
            if (firstRender)
            {
                dotNetRef = DotNetObjectReference.Create(this);
                await JS.InvokeVoidAsync("setGanttDotNet", dotNetRef);
            }
            await JS.InvokeVoidAsync("initGanttScroll");
            await JS.InvokeVoidAsync("initPanelResize");
        }
        catch (Exception) { /* 预渲染阶段 JS 不可用，忽略 */ }
    }
    public void Dispose() => dotNetRef?.Dispose();

    private async Task LoadTasks()
    {
        if (currentProjectId == 0) return;

        loading = true;
        tasks = await ProjectService.GetTasksByProjectIdAsync(currentProjectId);
        taskRelations = await ProjectService.GetRelationsByProjectIdAsync(currentProjectId);
        projectResources = await ResourceService.GetResourcesByProjectAsync(currentProjectId);
        if (tasks.Any())
        {
            // 加载后刷新 tasks，确保名称/工期/代码等字段是最新的
            // 注意：LoadTasks 不再重复计算 CPM（调用者应自行决定是否重算）
            var project = projects.FirstOrDefault(p => p.Id == currentProjectId);
            if (project != null)
            {
                // 时间标尺起点：项目计划开始 vs 最早的任务计划/实际开始
                var chartStart = project.PlanStartDate;
                if (tasks.Any())
                {
                    var minTaskDate = tasks.Min(t => t.PlanStartDate);
                    var minActualDate = tasks.Where(t => t.ActualStartDate.HasValue).Min(t => t.ActualStartDate.Value);
                    var minDates = new List<DateTime> { chartStart, minTaskDate };
                    if (tasks.Any(t => t.ActualStartDate.HasValue))
                        minDates.Add(minActualDate);
                    chartStart = minDates.Min();
                }
                projectStartDate = chartStart;
                // 终点：项目计划完成 vs 最晚任务计划/实际完成
                var chartEnd = project.PlanEndDate;
                if (tasks.Any())
                {
                    var maxTaskDate = tasks.Max(t => t.PlanEndDate);
                    var maxActualDate = tasks.Where(t => t.ActualEndDate.HasValue).Max(t => t.ActualEndDate.Value);
                    var maxDates = new List<DateTime> { chartEnd, maxTaskDate };
                    if (tasks.Any(t => t.ActualEndDate.HasValue))
                        maxDates.Add(maxActualDate);
                    chartEnd = maxDates.Max();
                }
                totalDays = Math.Max(90, (chartEnd - chartStart).Days + 30);
            }
        }
        RefreshFloatWarnings();
        CalculateHistogram();
        loading = false;
    }

    private void SelectTask(int taskId)
    {
        selectedTaskId = selectedTaskId == taskId ? null : taskId;
