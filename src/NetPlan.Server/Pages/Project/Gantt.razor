    /// <summary>
    /// 判断任务是否为父任务（有子任务）
    /// </summary>
    private bool IsParentTask(TaskItem task) =>
        tasks.Any(t => t.ParentTaskId == task.Id);

    /// <summary>
    /// 获取条形CSS类名，基于任务完成状态和里程碑标识
    /// </summary>
    private string GetBarClass(TaskItem task)
    {
        if (task.IsMilestone)
            return "bar-milestone bar-milestone-flag" + (task.IsCritical && showCriticalLine ? " bar-critical" : "");

        if (task.IsCritical && showCriticalLine)
            return "bar-critical";

        if (task.CompletionPercentage >= 100)
            return "bar-completed";

        if (task.CompletionPercentage > 0)
            return "bar-in-progress";

        return "bar-not-started";
    }

    /// <summary>
    /// 获取任务状态文字
    /// </summary>
    private string GetTaskStatusText(TaskItem task)
    {
        if (task.IsMilestone) return "里程碑";
        if (task.IsCritical) return "关键";
        if (task.CompletionPercentage >= 100) return "完成";
        if (task.CompletionPercentage > 0) return "进行";
        return "未开始";
    }

    /// <summary>
    /// 获取任务状态徽标HTML（左侧列表显示）
    /// </summary>
    private RenderFragment GetTaskStatusBadge(TaskItem task) => builder =>
    {
        string badgeClass;
        string badgeText;

        if (task.IsMilestone)
        {
            badgeClass = "milestone";
            badgeText = "M";
        }
        else if (task.IsCritical)
        {
            badgeClass = "critical";
            badgeText = "!";
        }
        else if (task.CompletionPercentage >= 100)
        {
            badgeClass = "completed";
            badgeText = "✓";
        }
        else if (task.CompletionPercentage > 0)
        {
            badgeClass = "in-progress";
            badgeText = "~";
        }
        else
        {
            badgeClass = "not-started";
            badgeText = "○";
        }

        builder.OpenElement(0, "span");
        builder.AddAttribute(1, "class", $"task-status-badge {badgeClass}");
        builder.AddAttribute(2, "title", GetTaskStatusText(task));
        builder.AddContent(3, badgeText);
        builder.CloseElement();
    };

