    [JSInvokable]
    public async Task MoveTaskDays(int taskId, int deltaDays)
    {
        if (deltaDays == 0) return;
        deltaDays = Math.Clamp(deltaDays, -3650, 3650);
        var allTasks = await ProjectService.GetTasksByProjectIdAsync(currentProjectId);
        var task = allTasks.FirstOrDefault(t => t.Id == taskId);
        if (task == null) return;
        
        var newStart = task.PlanStartDate.AddDays(deltaDays);
        task.PlanStartDate = newStart;
        task.PlanEndDate = newStart.AddDays(task.PlanDuration - 1);
        task.IsManualSchedule = true;
        await ProjectService.UpdateTaskAsync(task);

        // 更新所有关联关系的 Lag，使其与实际日期差保持一致
        var relations = await ProjectService.GetRelationsByProjectIdAsync(currentProjectId);
        await UpdateRelationLagsAsync(task, allTasks, relations);

        await ProjectService.CalculateScheduleAsync(currentProjectId);
        await LoadTasks();
        StateHasChanged();
    }

    /// <summary>
    /// 根据任务的新日期重新计算所有关联关系的 Lag，使关系定义与当前实际日期一致
    /// </summary>
    private async Task UpdateRelationLagsAsync(TaskItem movedTask, List<TaskItem> allTasks, List<TaskRelation> relations)
    {
        var taskDict = allTasks.ToDictionary(t => t.Id);

        // 作为紧后任务：更新前驱关系的 Lag（前驱任务→当前任务）
        foreach (var rel in relations.Where(r => r.SuccessorTaskId == movedTask.Id))
        {
            if (!taskDict.TryGetValue(rel.PredecessorTaskId, out var pred)) continue;
            rel.Lag = ComputeLag(rel.Type, pred, movedTask);
        }

        // 作为紧前任务：更新后继关系的 Lag（当前任务→后继任务）
        foreach (var rel in relations.Where(r => r.PredecessorTaskId == movedTask.Id))
        {
            if (!taskDict.TryGetValue(rel.SuccessorTaskId, out var succ)) continue;
            rel.Lag = ComputeLag(rel.Type, movedTask, succ);
        }

        await ProjectService.SaveChangesAsync();
    }

    /// <summary>根据关系类型和新日期反算 Lag</summary>
    private static int ComputeLag(RelationType type, TaskItem pred, TaskItem succ)
    {
        return type switch
        {
            RelationType.FS => (succ.PlanStartDate - pred.PlanEndDate).Days - 1,
            RelationType.SS => (succ.PlanStartDate - pred.PlanStartDate).Days,
            RelationType.FF => (succ.PlanEndDate - pred.PlanEndDate).Days,
            RelationType.SF => (succ.PlanEndDate - pred.PlanStartDate).Days + 1,
            _ => 0
        };
    }

