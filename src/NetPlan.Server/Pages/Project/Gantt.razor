    /// <summary>
    /// 自动生成下一个任务代码（T1, T2, ...）
    /// </summary>
    private async Task<string> GenerateNextTaskCode()
    {
        var existing = await ProjectService.GetTasksByProjectIdAsync(currentProjectId);
        int maxNum = 0;
        foreach (var t in existing)
        {
            if (t.Code.StartsWith("T") && int.TryParse(t.Code[1..], out var n))
                maxNum = Math.Max(maxNum, n);
        }
        return $"T{maxNum + 1}";
    }

    /// <summary>
    /// 获取任务的资源摘要（显示在列表列中）
    /// </summary>
    private string GetTaskResourceSummary(TaskItem task)
    {
        if (task.ResourceAssignments == null || task.ResourceAssignments.Count == 0)
            return "";
        var parts = task.ResourceAssignments
            .Where(a => a.Resource != null)
            .Select(a => $"{a.Resource.Name}:{a.Quantity}{a.Resource.Unit}");
        return string.Join(", ", parts);
    }

    /// <summary>
    /// 获取前置任务摘要（显示在列表列中）
    /// </summary>
    private string GetPredecessorSummary(TaskItem task)
    {
        if (task.Predecessors == null || task.Predecessors.Count == 0)
            return "";
        var parts = task.Predecessors
            .Where(r => r.PredecessorTask != null)
            .Select(r => r.Lag == 0
                ? r.PredecessorTask.Code
                : $"{r.PredecessorTask.Code}{(r.Lag>0?"+":"")}{r.Lag}");
        return string.Join(", ", parts);
    }

    private string GetSuccessorSummary(TaskItem task)
    {
        if (task.Successors == null || task.Successors.Count == 0)
            return "";
        var parts = task.Successors
            .Where(r => r.SuccessorTask != null)
            .Select(r => r.Lag == 0
                ? r.SuccessorTask.Code
                : $"{r.SuccessorTask.Code}{(r.Lag>0?"+":"")}{r.Lag}");
        return string.Join(", ", parts);
    }

