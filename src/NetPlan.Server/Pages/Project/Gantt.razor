    private bool GetColumnVisible(string key)
    {
        var col = columnDefs.FirstOrDefault(c => c.Key == key);
        return col?.Visible ?? true;
    }

    /// <summary>时差值 → 颜色样式</summary>
    private string GetFloatColorStyle(int? value)
    {
        if (value == null) return "";
        var v = Math.Abs(value.Value);
        if (v == 0) return "color:red;font-weight:bold";           // 关键路径
        if (v <= 100) return "color:inherit";                       // 正常
        if (v <= 200) return "color:#f0ad4e;font-weight:bold";      // 🟡 可疑
        if (v <= 365) return "color:#fd7e14;font-weight:bold";      // 🟠 警告
        return "color:#dc3545;font-weight:bold";                    // 🔴 严重
    }

    /// <summary>加载任务后刷新时差警告列表</summary>
    private void RefreshFloatWarnings()
    {
        taskFloatWarnings.Clear();
        foreach (var t in tasks)
        {
            if (t.TotalFloat.HasValue && Math.Abs(t.TotalFloat.Value) > 100)
                taskFloatWarnings.Add(($"{t.Name} (TF)", Math.Abs(t.TotalFloat.Value)));
            if (t.FreeFloat.HasValue && Math.Abs(t.FreeFloat.Value) > 100)
                taskFloatWarnings.Add(($"{t.Name} (FF)", Math.Abs(t.FreeFloat.Value)));
        }
    }

    private void ToggleColumnPanel()
    {
        showColumnPanel = !showColumnPanel;
        if (showColumnPanel)
        {
            // 深拷贝当前列可见状态到临时列表
            columnTemp = columnDefs.Select(c => new ColumnInfo { Key = c.Key, Label = c.Label, Visible = c.Visible }).ToList();
        }
    }

    private void ApplyColumnVisibility()
    {
        // 将临时状态写回正式列定义
        foreach (var ct in columnTemp)
        {
            var cd = columnDefs.FirstOrDefault(c => c.Key == ct.Key);
            if (cd != null) cd.Visible = ct.Visible;
        }
        showColumnPanel = false;
        _ = SaveGanttSettings();
    }

    private void CancelColumnVisibility()
    {
        showColumnPanel = false;
    }

    /// <summary>列复选框变更处理 — 直接操作 List 对象属性，Blazor 能正确检测变更</summary>
    private void OnColumnCheckChange(int index, bool value)
    {
        if (index >= 0 && index < columnTemp.Count)
            columnTemp[index].Visible = value;
    }

    // ==================== 甘特图设置持久化 ====================
    private class GanttSettings
    {
        public bool ShowTodayLine { get; set; }
        public bool ShowRelationLine { get; set; }
        public bool ShowCriticalLine { get; set; } = true;
        public Dictionary<string, bool> ColumnVisibility { get; set; } = new();
    }

    private const string GANTT_SETTINGS_KEY = "gantt_settings";

    /// <summary>从 localStorage 恢复甘特图显示设置</summary>
    private async Task RestoreGanttSettings()
    {
        try
        {
            var json = await JS.InvokeAsync<string>("localStorage.getItem", GANTT_SETTINGS_KEY);
            if (!string.IsNullOrEmpty(json))
            {
                var settings = System.Text.Json.JsonSerializer.Deserialize<GanttSettings>(json);
                if (settings != null)
                {
                    showTodayLine = settings.ShowTodayLine;
                    showRelationLine = settings.ShowRelationLine;
                    showCriticalLine = settings.ShowCriticalLine;
                    if (settings.ColumnVisibility != null)
                    {
                        foreach (var kv in settings.ColumnVisibility)
                        {
                            var col = columnDefs.FirstOrDefault(c => c.Key == kv.Key);
                            if (col != null) col.Visible = kv.Value;
                        }
                    }
                }
            }
        }
        catch { /* JS 不可用时忽略 */ }
    }

    /// <summary>将甘特图显示设置存入 localStorage</summary>
    private async Task SaveGanttSettings()
    {
        try
        {
            var settings = new GanttSettings
            {
                ShowTodayLine = showTodayLine,
                ShowRelationLine = showRelationLine,
                ShowCriticalLine = showCriticalLine,
                ColumnVisibility = columnDefs.ToDictionary(c => c.Key, c => c.Visible)
            };
            var json = System.Text.Json.JsonSerializer.Serialize(settings);
            await JS.InvokeVoidAsync("localStorage.setItem", GANTT_SETTINGS_KEY, json);
        }
        catch { /* JS 不可用时忽略 */ }
    }

