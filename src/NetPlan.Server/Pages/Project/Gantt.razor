            ProjectId = task.ProjectId,
            Code = task.Code,
            Name = task.Name,
            SortOrder = task.SortOrder,
            ResponsiblePerson = task.ResponsiblePerson,
            CompletionPercentage = task.CompletionPercentage,
            IsMilestone = task.IsMilestone,
            IsManualSchedule = task.IsManualSchedule,
            Notes = task.Notes,
            PlanStartDate = task.PlanStartDate,
            PlanEndDate = task.PlanEndDate,
            PlanDuration = task.PlanDuration,
            ActualStartDate = task.ActualStartDate,
            ActualEndDate = task.ActualEndDate,
            EarlyStart = task.EarlyStart,
            EarlyFinish = task.EarlyFinish,
            LateStart = task.LateStart,
            LateFinish = task.LateFinish,
            TotalFloat = task.TotalFloat,
            IsCritical = task.IsCritical,
            CreatedAt = task.CreatedAt
        };
        taskModalVisible = true;
        selectedResourceId = 0;
        assignQuantity = 1;

        // 检查草稿
        if (task.Id > 0)
        {
            var draftJson = await JS.InvokeAsync<string>("loadDraft", $"task_{task.Id}");
            if (!string.IsNullOrEmpty(draftJson))
            {
                try { editingTask = System.Text.Json.JsonSerializer.Deserialize<TaskItem>(draftJson) ?? editingTask; }
                catch { }
            }
        }
        
        // 加载资源分配和项目资源列表
        projectResources = await ResourceService.GetResourcesByProjectAsync(currentProjectId);
        taskAssignments = await ResourceService.GetAssignmentsByTaskIdAsync(task.Id);

        // 加载前后置任务关系
        var fullTask = await ProjectService.GetTaskByIdAsync(task.Id);
        editingPredecessors = fullTask?.Predecessors?.ToList() ?? new();
        editingSuccessors = fullTask?.Successors?.ToList() ?? new();
        availTasks = tasks.Where(t => t.Id != task.Id).ToList();
        selectedPredTaskId = 0; selectedPredLag = 0; selectedPredType = RelationType.FS;
        selectedSuccTaskId = 0; selectedSuccLag = 0; selectedSuccType = RelationType.FS;
        editingPredRelationIndex = -1;
        editingSuccRelationIndex = -1;
    }

    private async Task SaveDraft()
    {
        if (editingTask == null || editingTask.Id <= 0) return;
        var json = System.Text.Json.JsonSerializer.Serialize(editingTask);
        await JS.InvokeVoidAsync("saveDraft", $"task_{editingTask.Id}", json);
    }

    private async Task HandleTaskOk()
    {
        if (editingTask == null) return;

        // 防日期清除 + 强制联动
        if (editingTask.PlanStartDate.Year < 2000)
            editingTask.PlanStartDate = DateTime.Today;
        editingTask.PlanDuration = Math.Max(1, editingTask.PlanDuration);
        editingTask.PlanEndDate = editingTask.PlanStartDate.AddDays(editingTask.PlanDuration - 1);

        // 自动计算实际工期
        if (editingTask.ActualStartDate.HasValue && editingTask.ActualEndDate.HasValue)
            editingTask.ActualDuration = Math.Max(1, (editingTask.ActualEndDate.Value - editingTask.ActualStartDate.Value).Days + 1);

        if (editingTask.Id > 0)
        {
            await ProjectService.UpdateTaskAsync(editingTask);
        }
        else
        {
            await ProjectService.CreateTaskAsync(editingTask);
        }

        // 同步前后置任务关系：先删后建（用全新对象避免EF跟踪冲突）
        if (editingTask.Id > 0)
        {
            var existingRels = await ProjectService.GetRelationsByTaskIdAsync(editingTask.Id);
            foreach (var r in existingRels)
                await ProjectService.DeleteRelationAsync(r.Id);

            foreach (var rel in editingPredecessors)
            {
                await ProjectService.CreateRelationAsync(new TaskRelation
                {
                    ProjectId = currentProjectId,
                    PredecessorTaskId = rel.PredecessorTaskId,
                    SuccessorTaskId = editingTask.Id,
                    Type = rel.Type,
                    Lag = rel.Lag
                });
            }
            foreach (var rel in editingSuccessors)
            {
                await ProjectService.CreateRelationAsync(new TaskRelation
                {
                    ProjectId = currentProjectId,
                    PredecessorTaskId = editingTask.Id,
                    SuccessorTaskId = rel.SuccessorTaskId,
                    Type = rel.Type,
                    Lag = rel.Lag
                });
            }
        }

        taskModalVisible = false;
        await JS.InvokeVoidAsync("clearDraft", $"task_{editingTask.Id}");
        // 重算调度（更新ES/EF/LS/LF/关键路径），然后刷新数据和甘特图
        await ProjectService.CalculateScheduleAsync(currentProjectId);
        await LoadTasks();
    }

    private async Task AddResourceAssignment()
    {
        if (editingTask == null || editingTask.Id == 0 || selectedResourceId == 0) return;

        // 先保存任务（如果是新建的还没有Id）
        if (editingTask.Id == 0)
        {
            editingTask.PlanEndDate = editingTask.PlanStartDate.AddDays(editingTask.PlanDuration - 1);
            await ProjectService.CreateTaskAsync(editingTask);
            // 修正本地引用
        }

        // 检查是否已存在
        var existing = taskAssignments.FirstOrDefault(a => a.ResourceId == selectedResourceId);
        if (existing != null)
        {
            existing.Quantity += assignQuantity;
            await ResourceService.UpdateAssignmentAsync(existing);
        }
        else
        {
            var assignment = new ResourceAssignment
            {
                TaskId = editingTask.Id,
                ResourceId = selectedResourceId,
                Quantity = assignQuantity > 0 ? assignQuantity : 1
            };
            await ResourceService.CreateAssignmentAsync(assignment);
        }

        // 刷新列表
        taskAssignments = await ResourceService.GetAssignmentsByTaskIdAsync(editingTask.Id);
        selectedResourceId = 0;
        assignQuantity = 1;
    }

    // ========== 日期联动计算 ==========
    private void OnPlanDatesChanged()
    {
        if (editingTask == null) return;
        // 防止日期清除为 0001/01/01
        if (editingTask.PlanStartDate.Year < 2000)
            editingTask.PlanStartDate = DateTime.Today;
        if (editingTask.PlanEndDate.Year < 2000)
            editingTask.PlanEndDate = editingTask.PlanStartDate.AddDays(Math.Max(1, editingTask.PlanDuration) - 1);
        // PlanEndDate 始终跟随 PlanStartDate + PlanDuration
        editingTask.PlanEndDate = editingTask.PlanStartDate.AddDays(Math.Max(1, editingTask.PlanDuration) - 1);
    }
    private void OnPlanEndDateChanged()
    {
        if (editingTask == null) return;
        if (editingTask.PlanEndDate.Year < 2000)
            editingTask.PlanEndDate = editingTask.PlanStartDate.AddDays(Math.Max(1, editingTask.PlanDuration) - 1);
        if (editingTask.PlanEndDate < editingTask.PlanStartDate)
            editingTask.PlanEndDate = editingTask.PlanStartDate.AddDays(Math.Max(1, editingTask.PlanDuration) - 1);
        editingTask.PlanDuration = Math.Max(1, (editingTask.PlanEndDate - editingTask.PlanStartDate).Days + 1);
    }
    private void OnPlanDurationChanged()
    {
        if (editingTask == null) return;
        editingTask.PlanDuration = Math.Max(1, editingTask.PlanDuration);
        editingTask.PlanEndDate = editingTask.PlanStartDate.AddDays(editingTask.PlanDuration - 1);
    }
    private void OnActualDatesChanged()
    {
        if (editingTask == null) return;
        // 防倒置：实际完成 < 实际开始 → 自动纠正
        if (editingTask.ActualEndDate.HasValue && editingTask.ActualStartDate.HasValue
            && editingTask.ActualEndDate.Value < editingTask.ActualStartDate.Value)
        {
            editingTask.ActualEndDate = editingTask.ActualStartDate.Value;
        }
        // 自动计算实际工期
        if (editingTask.ActualStartDate.HasValue && editingTask.ActualEndDate.HasValue)
            editingTask.ActualDuration = Math.Max(1, (editingTask.ActualEndDate.Value - editingTask.ActualStartDate.Value).Days + 1);
        else
            editingTask.ActualDuration = null;
    }

