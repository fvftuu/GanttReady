    // ========== 任务上下移动 ==========
    private async Task MoveTaskUp()
    {
        if (selectedTaskId == null) return;
        var current = tasks.FirstOrDefault(t => t.Id == selectedTaskId.Value);
        if (current == null) return;
        var above = tasks.Where(t => t.SortOrder < current.SortOrder).OrderByDescending(t => t.SortOrder).FirstOrDefault();
        if (above == null) return;
        (current.SortOrder, above.SortOrder) = (above.SortOrder, current.SortOrder);
        await ProjectService.UpdateTaskAsync(current);
        await ProjectService.UpdateTaskAsync(above);
        await LoadTasks();
        await JS.InvokeVoidAsync("syncGanttRowHeightsDeferred");
    }

    private async Task MoveTaskDown()
    {
        if (selectedTaskId == null) return;
        var current = tasks.FirstOrDefault(t => t.Id == selectedTaskId.Value);
        if (current == null) return;
        var below = tasks.Where(t => t.SortOrder > current.SortOrder).OrderBy(t => t.SortOrder).FirstOrDefault();
        if (below == null) return;
        (current.SortOrder, below.SortOrder) = (below.SortOrder, current.SortOrder);
        await ProjectService.UpdateTaskAsync(current);
        await ProjectService.UpdateTaskAsync(below);
        await LoadTasks();
        await JS.InvokeVoidAsync("syncGanttRowHeightsDeferred");
    }

    // 获取日期所在月的第几周
    private int GetWeekOfMonth(DateTime date)
    {
        var firstDayOfMonth = new DateTime(date.Year, date.Month, 1);
        var dayOfWeek = (int)firstDayOfMonth.DayOfWeek;
        dayOfWeek = dayOfWeek == 0 ? 7 : dayOfWeek; // 周一作为一周开始
        return (date.Day + dayOfWeek - 2) / 7 + 1;
    }

    // 生成中文周范围如"1-7"
    private string GetChinesWeekRange(int startDay, int endDay)
    {
        return $"{startDay}-{endDay}";
    }

