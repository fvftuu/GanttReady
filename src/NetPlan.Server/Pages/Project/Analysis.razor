@page "/analysis"
@page "/project/{ProjectId:int}/analysis"
@inject IAnalysisService AnalysisService
@inject IProjectService ProjectService
@inject IResourceService ResourceService
@inject IAiService AiService
@inject IJSRuntime JS

<PageTitle>计划分析 - NetPlan</PageTitle>

<div class="page-header">
    <div class="header-left">
        <select class="form-control" @bind="selectedScope" @bind:after="OnScopeChanged" style="width:220px;">
            <option value="all">🌐 所有项目（共享资源）</option>
            @foreach (var project in projects)
            {
                <option value="@("p-"+project.Id)">📁 @project.Name</option>
            }
        </select>
        <span class="page-title">计划分析仪表板</span>
        <button class="btn btn-default btn-sm" style="margin-left:12px;" @onclick="ShowAiSettings">🤖 AI 设置</button>
            <div class="scale-switch" style="margin-left:8px;">
                @foreach (var role in _roles)
                {
                    <button class="scale-btn @(_currentRole == role.Value ? "active" : "")"
                            @onclick="() => SwitchRole(role.Value)" title="@role.Desc">
                        @role.Icon @role.Label
                    </button>
                }
            </div>
    </div>
    <div class="header-right">
        <button class="btn btn-default btn-sm" onclick="window.print()">🖨 打印</button>
    </div>
</div>

<div class="page-body">
    <div class="page-main" style="padding:20px;">
        @if (isLoading)
        {
            <Skeleton Type="text" Count="8" />
        }
        else if (isAllProjects)
        {
            <div class="section">
                <h3>🌐 所有项目分析</h3>
                <p style="color:var(--text-secondary);">请选择具体项目后使用 AI 分析。</p>
            </div>
        }
        else if (analysisResult != null)
        {
            <div class="section">
                @{
                    var currentRoleInfo = _roles.FirstOrDefault(r => r.Value == _currentRole);
                    var roleIcon = currentRoleInfo.Icon;
                    var roleLabel = currentRoleInfo.Label;
                }
                <h3>🤖 @roleIcon @roleLabel 视角 · AI 分析报告</h3>
                @if (_aiLoading)
                {
                    <div class="loading">⏳ AI 正在分析项目数据...</div>
                }
                else if (_aiReports.TryGetValue(_currentReportKey, out var report))
                {
                    <div style="background:#fafafa;border:1px solid var(--border);border-radius:var(--radius-sm);padding:16px;line-height:1.8;white-space:pre-wrap;font-size:13px;">@report</div>
                }
                else
                {
                    <div style="color:var(--text-secondary);padding:12px 0;">点击上方角色按钮生成对应视角的 AI 分析报告。</div>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <p>无法加载分析数据。</p>
                <button class="btn btn-primary" @onclick="LoadAnalysis">重试</button>
            </div>
        }
    </div>
</div>

@* ========== AI 服务设置弹窗 ========== *@
@if (_showAiSettings)
{
    <div class="modal-overlay">
        <div class="modal-content" style="width:720px;height:620px;display:flex;flex-direction:column;">
            <h3>🤖 AI 服务设置</h3>
            <div style="display:flex;flex:1;gap:0;overflow:hidden;margin-top:10px;">
                <div style="width:190px;border-right:1px solid var(--border);padding-right:10px;overflow-y:auto;display:flex;flex-direction:column;flex-shrink:0;">
                    @for (int ci = 0; ci < _aiConnections.Count; ci++)
                    {
                        var c = _aiConnections[ci]; var idx = ci;
                        <div @onclick="() => _aiSelectedIdx = idx"
                             style="padding:7px 10px;border-radius:6px;cursor:pointer;margin-bottom:4px;display:flex;align-items:center;gap:6px;font-size:13px;
                                    @(idx == _aiSelectedIdx ? "background:#e6f7ff;border:1px solid #91d5ff;" : "background:transparent;border:1px solid transparent;")">
                            <span style="font-size:16px;line-height:1;">@GetProviderLogo(c.Name)</span>
                            <span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@c.Name</span>
                            @if (c.IsActive) { <span style="color:#faad14;font-size:11px;margin-left:2px;">⭐</span> }
                            @if (c.Status == "ok") { <span style="color:#52c41a;font-size:10px;">🟢</span> }
                            else if (c.Status == "fail") { <span style="color:#ff4d4f;font-size:10px;">🔴</span> }
                        </div>
                    }
                    <button class="btn btn-default btn-sm" @onclick="AddAiConnection" style="margin-top:8px;">＋ 添加连接</button>
                </div>
                <div style="flex:1;padding-left:16px;overflow-y:auto;">
                    @{ var selectedConn = _aiSelectedIdx >= 0 && _aiSelectedIdx < _aiConnections.Count ? _aiConnections[_aiSelectedIdx] : null; }
                    @if (selectedConn != null)
                    {
                        var conn = selectedConn; var idx = _aiSelectedIdx;
                        <div style="display:flex;justify-content:flex-end;gap:6px;margin-bottom:8px;">
                            <button class="btn btn-default btn-sm" @onclick="() => TestAiConnection(idx)">@(conn.Testing ? "⏳" : "🔌") 检测连接</button>
                            @if (conn.Status == "ok") { <span style="color:#52c41a;">🟢 连接正常</span> }
                            else if (conn.Status == "fail") { <span style="color:#ff4d4f;">🔴 @conn.StatusMessage</span> }
                            <div style="flex:1;"></div>
                            <button class="btn btn-default btn-sm" @onclick="() => SelectAiConnection(idx)">⭐ 设为当前</button>
                            @if (_aiConnections.Count > 1) { <button class="btn btn-danger btn-sm" @onclick="() => RemoveAiConnection(idx)">✕ 删除</button> }
                        </div>
                        <div class="form-group"><label>名称</label><input type="text" class="form-control" @bind="conn.Name" placeholder="连接名称" /></div>
                        <div class="form-group"><label>API 地址</label><input type="text" class="form-control" @bind="conn.Endpoint" placeholder="https://api.deepseek.com/v1" /></div>
                        <div class="form-group"><label>API 格式</label><select class="form-control" @bind="conn.ApiFormat"><option value="openai">OpenAI 格式</option><option value="anthropic">Anthropic 格式</option></select></div>
                        <div class="form-group">
                            <label>模型</label>
                            <input type="text" class="form-control" @bind="conn.Model" placeholder="deepseek-v4-flash" />
                        </div>
                        <div class="form-group"><label>API Key</label><input type="text" class="form-control" @bind="conn.ApiKey" placeholder="sk-..." style="font-family:monospace;" /></div>
                    }
                    else { <div style="color:var(--text-secondary);padding:40px 0;text-align:center;">选择一个连接或添加新连接</div> }
                </div>
            </div>
            <div class="dialog-actions" style="margin-top:12px;padding-top:12px;border-top:1px solid var(--border);">
                <button class="btn btn-default" @onclick="() => _showAiSettings = false">取消</button>
                <button class="btn btn-primary" @onclick="SaveAiSettings">保存</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int? ProjectId { get; set; }

    // AI 增强数据
    private string? _currentProjectName;
    private EarnedValueResult? _earnedValueResult;
    private StageCompletionResult? _stageCompletionResult;
    private ResourceSummary? _resourceSummary;

    // 角色选择
    private string _currentRole = "manager";
    private List<(string Value, string Label, string Icon, string Desc)> _roles = new()
    {
        ("operator",  "操作人员", "👷", "我接下来做什么"),
        ("manager",   "项目经理", "📋", "项目在控制中吗"),
        ("investor",  "监理业主", "📊", "钱和时间花得值吗"),
        ("executive", "公司高层", "🏢", "哪个项目要我拍板"),
    };

    private Dictionary<string, string> _aiReports = new();
    private bool _aiLoading = false;
    private string _aiLoadingTab = "";
    private bool _showAiSettings = false;
    private int _aiSelectedIdx = 0;
    private List<AiConnection> _aiConnections = new();

    private string _currentReportKey => analysisResult != null ? $"analysis_{selectedProjectId}_{_currentRole}" : "";

    private async Task SwitchRole(string role)
    {
        if (_currentRole == role) return;
        _currentRole = role;
        await JS.InvokeVoidAsync("localStorage.setItem", "ai_role", role);
        if (analysisResult != null)
        {
            var key = _currentReportKey;
            if (!_aiReports.ContainsKey(key))
                await GenerateAiReportForTab(key);
        }
    }

    private string GetProviderLogo(string name) => name.ToLower() switch
    {
        "deepseek" => "🧊",
        "moonshot" => "🌙",
        "qwen" => "🐉",
        "zhipu" => "🧠",
        "minimax" => "🎯",
        "volcengine" => "🌋",
        "youdao" => "📖",
        "qianfan" => "☁️",
        "stepfun" => "⚡",
        "xiaomi" => "📱",
        "ollama" => "🦙",
        "openai" => "🟢",
        "anthropic" => "🏔️",
        "gemini" => "♊",
        "github-copilot" => "🐙",
        "openrouter" => "🌐",
        _ => "🔌"
    };

    private void InitDefaultConnections()
    {
        if (_aiConnections.Count > 0) return;
        _aiConnections = new()
        {
            new() { Name = "deepseek", Endpoint = "https://api.deepseek.com/v1", ApiFormat = "openai", Model = "deepseek-v4-flash", IsActive = true, Models = new() { "deepseek-v4-flash", "deepseek-v4-pro", "deepseek-reasoner" } },
            new() { Name = "moonshot", Endpoint = "https://api.moonshot.cn/v1", ApiFormat = "openai", Model = "kimi-k2.6", Models = new() { "kimi-k2.6", "kimi-k2.5" } },
            new() { Name = "qwen", Endpoint = "https://dashscope.aliyuncs.com/compatible-mode/v1", ApiFormat = "openai", Model = "qwen3.6-plus", Models = new() { "qwen3.6-plus", "qwen3.5-plus", "qwen3-coder-plus" } },
            new() { Name = "zhipu", Endpoint = "https://open.bigmodel.cn/api/paas/v4", ApiFormat = "openai", Model = "glm-5", Models = new() { "glm-5", "glm-4.7", "glm-4.7-flash", "GLM-4.7-Flash" } },
            new() { Name = "minimax", Endpoint = "https://api.minimaxi.com/v1", ApiFormat = "openai", Model = "MiniMax-M2.7", Models = new() { "MiniMax-M2.7", "MiniMax-M2.5" } },
            new() { Name = "volcengine", Endpoint = "https://ark.cn-beijing.volces.com/api/v3", ApiFormat = "openai", Model = "doubao-seed-2-0-pro-260215", Models = new() { "doubao-seed-2-0-pro-260215", "doubao-seed-2-0-lite-260215", "doubao-seed-2-0-mini-260215" } },
            new() { Name = "youdao", Endpoint = "https://openapi.youdao.com/llmgateway/api/v1/chat/completions", ApiFormat = "openai", Model = "deepseek-chat", Models = new() { "deepseek-chat", "deepseek-reasoner" } },
            new() { Name = "qianfan", Endpoint = "https://qianfan.baidubce.com/v2", ApiFormat = "openai", Model = "deepseek-v3.2", Models = new() { "deepseek-v3.2", "deepseek-r1", "ernie-4.5-8k" } },
            new() { Name = "stepfun", Endpoint = "https://api.stepfun.com/v1", ApiFormat = "openai", Model = "step-3.5-flash", Models = new() { "step-3.5-flash" } },
            new() { Name = "xiaomi", Endpoint = "https://api.xiaomimimo.com/v1", ApiFormat = "openai", Model = "mimo-v2.5-pro", Models = new() { "mimo-v2.5-pro", "mimo-v2.5", "mimo-v2-pro", "mimo-v2-flash" } },
            new() { Name = "ollama", Endpoint = "http://localhost:11434/v1", ApiFormat = "openai", Model = "llama3", Models = new() { "qwen3-coder-next", "glm-4.7-flash" } },
            new() { Name = "openai", Endpoint = "https://api.openai.com/v1", ApiFormat = "openai", Model = "gpt-5.4", Models = new() { "gpt-5.4", "gpt-5.2", "gpt-5.3-codex" } },
            new() { Name = "anthropic", Endpoint = "https://api.anthropic.com", ApiFormat = "anthropic", Model = "claude-sonnet-4-5-20250929", Models = new() { "claude-sonnet-4-5-20250929", "claude-opus-4-6" } },
            new() { Name = "gemini", Endpoint = "https://generativelanguage.googleapis.com/v1beta", ApiFormat = "openai", Model = "gemini-3-pro-preview", Models = new() { "gemini-3-pro-preview", "gemini-3-flash-preview" } },
            new() { Name = "github-copilot", Endpoint = "https://api.individual.githubcopilot.com", ApiFormat = "openai", Model = "gpt-5-mini", Models = new() { "gpt-5-mini", "claude-haiku-4.5", "gpt-4.1", "gpt-4o" } },
            new() { Name = "openrouter", Endpoint = "https://openrouter.ai/api/v1", ApiFormat = "openai", Model = "anthropic/claude-sonnet-4.5", Models = new() { "anthropic/claude-sonnet-4.5", "openai/gpt-5.2-codex", "google/gemini-3-pro-preview" } },
        };
    }

    private class AiConnection
    {
        public string Name { get; set; } = "";
        public string Endpoint { get; set; } = "https://api.deepseek.com/v1";
        public string ApiKey { get; set; } = "";
        public string Model { get; set; } = "deepseek-v4-flash";
        public string ApiFormat { get; set; } = "openai";
        public List<string> Models { get; set; } = new();
        public bool IsActive { get; set; } = false;
        public bool Testing { get; set; } = false;
        public string Status { get; set; } = "";
        public string StatusMessage { get; set; } = "";
    }

    // ===== AI 设置 =====
    private async Task LoadAiSettings()
    {
        var version = await JS.InvokeAsync<string>("localStorage.getItem", "ai_connections_v");
        if (version != "2")
        {
            await JS.InvokeVoidAsync("localStorage.removeItem", "ai_connections");
            await JS.InvokeVoidAsync("localStorage.setItem", "ai_connections_v", "2");
            InitDefaultConnections();
            return;
        }
        try
        {
            var json = await JS.InvokeAsync<string>("localStorage.getItem", "ai_connections");
            if (!string.IsNullOrEmpty(json))
            {
                var list = System.Text.Json.JsonSerializer.Deserialize<List<AiConnection>>(json);
                if (list != null && list.Count > 0)
                {
                    _aiConnections = list;
                    return;
                }
            }
        }
        catch { }
        InitDefaultConnections();
    }

    private async Task SaveAiSettings()
    {
        var json = System.Text.Json.JsonSerializer.Serialize(_aiConnections);
        await JS.InvokeVoidAsync("localStorage.setItem", "ai_connections", json);
        _showAiSettings = false;
    }

    private void ShowAiSettings()
    {
        _showAiSettings = true;
        InitDefaultConnections();
    }
    private void AddAiConnection() => _aiConnections.Add(new AiConnection { Name = "新连接", Endpoint = "https://api.deepseek.com/v1", Model = "deepseek-v4-flash", ApiFormat = "openai" });
    private void RemoveAiConnection(int idx) { if (idx >= 0 && idx < _aiConnections.Count) _aiConnections.RemoveAt(idx); }
    private void SelectAiConnection(int idx) { foreach (var c in _aiConnections) c.IsActive = false; if (idx >= 0 && idx < _aiConnections.Count) _aiConnections[idx].IsActive = true; }

    private async Task TestAiConnection(int idx)
    {
        if (idx < 0 || idx >= _aiConnections.Count) return;
        var conn = _aiConnections[idx];
        conn.Testing = true; conn.Status = "testing"; conn.StatusMessage = ""; StateHasChanged();
        try
        {
            using var http = new HttpClient();
            http.Timeout = TimeSpan.FromSeconds(10);
            HttpRequestMessage request;
            if ((conn.ApiFormat ?? "openai").ToLower() == "anthropic")
            {
                request = new HttpRequestMessage(HttpMethod.Post, $"{conn.Endpoint.TrimEnd('/')}/messages");
                request.Content = new StringContent("{\"model\":\"" + conn.Model + "\",\"messages\":[{\"role\":\"user\",\"content\":\"ping\"}],\"max_tokens\":1}", System.Text.Encoding.UTF8, "application/json");
                if (!string.IsNullOrEmpty(conn.ApiKey)) request.Headers.Add("x-api-key", conn.ApiKey);
                request.Headers.Add("anthropic-version", "2023-06-01");
            }
            else
            {
                request = new HttpRequestMessage(HttpMethod.Post, $"{conn.Endpoint.TrimEnd('/')}/chat/completions");
                request.Content = new StringContent("{\"model\":\"" + conn.Model + "\",\"messages\":[{\"role\":\"user\",\"content\":\"ping\"}],\"max_tokens\":1}", System.Text.Encoding.UTF8, "application/json");
                if (!string.IsNullOrEmpty(conn.ApiKey)) request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", conn.ApiKey);
            }
            var response = await http.SendAsync(request);
            conn.Status = response.IsSuccessStatusCode ? "ok" : "fail";
            conn.StatusMessage = response.IsSuccessStatusCode ? "" : $"HTTP {(int)response.StatusCode}";
        }
        catch (Exception ex) { conn.Status = "fail"; conn.StatusMessage = ex.Message; }
        conn.Testing = false; StateHasChanged();
    }

    private AiOptions? BuildAiOptions()
    {
        var conn = GetActiveConnection();
        if (conn == null || string.IsNullOrEmpty(conn.Endpoint)) return null;
        return new AiOptions
        {
            Endpoint = conn.Endpoint,
            ApiKey = conn.ApiKey,
            Model = string.IsNullOrEmpty(conn.Model) ? "deepseek-v4-flash" : conn.Model,
            ApiFormat = string.IsNullOrEmpty(conn.ApiFormat) ? "openai" : conn.ApiFormat
        };
    }

    private AiConnection? GetActiveConnection() => _aiConnections.FirstOrDefault(c => c.IsActive) ?? _aiConnections.FirstOrDefault();

    private async Task GenerateAiReportForTab(string tabName)
    {
        if (analysisResult == null) return;
        _aiLoading = true;
        _aiLoadingTab = tabName;
        StateHasChanged();

        var data = BuildAiReportData();
        var systemPrompt = GetRolePrompt(_currentRole);

        var opts = BuildAiOptions();
        if (opts == null) { _aiLoading = false; _aiLoadingTab = ""; StateHasChanged(); return; }
        var result = await AiService.ChatAsync(systemPrompt, data, overrideOptions: opts);
        _aiReports[tabName] = result;
        _aiLoading = false;
        _aiLoadingTab = "";
        await SaveAiReportsToStorage();
        // 同步到聊天面板可读的共享存储
        await JS.InvokeVoidAsync("localStorage.setItem", "ai_latest_analysis", result ?? "");
        StateHasChanged();
    }

    private async Task SaveAiReportsToStorage()
    {
        var json = System.Text.Json.JsonSerializer.Serialize(_aiReports);
        await JS.InvokeVoidAsync("localStorage.setItem", "ai_reports", json);
    }

    private async Task LoadAiReportsFromStorage()
    {
        try
        {
            var json = await JS.InvokeAsync<string>("localStorage.getItem", "ai_reports");
            if (!string.IsNullOrEmpty(json))
            {
                var r = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, string>>(json);
                if (r != null) _aiReports = r;
            }
        }
        catch { }
    }

    private string BuildAiReportData()
    {
        if (analysisResult == null) return "无数据";
        var sb = new System.Text.StringBuilder();

        var projName = string.IsNullOrEmpty(_currentProjectName) ? "当前项目" : _currentProjectName;

        // 1. 项目概况
        sb.AppendLine($"## 项目基本信息");
        sb.AppendLine($"- **项目名称**：{projName}");
        sb.AppendLine($"- **总工期**：{analysisResult.ProjectDurationDays}天");
        sb.AppendLine($"- **总任务数**：{analysisResult.TotalTasks}个");
        sb.AppendLine($"- **计划最早完成**：{analysisResult.EarliestFinish:yyyy-MM-dd}");
        sb.AppendLine($"- **按时完成**：{analysisResult.OnTimeTasks.Count}个 ／ **提前完成**：{analysisResult.EarlyStartTasks.Count}个 ／ **延后**：{analysisResult.LateStartTasks.Count}个");
        if (_resourceSummary != null)
        {
            sb.AppendLine($"- **总资源数**：人工{_resourceSummary.LaborCount}/材料{_resourceSummary.MaterialCount}/设备{_resourceSummary.EquipmentCount}，**总预算成本**：{_resourceSummary.TotalCost:N0}元");
        }
        sb.AppendLine();

        // 2. EVM 挣值分析
        if (_earnedValueResult != null)
        {
            var evm = _earnedValueResult;
            var spiStatus = evm.SchedulePerformanceIndex >= 1.0 ? "✅ 正常" : evm.SchedulePerformanceIndex >= 0.9 ? "⚠️ 预警" : "🔴 滞后";
            var cpiStatus = evm.CostPerformanceIndex >= 1.0 ? "✅ 正常" : evm.CostPerformanceIndex >= 0.9 ? "⚠️ 预警" : "🔴 超支";
            sb.AppendLine($"## 挣值分析 (EVM)");
            sb.AppendLine($"- **计划价值 PV**：{evm.PlannedValue:N0} ｜ **挣值 EV**：{evm.EarnedValue:N0} ｜ **实际成本 AC**：{evm.ActualCost:N0}");
            sb.AppendLine($"- **进度绩效 SPI**：{evm.SchedulePerformanceIndex:F2}（{spiStatus}）");
            sb.AppendLine($"- **成本绩效 CPI**：{evm.CostPerformanceIndex:F2}（{cpiStatus}）");
            sb.AppendLine($"- **综合绩效 CSI**：{evm.CostScheduleIndex:F2}（{(evm.CostScheduleIndex >= 0.9 ? "✅ 可控" : "⚠️ 需关注")}）");
            sb.AppendLine($"- **进度偏差 SV**：{evm.ScheduleVariance:F0} ｜ **成本偏差 CV**：{evm.CostVariance:F0}");
            sb.AppendLine($"- **总预算 BAC**：{evm.BudgetAtCompletion:N0} ｜ **估算完工 EAC**：{evm.EstimateAtCompletion:N0}");
            if (evm.MonthlyTrend.Count > 1)
            {
                var trend = evm.MonthlyTrend.OrderByDescending(m => m.Month).Take(3).ToList();
                sb.AppendLine($"- **SPI 近期趋势**（最近3月）：{string.Join(" → ", trend.Select(m => $"{m.Month}={m.SPI:F2}"))}");
            }
            sb.AppendLine();
        }

        // 3. 阶段完成率
        if (_stageCompletionResult != null)
        {
            var sc = _stageCompletionResult;
            sb.AppendLine($"## 阶段完成率");
            sb.AppendLine($"- **检测方法**：{sc.DetectionMethod}");
            sb.AppendLine($"- **完成进度**：{sc.CompletedStages}/{sc.TotalStages}阶段完成，**整体完成率**：{sc.OverallPct:F1}%");
            foreach (var s in sc.Stages.Take(7))
            {
                var icon = s.Status == "completed" ? "✅" : s.Status == "in_progress" ? "🔄" : s.Status == "delayed" ? "🔴" : "⏳";
                sb.AppendLine($"  - {icon} {s.StageName}：计划 {s.PlannedCompletionPct}% / 实际 {s.ActualCompletionPct}%（{s.CompletedTasks}/{s.TotalTasks}任务）{(s.DelayDays.HasValue && s.DelayDays != 0 ? $"偏差 {s.DelayDays}天" : "")}");
            }
            sb.AppendLine();
        }

        // 4. 关键路径
        sb.AppendLine($"## 关键路径");
        sb.AppendLine($"共 {analysisResult.CriticalPathTasks.Count} 个关键任务：");
        foreach (var t in analysisResult.CriticalPathTasks.Take(10))
        {
            var floatStr = t.TotalFloat.HasValue ? $"，时差：{t.TotalFloat}天" : "";
            var respStr = string.IsNullOrEmpty(t.ResponsiblePerson) ? "" : $"，负责人：{t.ResponsiblePerson}";
            sb.AppendLine($"- **{t.Code} {t.Name}**：{t.PlanStartDate:MM/dd}→{t.PlanEndDate:MM/dd}（{t.PlanDuration}天）{floatStr}{respStr}");
        }
        if (analysisResult.CriticalPathTasks.Count > 10)
            sb.AppendLine($"  ... 还有 {analysisResult.CriticalPathTasks.Count - 10} 个关键任务未列出");
        sb.AppendLine();

        // 5. 延后任务 TOP10
        if (analysisResult.LateStartTasks.Any())
        {
            sb.AppendLine($"## 延后任务 TOP{Math.Min(analysisResult.LateStartTasks.Count, 10)}");
            foreach (var t in analysisResult.LateStartTasks.OrderBy(t => t.PlanEndDate).Take(10))
            {
                var delayDays = t.ActualEndDate.HasValue ? (t.ActualEndDate.Value - t.PlanEndDate).Days : (DateTime.Today - t.PlanEndDate).Days;
                var pct = t.CompletionPercentage;
                sb.AppendLine($"- **{t.Code} {t.Name}**：计划完成 {t.PlanEndDate:MM/dd}，延后 {delayDays}天，完成率 {pct}%");
            }
            sb.AppendLine();
        }

        // 6. 里程碑
        if (analysisResult.Milestones.Any())
        {
            sb.AppendLine($"## 里程碑");
            sb.AppendLine($"共 {analysisResult.Milestones.Count} 个：");
            foreach (var m in analysisResult.Milestones.OrderBy(m => m.Date))
                sb.AppendLine($"- {m.Name}：{m.Date:yyyy-MM-dd}");
            sb.AppendLine();
        }

        // 7. 资源冲突
        sb.AppendLine($"## 资源冲突");
        if (resourceConflicts.Any())
        {
            sb.AppendLine($"共 {resourceConflicts.Count} 项：");
            foreach (var c in resourceConflicts.Take(10))
                sb.AppendLine($"- **{c.ResourceName}**（{c.ConflictPeriod}）：涉及任务 {string.Join("、", c.ConflictTasks)}");
            if (resourceConflicts.Count > 10)
                sb.AppendLine($"  ... 还有 {resourceConflicts.Count - 10} 项资源冲突未列出");
        }
        else
        {
            sb.AppendLine("未检测到资源冲突，分配合理。");
        }
        sb.AppendLine();

        // 8. 资源使用情况
        if (resourceUsages.Any())
        {
            sb.AppendLine($"## 资源使用 TOP5（按负荷率排序）");
            foreach (var u in resourceUsages.OrderByDescending(u => u.PeakUsage / Math.Max(0.001m, u.Capacity)).Take(5))
            {
                var pct = u.Capacity > 0 ? (int)(u.PeakUsage / u.Capacity * 100) : 0;
                var status = pct > 100 ? "🔴 超额" : "✅ 正常";
                sb.AppendLine($"- **{u.ResourceName}**：容量 {u.Capacity}{u.Unit}，峰值 {u.PeakUsage}{u.Unit}（{pct}%），{status}");
            }
            sb.AppendLine();
        }

        return sb.ToString();
    }

