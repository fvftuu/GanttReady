    {
        "deepseek" => "🧊",
        "moonshot" => "🌙",
        "qwen" => "🐉",
        "zhipu" => "🧠",
        "minimax" => "🎯",
        "volcengine" => "🌋",
        "youdao" => "📖",
        "qianfan" => "☁️",
        "stepfun" => "⚡",
        "xiaomi" => "📱",
        "ollama" => "🦙",
        "openai" => "🟢",
        "anthropic" => "🏔️",
        "gemini" => "♊",
        "github-copilot" => "🐙",
        "openrouter" => "🌐",
        _ => "🔌"
    };

    private void InitDefaultConnections()
    {
        if (_aiConnections.Count > 0) return;
        _aiConnections = new()
        {
            new() { Name = "deepseek", Endpoint = "https://api.deepseek.com/v1", ApiFormat = "openai", Model = "deepseek-v4-flash", IsActive = true, Models = new() { "deepseek-v4-flash", "deepseek-v4-pro", "deepseek-reasoner" } },
            new() { Name = "moonshot", Endpoint = "https://api.moonshot.cn/v1", ApiFormat = "openai", Model = "kimi-k2.6", Models = new() { "kimi-k2.6", "kimi-k2.5" } },
            new() { Name = "qwen", Endpoint = "https://dashscope.aliyuncs.com/compatible-mode/v1", ApiFormat = "openai", Model = "qwen3.6-plus", Models = new() { "qwen3.6-plus", "qwen3.5-plus", "qwen3-coder-plus" } },
            new() { Name = "zhipu", Endpoint = "https://open.bigmodel.cn/api/paas/v4", ApiFormat = "openai", Model = "glm-5", Models = new() { "glm-5", "glm-4.7", "glm-4.7-flash", "GLM-4.7-Flash" } },
            new() { Name = "minimax", Endpoint = "https://api.minimaxi.com/v1", ApiFormat = "openai", Model = "MiniMax-M2.7", Models = new() { "MiniMax-M2.7", "MiniMax-M2.5" } },
            new() { Name = "volcengine", Endpoint = "https://ark.cn-beijing.volces.com/api/v3", ApiFormat = "openai", Model = "doubao-seed-2-0-pro-260215", Models = new() { "doubao-seed-2-0-pro-260215", "doubao-seed-2-0-lite-260215", "doubao-seed-2-0-mini-260215" } },
            new() { Name = "youdao", Endpoint = "https://openapi.youdao.com/llmgateway/api/v1/chat/completions", ApiFormat = "openai", Model = "deepseek-chat", Models = new() { "deepseek-chat", "deepseek-reasoner" } },
            new() { Name = "qianfan", Endpoint = "https://qianfan.baidubce.com/v2", ApiFormat = "openai", Model = "deepseek-v3.2", Models = new() { "deepseek-v3.2", "deepseek-r1", "ernie-4.5-8k" } },
            new() { Name = "stepfun", Endpoint = "https://api.stepfun.com/v1", ApiFormat = "openai", Model = "step-3.5-flash", Models = new() { "step-3.5-flash" } },
            new() { Name = "xiaomi", Endpoint = "https://api.xiaomimimo.com/v1", ApiFormat = "openai", Model = "mimo-v2.5-pro", Models = new() { "mimo-v2.5-pro", "mimo-v2.5", "mimo-v2-pro", "mimo-v2-flash" } },
            new() { Name = "ollama", Endpoint = "http://localhost:11434/v1", ApiFormat = "openai", Model = "llama3", Models = new() { "qwen3-coder-next", "glm-4.7-flash" } },
            new() { Name = "openai", Endpoint = "https://api.openai.com/v1", ApiFormat = "openai", Model = "gpt-5.4", Models = new() { "gpt-5.4", "gpt-5.2", "gpt-5.3-codex" } },
            new() { Name = "anthropic", Endpoint = "https://api.anthropic.com", ApiFormat = "anthropic", Model = "claude-sonnet-4-5-20250929", Models = new() { "claude-sonnet-4-5-20250929", "claude-opus-4-6" } },
            new() { Name = "gemini", Endpoint = "https://generativelanguage.googleapis.com/v1beta", ApiFormat = "openai", Model = "gemini-3-pro-preview", Models = new() { "gemini-3-pro-preview", "gemini-3-flash-preview" } },
            new() { Name = "github-copilot", Endpoint = "https://api.individual.githubcopilot.com", ApiFormat = "openai", Model = "gpt-5-mini", Models = new() { "gpt-5-mini", "claude-haiku-4.5", "gpt-4.1", "gpt-4o" } },
            new() { Name = "openrouter", Endpoint = "https://openrouter.ai/api/v1", ApiFormat = "openai", Model = "anthropic/claude-sonnet-4.5", Models = new() { "anthropic/claude-sonnet-4.5", "openai/gpt-5.2-codex", "google/gemini-3-pro-preview" } },
        };
    }

    private class AiConnection
    {
        public string Name { get; set; } = "";
        public string Endpoint { get; set; } = "https://api.deepseek.com/v1";
        public string ApiKey { get; set; } = "";
        public string Model { get; set; } = "deepseek-v4-flash";
        public string ApiFormat { get; set; } = "openai";
        public List<string> Models { get; set; } = new();
        public bool IsActive { get; set; } = false;
        public bool Testing { get; set; } = false;
        public string Status { get; set; } = "";
        public string StatusMessage { get; set; } = "";
    }

    // ===== AI 设置 =====
    private async Task LoadAiSettings()
    {
        var version = await JS.InvokeAsync<string>("localStorage.getItem", "ai_connections_v");
        if (version != "2")
        {
            await JS.InvokeVoidAsync("localStorage.removeItem", "ai_connections");
            await JS.InvokeVoidAsync("localStorage.setItem", "ai_connections_v", "2");
            InitDefaultConnections();
            return;
        }
        try
        {
            var json = await JS.InvokeAsync<string>("localStorage.getItem", "ai_connections");
            if (!string.IsNullOrEmpty(json))
            {
                var list = System.Text.Json.JsonSerializer.Deserialize<List<AiConnection>>(json);
                if (list != null && list.Count > 0)
                {
                    _aiConnections = list;
                    return;
                }
            }
        }
        catch { }
        InitDefaultConnections();
    }

    private async Task SaveAiSettings()
    {
        var json = System.Text.Json.JsonSerializer.Serialize(_aiConnections);
        await JS.InvokeVoidAsync("localStorage.setItem", "ai_connections", json);
        _showAiSettings = false;
    }

    private void ShowAiSettings()
    {
        _showAiSettings = true;
        InitDefaultConnections();
    }
    private void AddAiConnection() => _aiConnections.Add(new AiConnection { Name = "新连接", Endpoint = "https://api.deepseek.com/v1", Model = "deepseek-v4-flash", ApiFormat = "openai" });
    private void RemoveAiConnection(int idx) { if (idx >= 0 && idx < _aiConnections.Count) _aiConnections.RemoveAt(idx); }
    private void SelectAiConnection(int idx) { foreach (var c in _aiConnections) c.IsActive = false; if (idx >= 0 && idx < _aiConnections.Count) _aiConnections[idx].IsActive = true; }

    private async Task TestAiConnection(int idx)
    {
        if (idx < 0 || idx >= _aiConnections.Count) return;
        var conn = _aiConnections[idx];
        conn.Testing = true; conn.Status = "testing"; conn.StatusMessage = ""; StateHasChanged();
        try
        {
            using var http = new HttpClient();
            http.Timeout = TimeSpan.FromSeconds(10);
            HttpRequestMessage request;
            if ((conn.ApiFormat ?? "openai").ToLower() == "anthropic")
            {
                request = new HttpRequestMessage(HttpMethod.Post, $"{conn.Endpoint.TrimEnd('/')}/messages");
                request.Content = new StringContent("{\"model\":\"" + conn.Model + "\",\"messages\":[{\"role\":\"user\",\"content\":\"ping\"}],\"max_tokens\":1}", System.Text.Encoding.UTF8, "application/json");
                if (!string.IsNullOrEmpty(conn.ApiKey)) request.Headers.Add("x-api-key", conn.ApiKey);
                request.Headers.Add("anthropic-version", "2023-06-01");
            }
            else
            {
                request = new HttpRequestMessage(HttpMethod.Post, $"{conn.Endpoint.TrimEnd('/')}/chat/completions");
                request.Content = new StringContent("{\"model\":\"" + conn.Model + "\",\"messages\":[{\"role\":\"user\",\"content\":\"ping\"}],\"max_tokens\":1}", System.Text.Encoding.UTF8, "application/json");
                if (!string.IsNullOrEmpty(conn.ApiKey)) request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", conn.ApiKey);
            }
            var response = await http.SendAsync(request);
            conn.Status = response.IsSuccessStatusCode ? "ok" : "fail";
            conn.StatusMessage = response.IsSuccessStatusCode ? "" : $"HTTP {(int)response.StatusCode}";
        }
        catch (Exception ex) { conn.Status = "fail"; conn.StatusMessage = ex.Message; }
        conn.Testing = false; StateHasChanged();
    }

    private void ToggleAiMode()
    {
        _aiMode = !_aiMode;
        if (_aiMode) _ = GenerateAiReportForTab("analysis");
    }

    private AiOptions? BuildAiOptions()
    {
        var conn = GetActiveConnection();
        if (conn == null || string.IsNullOrEmpty(conn.Endpoint)) return null;
        return new AiOptions
        {
            Endpoint = conn.Endpoint,
            ApiKey = conn.ApiKey,
            Model = string.IsNullOrEmpty(conn.Model) ? "deepseek-v4-flash" : conn.Model,
            ApiFormat = string.IsNullOrEmpty(conn.ApiFormat) ? "openai" : conn.ApiFormat
        };
    }

    private AiConnection? GetActiveConnection() => _aiConnections.FirstOrDefault(c => c.IsActive) ?? _aiConnections.FirstOrDefault();

    private async Task GenerateAiReportForTab(string tabName)
    {
        if (analysisResult == null) return;
        _aiLoading = true;
        _aiLoadingTab = tabName;
        StateHasChanged();

        var data = BuildAiReportData();
        var systemPrompt = tabName switch
        {
            "overview" => "你是一个专业的项目管理分析师。根据提供的项目数据，生成一份简洁的项目总览分析。用中文，300字以内。包含：项目整体状态、进度绩效、关键指标。不要使用markdown格式。",
            "implementation" => "你是一个专业的项目管理分析师。根据提供的项目数据，生成一份实施阶段分析。用中文，400字以内。包含：进度执行情况、资源使用状况、偏差分析、改进建议。不要使用markdown格式。",
            "monthly" => "你是一个专业的项目管理分析师。根据提供的项目数据，生成一份月度分析报告。用中文，300字以内。包含：本月执行概况、进度偏差、关键风险、下月建议。不要使用markdown格式。",
            "annual" => "你是一个专业的项目管理分析师。根据提供的项目数据，生成一份年度总结报告。用中文，500字以内。包含：年度执行概况、核心指标、里程碑回顾、存在问题、下阶段建议。不要使用markdown格式。",
            _ => "你是一个专业的项目管理分析师。根据提供的项目数据，生成一份简洁的项目分析报告。用中文，300字以内。"
        };

        var opts = BuildAiOptions();
        if (opts == null) { _aiLoading = false; _aiLoadingTab = ""; StateHasChanged(); return; }
        var result = await AiService.ChatAsync(systemPrompt, data, overrideOptions: opts);
        _aiReports[tabName] = result;
        _aiLoading = false;
        _aiLoadingTab = "";
        await SaveAiReportsToStorage();
        StateHasChanged();
    }

    private async Task SaveAiReportsToStorage()
    {
        var json = System.Text.Json.JsonSerializer.Serialize(_aiReports);
        await JS.InvokeVoidAsync("localStorage.setItem", "ai_reports", json);
    }

    private async Task LoadAiReportsFromStorage()
    {
        try
        {
            var json = await JS.InvokeAsync<string>("localStorage.getItem", "ai_reports");
            if (!string.IsNullOrEmpty(json))
            {
                var r = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, string>>(json);
                if (r != null) _aiReports = r;
            }
        }
        catch { }
    }

    private string BuildAiReportData()
    {
        if (analysisResult == null) return "无数据";
        var lateCount = analysisResult.LateStartTasks.Count;
        var earlyCount = analysisResult.EarlyStartTasks.Count;

        return $"项目工期：{analysisResult.ProjectDurationDays}天；" +
               $"总任务数：{analysisResult.TotalTasks}；" +
               $"关键路径任务：{analysisResult.CriticalPathTasks.Count}个；" +
               $"里程碑：{analysisResult.Milestones.Count}个；" +
               $"按时完成：{analysisResult.OnTimeTasks.Count}个；" +
               $"提前完成：{earlyCount}个；" +
               $"延后任务：{lateCount}个；" +
               $"资源冲突：{resourceConflicts.Count}项。";
    }

    private List<Models.Project> projects = new();
    private string selectedScope = "all";  // "all" 或 "p-{id}"
    private bool isAllProjects => selectedScope == "all";
    private int? selectedProjectId =>
        selectedScope.StartsWith("p-") && int.TryParse(selectedScope.Substring(2), out var id) ? id : null;

    private ProjectAnalysisResult? analysisResult;
    private bool isLoading = true;
    private int totalAssignments = 0;

    // 所有项目分析数据
    private List<AllProjectResourceItem> allProjectResources = new();
    private List<ProjectResourceSummary> projectSummaries = new();

    // 资源使用情况
    private List<ResourceUsageSummary> resourceUsages = new();
    private List<ResourceConflict> resourceConflicts = new();

    protected override async Task OnInitializedAsync()
    {
        projects = await ProjectService.GetAllProjectsAsync();
        await LoadAiSettings();
        await LoadAiReportsFromStorage();
        // 如果 URL 中有 ProjectId，则选中对应项目
        if (ProjectId.HasValue)
            selectedScope = "p-" + ProjectId.Value;
        await LoadAnalysis();
    }

    private async Task OnScopeChanged()
    {
        await LoadAnalysis();
    }

    private async Task LoadAnalysis()
    {
        isLoading = true;
        analysisResult = null;
        resourceUsages = new();
        resourceConflicts = new();
        allProjectResources = new();
        projectSummaries = new();
        StateHasChanged();

        try
        {
            if (isAllProjects)
            {
                await LoadAllProjectsAnalysis();
            }
            else if (selectedProjectId.HasValue)
            {
                await LoadSingleProjectAnalysis(selectedProjectId.Value);
            }
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadAllProjectsAnalysis()
    {
        var allProjects = await ProjectService.GetAllProjectsAsync();
        var allResources = await ResourceService.GetAllResourcesAsync();

        // 各项目资源使用汇总
        foreach (var proj in allProjects)
        {
            try
            {
                var tasks = await ProjectService.GetTasksByProjectIdAsync(proj.Id);
                var assignments = await ResourceService.GetAssignmentsByProjectAsync(proj.Id);
                var resUsages = CalculateResourceUsages(assignments, tasks, allResources.Where(r => r.ProjectId == null || r.ProjectId == proj.Id).ToList());
                projectSummaries.Add(new ProjectResourceSummary
                {
                    ProjectId = proj.Id,
                    ProjectName = proj.Name,
                    TaskCount = tasks.Count,
                    ResourceCount = resUsages.Count,
                    ConflictCount = resUsages.Count(r => r.PeakUsage > r.Capacity && r.Capacity > 0)
                });
            }
            catch (Exception ex)
            {
                projectSummaries.Add(new ProjectResourceSummary
                {
                    ProjectId = proj.Id,
                    ProjectName = proj.Name + " (加载失败)",
                    TaskCount = 0,
                    ResourceCount = 0,
                    ConflictCount = 0
                });
            }
        }

        // 共享资源跨项目分析
        var sharedResources = allResources.Where(r => r.ProjectId == null).ToList();
        foreach (var res in sharedResources)
        {
            var allAssignments = await ResourceService.GetAllAssignmentsAsync();
            var resAssignments = allAssignments.Where(a => a.ResourceId == res.Id).ToList();
            if (!resAssignments.Any()) continue;

            var projectNames = new List<string>();
            foreach (var a in resAssignments)
            {
                var task = (await ProjectService.GetTaskByIdAsync(a.TaskId));
                if (task != null)
                {
                    var proj = allProjects.FirstOrDefault(p => p.Id == task.ProjectId);
                    if (proj != null && !projectNames.Contains(proj.Name))
                        projectNames.Add(proj.Name);
                }
            }

            allProjectResources.Add(new AllProjectResourceItem
            {
                ResourceName = res.Name,
                ResourceType = res.Type,
                TotalCapacity = res.Quantity,
                Unit = res.Unit ?? "",
                UsedByProjects = projectNames
            });
        }

        // 渲染图表
        await RenderAllProjectsChart();
    }

    private async Task LoadSingleProjectAnalysis(int projectId)
    {
        var project = await ProjectService.GetProjectByIdAsync(projectId);
        if (project != null)
        {
            var tasks = await ProjectService.GetTasksByProjectIdAsync(projectId);
            analysisResult = AnalysisService.AnalyzeProject(project, tasks);
            await AnalyzeResourceConflicts(tasks, project);
        }
        await RenderSingleProjectChart(projectId);
    }

    private List<ResourceUsageSummary> CalculateResourceUsages(
        List<Models.ResourceAssignment> assignments,
        List<Models.TaskItem> tasks,
        List<Models.Resource> resources)
    {
        var result = new List<ResourceUsageSummary>();
        var byResource = assignments.GroupBy(a => a.ResourceId).ToDictionary(g => g.Key, g => g.ToList());
        foreach (var kv in byResource)
        {
            var resource = resources.FirstOrDefault(r => r.Id == kv.Key);
            if (resource == null) continue;
            var taskAssignments = kv.Value;
            var monthlyUsage = new Dictionary<string, decimal>();
            foreach (var asgn in taskAssignments)
            {
                var task = tasks.FirstOrDefault(t => t.Id == asgn.TaskId);
                if (task == null) continue;
                var start = task.PlanStartDate;
                var end = task.PlanEndDate;
                var cur = new DateTime(start.Year, start.Month, 1);
                while (cur <= end)
                {
                    var key = cur.ToString("yyyy-MM");
                    if (!monthlyUsage.ContainsKey(key)) monthlyUsage[key] = 0;
                    monthlyUsage[key] += asgn.Quantity;
                    cur = cur.AddMonths(1);
                }
            }
            if (!monthlyUsage.Any()) continue;
            var peakKey = monthlyUsage.OrderByDescending(x => x.Value).First().Key;
            var peakUsage = monthlyUsage[peakKey];
            result.Add(new ResourceUsageSummary
            {
                ResourceId = resource.Id,
                ResourceName = resource.Name,
                ResourceType = resource.Type,
                Unit = resource.Unit ?? "",
                Capacity = resource.Quantity,
                PeakUsage = peakUsage,
                PeakPeriod = peakKey
            });
        }
        return result.OrderByDescending(r => r.PeakUsage / Math.Max(0.001m, r.Capacity)).ToList();
    }

    private async Task AnalyzeResourceConflicts(List<Models.TaskItem> tasks, Models.Project project)
    {
        resourceUsages = new();
        resourceConflicts = new();
        var assignments = await ResourceService.GetAssignmentsByProjectAsync(project.Id);
        totalAssignments = assignments.Count;
        if (!assignments.Any()) return;
        var resources = await ResourceService.GetResourcesByProjectAsync(project.Id);
        resourceUsages = CalculateResourceUsages(assignments, tasks, resources);

        foreach (var usage in resourceUsages)
        {
            if (usage.PeakUsage > usage.Capacity && usage.Capacity > 0)
            {
                resourceConflicts.Add(new ResourceConflict
                {
                    ResourceName = usage.ResourceName,
                    ConflictPeriod = usage.PeakPeriod,
                    ConflictTasks = new()
                });
            }
        }
    }

    private async Task RenderAllProjectsChart()
    {
        await Task.Delay(100);
        var labels = projectSummaries.Select(p => p.ProjectName).ToArray();
        var taskData = projectSummaries.Select(p => p.TaskCount).ToArray();
        var conflictData = projectSummaries.Select(p => p.ConflictCount).ToArray();
        var chartData = new
        {
            labels = labels,
            datasets = new[]
            {
                new { label = "任务数", data = taskData, backgroundColor = "#1890ff" },
                new { label = "资源冲突", data = conflictData, backgroundColor = "#ff4d4f" }
            }
        };
        try { await JS.InvokeVoidAsync("renderAnalysisBarChart", "all-projects-chart", chartData); } catch {}
    }

    private async Task RenderSingleProjectChart(int projectId)
    {
        await Task.Delay(100);
        if (!resourceUsages.Any()) return;
        var labels = resourceUsages.Select(r => r.ResourceName).ToArray();
        var capacityData = resourceUsages.Select(r => (double)r.Capacity).ToArray();
        var usageData = resourceUsages.Select(r => (double)r.PeakUsage).ToArray();
        var chartData = new
        {
            labels = labels,
            datasets = new[]
            {
                new { label = "总容量", data = capacityData, backgroundColor = "#52c41a" },
                new { label = "峰值使用", data = usageData, backgroundColor = "#faad14" }
            }
        };
        try { await JS.InvokeVoidAsync("renderAnalysisBarChart", "single-project-chart", chartData); } catch {}
    }

