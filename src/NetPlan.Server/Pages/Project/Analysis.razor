    private string GetVarianceText()
    {
        if (_earnedValueResult == null)
        {
            if (analysisResult != null && analysisResult.LateStartTasks.Any())
            {
                var maxDays = analysisResult.LateStartTasks.Max(t =>
                    t.ActualEndDate.HasValue ? (t.ActualEndDate.Value - t.PlanEndDate).Days :
                    (DateTime.Today - t.PlanEndDate).Days);
                return $"+{maxDays}天";
            }
            return "—";
        }
        // SV = EV - PV，是金额差异而非天数；去除 "天" 后缀避免误解
        var sv = _earnedValueResult.ScheduleVariance;
        return sv >= 0 ? $"+{sv:N0}" : $"{sv:N0}";
    }

