@page "/analysis"
@page "/project/{ProjectId:int}/analysis"
@inject IAnalysisService AnalysisService
@inject IProjectService ProjectService
@inject IResourceService ResourceService
@inject IAiService AiService
@inject IJSRuntime JS

<PageTitle>计划分析 - NetPlan</PageTitle>

<div class="page-header">
    <div class="header-left">
        <select class="form-control" @bind="selectedScope" @bind:after="OnScopeChanged" style="width:220px;">
            <option value="all">🌐 所有项目（共享资源）</option>
            @foreach (var project in projects)
            {
                <option value="@("p-"+project.Id)">📁 @project.Name</option>
            }
        </select>
        <span class="page-title">计划分析仪表板</span>
        <button class="btn btn-default btn-sm" style="margin-left:12px;" @onclick="ShowAiSettings">🤖 AI 设置</button>
        @if (!string.IsNullOrEmpty(_aiEndpoint))
        {
            <button class="btn @(_aiMode ? "btn-primary" : "btn-default") btn-sm" style="margin-left:6px;" @onclick="ToggleAiMode">
                @(_aiMode ? "🔵 AI 分析" : "⚪ 标准分析")
            </button>
        }
    </div>
    <div class="header-right">
        <button class="btn btn-default btn-sm" onclick="window.print()">🖨 打印</button>
    </div>
</div>

<div class="page-body">
    <div class="page-main" style="padding:20px;">
        @if (isLoading)
        {
            <div class="loading">加载中，正在分析资源数据...</div>
        }
        else if (isAllProjects)
        {
            @* ========== 所有项目共享资源分析 ========== *@
            <div class="dashboard-cards">
                <div class="card">
                    <div class="card-title">项目总数</div>
                    <div class="card-value">@projectSummaries.Count 个</div>
                </div>
                <div class="card">
                    <div class="card-title">共享资源数</div>
                    <div class="card-value">@allProjectResources.Count 个</div>
                </div>
                <div class="card">
                    <div class="card-title">有冲突项目</div>
                    <div class="card-value @(projectSummaries.Any(p => p.ConflictCount > 0) ? "highlight" : "")">
                        @projectSummaries.Count(p => p.ConflictCount > 0) 个
                    </div>
                </div>
            </div>

            @* 图表：各项目任务数与冲突数 *@
            <div class="section">
                <h3>📊 各项目资源冲突概览</h3>
                <div style="height:300px;">
                    <canvas id="all-projects-chart"></canvas>
                </div>
            </div>

            @* 各项目汇总表格 *@
            <div class="section">
                <h3>📋 各项目汇总</h3>
                @if (!projectSummaries.Any())
                {
                    <div class="empty-state">库中没有项目，请先创建项目。</div>
                }
                else
                {
                    <table class="table">
                        <thead>
                            <tr>
                                <th>项目名称</th>
                                <th>任务数</th>
                                <th>资源数</th>
                                <th>冲突数</th>
                                <th>操作</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ps in projectSummaries)
                            {
                                <tr class="@(ps.ConflictCount > 0 ? "conflict-row" : "")">
                                    <td>@ps.ProjectName</td>
                                    <td>@ps.TaskCount</td>
                                    <td>@ps.ResourceCount</td>
                                    <td>
                                        @if (ps.ConflictCount > 0)
                                        {
                                            <span class="badge danger">@ps.ConflictCount 项</span>
                                        }
                                        else
                                        {
                                            <span class="badge success">✓ 正常</span>
                                        }
                                    </td>
                                    <td>
                                        <a href="/project/@ps.ProjectId/analysis" class="btn btn-sm btn-outline">查看详情</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>

            @* 共享资源使用详情 *@
            <div class="section">
                <h3>🌐 共享资源跨项目使用情况</h3>
                @if (!allProjectResources.Any())
                {
                    <div class="empty-state">当前没有共享资源（所有资源均绑定到具体项目）。</div>
                }
                else
                {
                    <table class="table">
                        <thead>
                            <tr>
                                <th>资源名称</th>
                                <th>类型</th>
                                <th>总容量</th>
                                <th>使用单位</th>
                                <th>使用项目</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in allProjectResources)
                            {
                                <tr>
                                    <td>@item.ResourceName</td>
                                    <td><span class="badge @GetResourceTypeBadgeClass(item.ResourceType)">@GetResourceTypeLabel(item.ResourceType)</span></td>
                                    <td>@item.TotalCapacity @item.Unit</td>
                                    <td>@item.Unit</td>
                                    <td>@string.Join("、", item.UsedByProjects)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        }
        else if (analysisResult != null)
        {
            @* ========== 单个项目分析（原有逻辑 + 图表）========== *@
            <div class="dashboard-cards">
                <div class="card">
                    <div class="card-title">项目工期</div>
                    <div class="card-value">@analysisResult.ProjectDurationDays 天</div>
                </div>
                <div class="card">
                    <div class="card-title">总任务数</div>
                    <div class="card-value">@analysisResult.TotalTasks 个</div>
                </div>
                <div class="card">
                    <div class="card-title">关键路径任务</div>
                    <div class="card-value highlight">@analysisResult.CriticalPathTasks.Count 个</div>
                </div>
                <div class="card">
                    <div class="card-title">最早完成</div>
                    <div class="card-value">@analysisResult.EarliestFinish.ToString("yyyy-MM-dd")</div>
                </div>
                @if (resourceConflicts.Any())
                {
                    <div class="card" style="border-left:4px solid #ff4d4f;">
                        <div class="card-title" style="color:#ff4d4f;">⚠ 资源冲突</div>
                        <div class="card-value" style="color:#ff4d4f;">@resourceConflicts.Count 项</div>
                    </div>
                }
            </div>

            @* 资源容量 vs 峰值使用图表 *@
            @if (resourceUsages.Any())
            {
                <div class="section">
                    <h3>📊 资源容量 vs 峰值使用</h3>
                    <div style="height:300px;">
                        <canvas id="single-project-chart"></canvas>
                    </div>
                </div>
            }

            <div class="section">
                <h3>📊 项目统计</h3>
                <div class="stats-grid">
                    <div class="stat-item">
                        <span class="stat-label">按时任务:</span>
                        <span class="stat-value">@analysisResult.OnTimeTasks.Count</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-label">提前任务:</span>
                        <span class="stat-value text-success">@analysisResult.EarlyStartTasks.Count</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-label">延后任务:</span>
                        <span class="stat-value text-warning">@analysisResult.LateStartTasks.Count</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-label">里程碑节点:</span>
                        <span class="stat-value">@analysisResult.Milestones.Count</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-label">资源分配项:</span>
                        <span class="stat-value">@totalAssignments</span>
                    </div>
                </div>
            </div>

            <div class="section">
                <h3>🔴 关键路径任务</h3>
                @if (analysisResult.CriticalPathTasks.Count == 0)
                {
                    <div class="empty-state">未检测到关键路径（请先在甘特图中点击「重算计划」）</div>
                }
                else
                {
                    <table class="table">
                        <thead>
                            <tr>
                                <th>代号</th>
                                <th>任务名称</th>
                                <th>计划开始</th>
                                <th>计划完成</th>
                                <th>工期(天)</th>
                                <th>总时差</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var task in analysisResult.CriticalPathTasks)
                            {
                                <tr class="critical-row">
                                    <td>@task.Code</td>
                                    <td>@task.Name</td>
                                    <td>@task.PlanStartDate.ToString("yyyy-MM-dd")</td>
                                    <td>@task.PlanEndDate.ToString("yyyy-MM-dd")</td>
                                    <td>@task.PlanDuration</td>
                                    <td>
                                        <span class="badge danger">
                                            @(task.TotalFloat?.ToString() ?? "0") 天
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>

            <div class="section">
                <h3>📋 时差分析</h3>
                <div class="float-chart">
                    @foreach (var task in analysisResult.Tasks.OrderBy(t => t.TotalFloat ?? 0).Take(20))
                    {
                        var floatVal = task.TotalFloat ?? 0;
                        var barWidth = Math.Min(100, Math.Max(1, Math.Abs(floatVal) * 5));
                        <div class="float-bar-row">
                            <div class="float-bar-label" title="@task.Name">
                                @(task.Name.Length > 15 ? task.Name.Substring(0, 15) + "..." : task.Name)
                            </div>
                            <div class="float-bar-container">
                                <div class="float-bar @(floatVal == 0 ? "critical" : floatVal <= 3 ? "warning" : "normal")"
                                     style="width: @barWidth%"></div>
                            </div>
                            <div class="float-bar-value">@floatVal 天</div>
                        </div>
                    }
                </div>
            </div>

            @if (analysisResult.Milestones.Count > 0)
            {
                <div class="section">
                    <h3>🎯 里程碑节点</h3>
                    <div class="milestone-timeline">
                        @foreach (var milestone in analysisResult.Milestones.OrderBy(m => m.Date))
                        {
                            <div class="milestone-item">
                                <div class="milestone-dot"></div>
                                <div class="milestone-content">
                                    <div class="milestone-name">@milestone.Name</div>
                                    <div class="milestone-date">@milestone.Date.ToString("yyyy-MM-dd")</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            @* 资源冲突检测 *@
            <div class="section">
                <h3>⚙️ 资源冲突检测</h3>
                @if (!resourceUsages.Any())
                {
                    <div class="empty-state">本项目暂无资源分配数据，请先在甘特图中为任务分配资源。</div>
                }
                else
                {
                    @if (!resourceConflicts.Any())
                    {
                        <div style="color:#52c41a;padding:8px 0;">✅ 未发现资源过度分配，所有资源在容量范围内。</div>
                    }
                    else
                    {
                        <div style="color:#ff4d4f;margin-bottom:12px;">发现 <strong>@resourceConflicts.Count</strong> 项资源过度分配，请调整任务排期或增加资源容量。</div>
                    }

                    <table class="table">
                        <thead>
                            <tr>
                                <th>资源名称</th>
                                <th>类型</th>
                                <th>总容量</th>
                                <th>峰值使用</th>
                                <th>峰值时段</th>
                                <th>状态</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var usage in resourceUsages)
                            {
                                var isConflict = usage.PeakUsage > usage.Capacity;
                                var pct = usage.Capacity > 0 ? (int)(usage.PeakUsage / usage.Capacity * 100) : 0;
                                <tr class="@(isConflict ? "conflict-row" : "")">
                                    <td>@usage.ResourceName</td>
                                    <td><span class="badge @GetResourceTypeBadgeClass(usage.ResourceType)">@GetResourceTypeLabel(usage.ResourceType)</span></td>
                                    <td>@usage.Capacity @usage.Unit</td>
                                    <td style="color:@(isConflict ? "#ff4d4f" : "#52c41a"); font-weight:bold;">
                                        @usage.PeakUsage @usage.Unit
                                        <small>(@pct%)</small>
                                    </td>
                                    <td>@usage.PeakPeriod</td>
                                    <td>
                                        @if (isConflict)
                                        {
                                            <span class="badge danger">⚠ 超额 @((usage.PeakUsage - usage.Capacity).ToString("0.#")) @usage.Unit</span>
                                        }
                                        else
                                        {
                                            <span class="badge success">✓ 正常</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <p>无法加载分析数据。</p>
                <button class="btn btn-primary" @onclick="LoadAnalysis">重试</button>
            </div>
        }
    </div>
</div>

@* ========== AI 设置弹窗 ========== *@
@if (_showAiSettings)
{
    <div class="modal-overlay">
        <div class="modal-content" style="width:540px;">
            <h3>🤖 AI 服务设置</h3>
            <div class="form-group">
                <label>API 地址</label>
                <input type="text" class="form-control" @bind="_aiEndpoint" placeholder="https://api.openai.com/v1" />
                <small style="color:#999;">支持 OpenAI / Azure OpenAI / Ollama (http://localhost:11434/v1)</small>
            </div>
            <div class="form-group">
                <label>API Key</label>
                <input type="text" class="form-control" @bind="_aiKey" placeholder="sk-..." style="font-family:monospace;" />
            </div>
            <div class="form-group">
                <label>模型</label>
                <input type="text" class="form-control" @bind="_aiModel" placeholder="gpt-4o-mini / qwen2.5" />
            </div>
            <div class="dialog-actions">
                <button class="btn btn-default" @onclick="() => _showAiSettings = false">取消</button>
                <button class="btn btn-primary" @onclick="SaveAiSettings">保存</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int? ProjectId { get; set; }

    private Dictionary<string, string> _aiReports = new();
    private bool _aiLoading = false;
    private string _aiLoadingTab = "";
    private bool _aiMode = false;
    private bool _showAiSettings = false;
    private string _aiEndpoint = "";
    private string _aiKey = "";
    private string _aiModel = "gpt-4o-mini";

    // ===== AI 设置 =====
    private async Task LoadAiSettings()
    {
        try
        {
            var json = await JS.InvokeAsync<string>("localStorage.getItem", "ai_settings");
            if (!string.IsNullOrEmpty(json))
            {
                var s = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, string>>(json);
                if (s != null)
                {
                    _aiEndpoint = s.GetValueOrDefault("endpoint", "");
                    _aiKey = s.GetValueOrDefault("key", "");
                    _aiModel = s.GetValueOrDefault("model", "gpt-4o-mini");
                }
            }
        }
        catch { }
    }

    private async Task SaveAiSettings()
    {
        var dict = new Dictionary<string, string>
        {
            ["endpoint"] = _aiEndpoint,
            ["key"] = _aiKey,
            ["model"] = _aiModel
        };
        var json = System.Text.Json.JsonSerializer.Serialize(dict);
        await JS.InvokeVoidAsync("localStorage.setItem", "ai_settings", json);
        _showAiSettings = false;
    }

    private void ShowAiSettings() { _showAiSettings = true; }

    private void ToggleAiMode()
    {
        _aiMode = !_aiMode;
        if (_aiMode) _ = GenerateAiReportForTab("overview");
    }

    private AiOptions BuildAiOptions()
    {
        return new AiOptions
        {
            Endpoint = string.IsNullOrEmpty(_aiEndpoint) ? "https://api.openai.com/v1" : _aiEndpoint,
            ApiKey = _aiKey,
            Model = string.IsNullOrEmpty(_aiModel) ? "gpt-4o-mini" : _aiModel
        };
    }

    private async Task GenerateAiReportForTab(string tabName)
    {
        if (analysisResult == null) return;
        _aiLoading = true;
        _aiLoadingTab = tabName;
        StateHasChanged();

        var data = BuildAiReportData();
        var systemPrompt = tabName switch
        {
            "overview" => "你是一个专业的项目管理分析师。根据提供的项目数据，生成一份简洁的项目总览分析。用中文，300字以内。包含：项目整体状态、进度绩效、关键指标。不要使用markdown格式。",
            "implementation" => "你是一个专业的项目管理分析师。根据提供的项目数据，生成一份实施阶段分析。用中文，400字以内。包含：进度执行情况、资源使用状况、偏差分析、改进建议。不要使用markdown格式。",
            "monthly" => "你是一个专业的项目管理分析师。根据提供的项目数据，生成一份月度分析报告。用中文，300字以内。包含：本月执行概况、进度偏差、关键风险、下月建议。不要使用markdown格式。",
            "annual" => "你是一个专业的项目管理分析师。根据提供的项目数据，生成一份年度总结报告。用中文，500字以内。包含：年度执行概况、核心指标、里程碑回顾、存在问题、下阶段建议。不要使用markdown格式。",
            _ => "你是一个专业的项目管理分析师。根据提供的项目数据，生成一份简洁的项目分析报告。用中文，300字以内。"
        };

        var result = await AiService.ChatAsync(systemPrompt, data, overrideOptions: BuildAiOptions());
        _aiReports[tabName] = result;
        _aiLoading = false;
        _aiLoadingTab = "";
        await SaveAiReportsToStorage();
        StateHasChanged();
    }

    private async Task SaveAiReportsToStorage()
    {
        var json = System.Text.Json.JsonSerializer.Serialize(_aiReports);
        await JS.InvokeVoidAsync("localStorage.setItem", "ai_reports", json);
    }

    private async Task LoadAiReportsFromStorage()
    {
        try
        {
            var json = await JS.InvokeAsync<string>("localStorage.getItem", "ai_reports");
            if (!string.IsNullOrEmpty(json))
            {
                var r = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, string>>(json);
                if (r != null) _aiReports = r;
            }
        }
        catch { }
    }

    private string BuildAiReportData()
    {
        if (analysisResult == null) return "无数据";
        var lateCount = analysisResult.LateStartTasks.Count;
        var earlyCount = analysisResult.EarlyStartTasks.Count;

        return $"项目工期：{analysisResult.ProjectDurationDays}天；" +
               $"总任务数：{analysisResult.TotalTasks}；" +
               $"关键路径任务：{analysisResult.CriticalPathTasks.Count}个；" +
               $"里程碑：{analysisResult.Milestones.Count}个；" +
               $"按时完成：{analysisResult.OnTimeTasks.Count}个；" +
               $"提前完成：{earlyCount}个；" +
               $"延后任务：{lateCount}个；" +
               $"资源冲突：{resourceConflicts.Count}项。";
    }

    private List<Models.Project> projects = new();
    private string selectedScope = "all";  // "all" 或 "p-{id}"
    private bool isAllProjects => selectedScope == "all";
    private int? selectedProjectId =>
        selectedScope.StartsWith("p-") && int.TryParse(selectedScope.Substring(2), out var id) ? id : null;

    private ProjectAnalysisResult? analysisResult;
    private bool isLoading = true;
    private int totalAssignments = 0;

    // 所有项目分析数据
    private List<AllProjectResourceItem> allProjectResources = new();
    private List<ProjectResourceSummary> projectSummaries = new();

    // 资源使用情况
    private List<ResourceUsageSummary> resourceUsages = new();
    private List<ResourceConflict> resourceConflicts = new();

    protected override async Task OnInitializedAsync()
    {
        projects = await ProjectService.GetAllProjectsAsync();
        await LoadAiSettings();
        await LoadAiReportsFromStorage();
        // 如果 URL 中有 ProjectId，则选中对应项目
        if (ProjectId.HasValue)
            selectedScope = "p-" + ProjectId.Value;
        await LoadAnalysis();
    }

    private async Task OnScopeChanged()
    {
        await LoadAnalysis();
    }

    private async Task LoadAnalysis()
    {
        isLoading = true;
        analysisResult = null;
        resourceUsages = new();
        resourceConflicts = new();
        allProjectResources = new();
        projectSummaries = new();
        StateHasChanged();

        try
        {
            if (isAllProjects)
            {
                await LoadAllProjectsAnalysis();
            }
            else if (selectedProjectId.HasValue)
            {
                await LoadSingleProjectAnalysis(selectedProjectId.Value);
            }
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadAllProjectsAnalysis()
    {
        var allProjects = await ProjectService.GetAllProjectsAsync();
        var allResources = await ResourceService.GetAllResourcesAsync();

        // 各项目资源使用汇总
        foreach (var proj in allProjects)
        {
            try
            {
                var tasks = await ProjectService.GetTasksByProjectIdAsync(proj.Id);
                var assignments = await ResourceService.GetAssignmentsByProjectAsync(proj.Id);
                var resUsages = CalculateResourceUsages(assignments, tasks, allResources.Where(r => r.ProjectId == null || r.ProjectId == proj.Id).ToList());
                projectSummaries.Add(new ProjectResourceSummary
                {
                    ProjectId = proj.Id,
                    ProjectName = proj.Name,
                    TaskCount = tasks.Count,
                    ResourceCount = resUsages.Count,
                    ConflictCount = resUsages.Count(r => r.PeakUsage > r.Capacity && r.Capacity > 0)
                });
            }
            catch (Exception ex)
            {
                projectSummaries.Add(new ProjectResourceSummary
                {
                    ProjectId = proj.Id,
                    ProjectName = proj.Name + " (加载失败)",
                    TaskCount = 0,
                    ResourceCount = 0,
                    ConflictCount = 0
                });
            }
        }

        // 共享资源跨项目分析
        var sharedResources = allResources.Where(r => r.ProjectId == null).ToList();
        foreach (var res in sharedResources)
        {
            var allAssignments = await ResourceService.GetAllAssignmentsAsync();
            var resAssignments = allAssignments.Where(a => a.ResourceId == res.Id).ToList();
            if (!resAssignments.Any()) continue;

            var projectNames = new List<string>();
            foreach (var a in resAssignments)
            {
                var task = (await ProjectService.GetTaskByIdAsync(a.TaskId));
                if (task != null)
                {
                    var proj = allProjects.FirstOrDefault(p => p.Id == task.ProjectId);
                    if (proj != null && !projectNames.Contains(proj.Name))
                        projectNames.Add(proj.Name);
                }
            }

            allProjectResources.Add(new AllProjectResourceItem
            {
                ResourceName = res.Name,
                ResourceType = res.Type,
                TotalCapacity = res.Quantity,
                Unit = res.Unit ?? "",
                UsedByProjects = projectNames
            });
        }

        // 渲染图表
        await RenderAllProjectsChart();
    }

    private async Task LoadSingleProjectAnalysis(int projectId)
    {
        var project = await ProjectService.GetProjectByIdAsync(projectId);
        if (project != null)
        {
            var tasks = await ProjectService.GetTasksByProjectIdAsync(projectId);
            analysisResult = AnalysisService.AnalyzeProject(project, tasks);
            await AnalyzeResourceConflicts(tasks, project);
        }
        await RenderSingleProjectChart(projectId);
    }

    private List<ResourceUsageSummary> CalculateResourceUsages(
        List<Models.ResourceAssignment> assignments,
        List<Models.TaskItem> tasks,
        List<Models.Resource> resources)
    {
        var result = new List<ResourceUsageSummary>();
        var byResource = assignments.GroupBy(a => a.ResourceId).ToDictionary(g => g.Key, g => g.ToList());
        foreach (var kv in byResource)
        {
            var resource = resources.FirstOrDefault(r => r.Id == kv.Key);
            if (resource == null) continue;
            var taskAssignments = kv.Value;
            var monthlyUsage = new Dictionary<string, decimal>();
            foreach (var asgn in taskAssignments)
            {
                var task = tasks.FirstOrDefault(t => t.Id == asgn.TaskId);
                if (task == null) continue;
                var start = task.PlanStartDate;
                var end = task.PlanEndDate;
                var cur = new DateTime(start.Year, start.Month, 1);
                while (cur <= end)
                {
                    var key = cur.ToString("yyyy-MM");
                    if (!monthlyUsage.ContainsKey(key)) monthlyUsage[key] = 0;
                    monthlyUsage[key] += asgn.Quantity;
                    cur = cur.AddMonths(1);
                }
            }
            if (!monthlyUsage.Any()) continue;
            var peakKey = monthlyUsage.OrderByDescending(x => x.Value).First().Key;
            var peakUsage = monthlyUsage[peakKey];
            result.Add(new ResourceUsageSummary
            {
                ResourceId = resource.Id,
                ResourceName = resource.Name,
                ResourceType = resource.Type,
                Unit = resource.Unit ?? "",
                Capacity = resource.Quantity,
                PeakUsage = peakUsage,
                PeakPeriod = peakKey
            });
        }
        return result.OrderByDescending(r => r.PeakUsage / Math.Max(0.001m, r.Capacity)).ToList();
    }

    private async Task AnalyzeResourceConflicts(List<Models.TaskItem> tasks, Models.Project project)
    {
        resourceUsages = new();
        resourceConflicts = new();
        var assignments = await ResourceService.GetAssignmentsByProjectAsync(project.Id);
        totalAssignments = assignments.Count;
        if (!assignments.Any()) return;
        var resources = await ResourceService.GetResourcesByProjectAsync(project.Id);
        resourceUsages = CalculateResourceUsages(assignments, tasks, resources);

        foreach (var usage in resourceUsages)
        {
            if (usage.PeakUsage > usage.Capacity && usage.Capacity > 0)
            {
                resourceConflicts.Add(new ResourceConflict
                {
                    ResourceName = usage.ResourceName,
                    ConflictPeriod = usage.PeakPeriod,
                    ConflictTasks = new()
                });
            }
        }
    }

    private async Task RenderAllProjectsChart()
    {
        await Task.Delay(100);
        var labels = projectSummaries.Select(p => p.ProjectName).ToArray();
        var taskData = projectSummaries.Select(p => p.TaskCount).ToArray();
        var conflictData = projectSummaries.Select(p => p.ConflictCount).ToArray();
        var chartData = new
        {
            labels = labels,
            datasets = new[]
            {
                new { label = "任务数", data = taskData, backgroundColor = "#1890ff" },
                new { label = "资源冲突", data = conflictData, backgroundColor = "#ff4d4f" }
            }
        };
        try { await JS.InvokeVoidAsync("renderAnalysisBarChart", "all-projects-chart", chartData); } catch {}
    }

    private async Task RenderSingleProjectChart(int projectId)
    {
        await Task.Delay(100);
        if (!resourceUsages.Any()) return;
        var labels = resourceUsages.Select(r => r.ResourceName).ToArray();
        var capacityData = resourceUsages.Select(r => (double)r.Capacity).ToArray();
        var usageData = resourceUsages.Select(r => (double)r.PeakUsage).ToArray();
        var chartData = new
        {
            labels = labels,
            datasets = new[]
            {
                new { label = "总容量", data = capacityData, backgroundColor = "#52c41a" },
                new { label = "峰值使用", data = usageData, backgroundColor = "#faad14" }
            }
        };
        try { await JS.InvokeVoidAsync("renderAnalysisBarChart", "single-project-chart", chartData); } catch {}
    }

