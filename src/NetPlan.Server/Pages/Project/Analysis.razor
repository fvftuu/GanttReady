@page "/analysis"
@page "/project/{ProjectId:int}/analysis"
@inject IAnalysisService AnalysisService
@inject IProjectService ProjectService
@inject IResourceService ResourceService
@inject IAiService AiService
@inject IJSRuntime JS

<PageTitle>计划分析 - NetPlan</PageTitle>

<div class="page-header">
    <div class="header-left">
        <select class="form-control" @bind="selectedScope" @bind:after="OnScopeChanged" style="width:220px;">
            <option value="all">🌐 所有项目（共享资源）</option>
            @foreach (var project in projects)
            {
                <option value="@("p-"+project.Id)">📁 @project.Name</option>
            }
        </select>
        <span class="page-title">进度分析报告</span>
        <button class="btn btn-default" @onclick="ShowAiSettings">🤖 AI 设置</button>
        <button class="btn btn-primary" @onclick="GenerateAiReport" disabled="@_aiLoading">
            @if (_aiLoading) { <span>⏳ 分析中...</span> } else { <span>🤖 AI 分析</span> }
        </button>
    </div>
</div>

<div class="page-body">
    <div class="page-main" style="padding:20px;">
        @if (isLoading)
        {
            <Skeleton Type="text" Count="8" />
        }
        else if (isAllProjects)
        {
            <div class="section">
                <h3>🌐 多项目横向分析</h3>
                @if (!string.IsNullOrEmpty(_aiReport))
                {
                    <div class="ai-report">@((MarkupString)_aiReport)</div>
                }
                else if (!_aiLoading)
                {
                    <p style="color:var(--text-secondary);">点击上方「AI 分析」按钮，生成多项目横向对比报告。</p>
                }
                else
                {
                    <div class="loading">⏳ AI 正在分析多项目数据...</div>
                }
            </div>
        }
        else if (analysisResult != null)
        {
            @* ===== 四张核心指标卡片（CSS 美化版） ===== *@
            <div class="analysis-metric-grid">
                <div class="analysis-metric-card">
                    <div class="metric-accent @GetProgressAccentClass(GetOverallProgress())"></div>
                    <div class="metric-label">整体完成度</div>
                    <div class="metric-value @GetProgressValueColor(GetOverallProgress())">@GetOverallProgress()%</div>
                    <div class="metric-trend @GetProgressTrendClass(GetOverallProgress())">@GetProgressStatusIcon(GetOverallProgress())</div>
                </div>
                <div class="analysis-metric-card">
                    <div class="metric-accent @GetCriticalAccentClass()"></div>
                    <div class="metric-label">关键任务完成率</div>
                    <div class="metric-value @GetCriticalValueColor()">@GetCriticalTaskRate()%</div>
                    <div class="metric-trend flat">@GetCriticalTaskDetail()</div>
                </div>
                <div class="analysis-metric-card">
                    <div class="metric-accent @GetMilestoneAccentClass()"></div>
                    <div class="metric-label">里程碑达成率</div>
                    <div class="metric-value @GetMilestoneValueColor()">@GetMilestoneRate()%</div>
                    <div class="metric-trend flat">@GetMilestoneDetail()</div>
                </div>
                <div class="analysis-metric-card">
                    <div class="metric-accent @GetVarianceAccentClass()"></div>
                    <div class="metric-label">进度偏差</div>
                    <div class="metric-value @GetVarianceColor()">@GetVarianceText()</div>
                    <div class="metric-trend @GetVarianceTrendClass()">@GetVarianceIcon()</div>
                </div>
            </div>

            @* ===== EVM 指标卡片（当有 EVM 数据时） ===== *@
            @if (_earnedValueResult != null)
            {
                var evm = _earnedValueResult;
                <div class="analysis-section-title"><span class="title-accent"></span>挣值分析指标</div>
                <div class="analysis-evms">
                    <div class="evm-item">
                        <div class="evm-label">SPI（进度绩效）</div>
                        <div class="evm-value @GetEVMColor(evm.SchedulePerformanceIndex, 1.0)">@evm.SchedulePerformanceIndex:F2</div>
                        <span class="evm-tag @GetEVMTagClass(evm.SchedulePerformanceIndex, 1.0)">@GetEVMStatus(evm.SchedulePerformanceIndex, 1.0)</span>
                    </div>
                    <div class="evm-item">
                        <div class="evm-label">CPI（成本绩效）</div>
                        <div class="evm-value @GetEVMColor(evm.CostPerformanceIndex, 1.0)">@evm.CostPerformanceIndex:F2</div>
                        <span class="evm-tag @GetEVMTagClass(evm.CostPerformanceIndex, 1.0)">@GetEVMStatus(evm.CostPerformanceIndex, 1.0)</span>
                    </div>
                    <div class="evm-item">
                        <div class="evm-label">SV（进度偏差）</div>
                        <div class="evm-value @GetEVMColor(evm.ScheduleVariance, 0)">@evm.ScheduleVariance:F0</div>
                        <span class="evm-tag @GetEVMTagClass(evm.ScheduleVariance, 0)">@(evm.ScheduleVariance >= 0 ? "提前" : "滞后")</span>
                    </div>
                    <div class="evm-item">
                        <div class="evm-label">CSI（综合绩效）</div>
                        <div class="evm-value @GetEVMColor(evm.CostScheduleIndex, 0.9)">@evm.CostScheduleIndex:F2</div>
                        <span class="evm-tag @GetEVMTagClass(evm.CostScheduleIndex, 0.9)">@(evm.CostScheduleIndex >= 0.9 ? "可控" : "关注")</span>
                    </div>
                </div>
            }

            @* ===== 阶段完成率进度条 ===== *@
            @if (_stageCompletionResult != null && _stageCompletionResult.TotalStages > 0)
            {
                <div class="analysis-section-title"><span class="title-accent"></span>阶段完成率</div>
                <div class="stage-progress-list">
                    @foreach (var s in _stageCompletionResult.Stages.Take(7))
                    {
                        var icon = s.Status == "completed" ? "✅" : s.Status == "in_progress" ? "🔄" : s.Status == "delayed" ? "🔴" : "⏳";
                        var barClass = s.Status == "completed" ? "ok" : s.Status == "in_progress" ? "warn" : s.Status == "delayed" ? "bad" : "pending";
                        <div class="stage-progress-item">
                            <span class="stage-status-icon">@icon</span>
                            <span class="stage-name">@s.StageName</span>
                            <div class="stage-bar-track">
                                <div class="stage-bar-fill @barClass" style="width:@Math.Max(1, (int)s.ActualCompletionPct)%">
                                    <span class="stage-pct">@((int)s.ActualCompletionPct)%</span>
                                </div>
                            </div>
                            @if (s.DelayDays.HasValue && s.DelayDays != 0)
                            {
                                <span class="stage-delay">@(s.DelayDays > 0 ? $"+{s.DelayDays}天" : $"{s.DelayDays}天")</span>
                            }
                        </div>
                    }
                </div>
            }

            @* ===== 关键路径摘要 ===== *@
            @if (analysisResult.CriticalPathTasks.Any())
            {
                <div class="analysis-section-title"><span class="title-accent"></span>关键路径（前 @Math.Min(analysisResult.CriticalPathTasks.Count, 8) 项）</div>
                <ul class="critical-path-list">
                    @foreach (var t in analysisResult.CriticalPathTasks.Take(8))
                    {
                        var floatStr = t.TotalFloat.HasValue ? $"{t.TotalFloat}天" : "-";
                        <li>
                            <span class="cp-code">@t.Code</span>
                            <span class="cp-name">@t.Name</span>
                            <span class="cp-dates">@t.PlanStartDate.ToString("MM/dd") → @t.PlanEndDate.ToString("MM/dd")</span>
                            <span class="cp-float">@floatStr</span>
                        </li>
                    }
                </ul>
            }

            @* ===== 里程碑时间轴 ===== *@
            @if (analysisResult.Milestones.Any())
            {
                <div class="analysis-section-title"><span class="title-accent"></span>里程碑</div>
                <div class="milestone-timeline">
                    @{
                        var today = DateTime.Today;
                    }
                    @foreach (var m in analysisResult.Milestones.OrderBy(m => m.Date))
                    {
                        var cls = m.Date <= today ? (m.Date >= today.AddDays(-30) ? "done" : "done") 
                                : (m.Date <= today.AddDays(14) ? "upcoming" : "upcoming");
                        var statusText = m.Date <= today ? "✅ 已完成" : (m.Date <= today.AddDays(14) ? "🔔 即将到期" : "📅");
                        <div class="milestone-item @cls">
                            <span class="milestone-date">@m.Date.ToString("yyyy-MM-dd")</span>
                            <span class="milestone-name">@m.Name</span>
                            <span class="milestone-status">@statusText</span>
                        </div>
                    }
                </div>
            }

            @* ===== 资源冲突表 ===== *@
            @if (resourceConflicts.Any())
            {
                <div class="analysis-section-title"><span class="title-accent"></span>资源冲突（@resourceConflicts.Count 项）</div>
                <table class="resource-conflict-table">
                    <thead>
                        <tr><th>资源名称</th><th>冲突时段</th><th>涉及任务</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var c in resourceConflicts.Take(8))
                        {
                            <tr>
                                <td class="resource-name">@c.ResourceName</td>
                                <td><span class="conflict-badge">@c.ConflictPeriod</span></td>
                                <td>@string.Join("、", c.ConflictTasks.Take(3))@(c.ConflictTasks.Count > 3 ? "…" : "")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }

            @* ===== AI 分析报告 ===== *@
            <div class="analysis-section-title" style="margin-top:24px;"><span class="title-accent"></span>AI 进度分析报告</div>
            <div class="analysis-report-section">
                @if (_aiLoading)
                {
                    <div class="report-loading">
                        <div class="loading-spinner"></div>
                        <div>AI 正在分析项目数据...</div>
                    </div>
                }
                else if (!string.IsNullOrEmpty(_aiReport))
                {
                    <div class="ai-report">@((MarkupString)_aiReport)</div>
                }
                else
                {
                    <div class="report-placeholder">点击上方「AI 分析」按钮生成进度分析报告。</div>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <p>无法加载分析数据。</p>
                <button class="btn btn-primary" @onclick="LoadAnalysis">重试</button>
            </div>
        }
    </div>
</div>

@* ========== AI 服务设置弹窗 ========== *@
@if (_showAiSettings)
{
    <div class="modal-overlay">
        <div class="modal-content" style="width:720px;height:620px;display:flex;flex-direction:column;">
            <h3>🤖 AI 服务设置</h3>
            <div style="display:flex;flex:1;gap:0;overflow:hidden;margin-top:10px;">
                <div style="width:190px;border-right:1px solid var(--border);padding-right:10px;overflow-y:auto;display:flex;flex-direction:column;flex-shrink:0;">
                    @for (int ci = 0; ci < _aiConnections.Count; ci++)
                    {
                        var c = _aiConnections[ci]; var idx = ci;
                        <div @onclick="() => _aiSelectedIdx = idx"
                             style="padding:7px 10px;border-radius:6px;cursor:pointer;margin-bottom:4px;display:flex;align-items:center;gap:6px;font-size:13px;
                                    @(idx == _aiSelectedIdx ? "background:#e6f7ff;border:1px solid #91d5ff;" : "background:transparent;border:1px solid transparent;")">
                            <span style="font-size:16px;line-height:1;">@GetProviderLogo(c.Name)</span>
                            <span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@c.Name</span>
                            @if (c.IsActive) { <span style="color:#faad14;font-size:11px;margin-left:2px;">⭐</span> }
                            @if (c.Status == "ok") { <span style="color:#52c41a;font-size:10px;">🟢</span> }
                            else if (c.Status == "fail") { <span style="color:#ff4d4f;font-size:10px;">🔴</span> }
                        </div>
                    }
                    <button class="btn btn-default btn-sm" @onclick="AddAiConnection" style="margin-top:8px;">＋ 添加连接</button>
                </div>
                <div style="flex:1;padding-left:16px;overflow-y:auto;">
                    @{ var selectedConn = _aiSelectedIdx >= 0 && _aiSelectedIdx < _aiConnections.Count ? _aiConnections[_aiSelectedIdx] : null; }
                    @if (selectedConn != null)
                    {
                        var conn = selectedConn; var idx = _aiSelectedIdx;
                        <div style="display:flex;justify-content:flex-end;gap:6px;margin-bottom:8px;">
                            <button class="btn btn-default btn-sm" @onclick="() => TestAiConnection(idx)">@(conn.Testing ? "⏳" : "🔌") 检测连接</button>
                            @if (conn.Status == "ok") { <span style="color:#52c41a;">🟢 连接正常</span> }
                            else if (conn.Status == "fail") { <span style="color:#ff4d4f;">🔴 @conn.StatusMessage</span> }
                            <div style="flex:1;"></div>
                            <button class="btn btn-default btn-sm" @onclick="() => SelectAiConnection(idx)">⭐ 设为当前</button>
                            @if (_aiConnections.Count > 1) { <button class="btn btn-danger btn-sm" @onclick="() => RemoveAiConnection(idx)">✕ 删除</button> }
                        </div>
                        <div class="form-group"><label>名称</label><input type="text" class="form-control" @bind="conn.Name" placeholder="连接名称" /></div>
                        <div class="form-group"><label>API 地址</label><input type="text" class="form-control" @bind="conn.Endpoint" placeholder="https://api.deepseek.com/v1" /></div>
                        <div class="form-group"><label>API 格式</label><select class="form-control" @bind="conn.ApiFormat"><option value="openai">OpenAI 格式</option><option value="anthropic">Anthropic 格式</option></select></div>
                        <div class="form-group">
                            <label>模型</label>
                            <input type="text" class="form-control" @bind="conn.Model" placeholder="deepseek-v4-flash" />
                        </div>
                        <div class="form-group"><label>API Key</label><input type="text" class="form-control" @bind="conn.ApiKey" placeholder="sk-..." style="font-family:monospace;" /></div>
                    }
                    else { <div style="color:var(--text-secondary);padding:40px 0;text-align:center;">选择一个连接或添加新连接</div> }
                </div>
            </div>
            <div class="dialog-actions" style="margin-top:12px;padding-top:12px;border-top:1px solid var(--border);">
                <button class="btn btn-default" @onclick="() => _showAiSettings = false">取消</button>
                <button class="btn btn-primary" @onclick="SaveAiSettings">保存</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int? ProjectId { get; set; }

    // AI 增强数据
    private string? _currentProjectName;
    private EarnedValueResult? _earnedValueResult;
    private StageCompletionResult? _stageCompletionResult;
    private ResourceSummary? _resourceSummary;

    // AI 报告
    private string? _aiReport;
    private bool _aiLoading = false;
    private bool _showAiSettings = false;
    private int _aiSelectedIdx = 0;
    private List<AiConnection> _aiConnections = new();

    private async Task GenerateAiReport()
    {
        if (_aiLoading) return;
        _aiLoading = true;
        _aiReport = null;
        StateHasChanged();

        try
        {
            var opts = BuildAiOptions();
            if (opts == null)
            {
                _aiReport = "⚠️ 请先在「AI 设置」中配置 API 连接。";
                _aiLoading = false;
                StateHasChanged();
                return;
            }

            if (isAllProjects)
            {
                await GenerateMultiProjectReport(opts);
            }
            else if (analysisResult != null)
            {
                await GenerateSingleProjectReport(opts);
            }
        }
        catch (Exception ex)
        {
            _aiReport = $"❌ AI 分析出错：{ex.Message}";
        }
        finally
        {
            _aiLoading = false;
            StateHasChanged();
        }
    }

    private async Task GenerateSingleProjectReport(AiOptions opts)
    {
        var data = BuildAiReportData();
        var prompt = ChatPromptBuilder.BuildAnalysisPrompt(data, selectedProjectId, isMultiProject: false);
        var result = await AiService.ChatAsync(prompt, data, overrideOptions: opts);
        _aiReport = result;
        await SaveAiReportToStorage();
        await JS.InvokeVoidAsync("localStorage.setItem", "ai_latest_analysis", result ?? "");
    }

    private async Task GenerateMultiProjectReport(AiOptions opts)
    {
        if (projects.Count == 0) return;
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("## 多项目概览");
        sb.AppendLine($"共 {projects.Count} 个在管项目：\n");
        sb.AppendLine("| 项目名称 | 总任务 | 完成率 | 关键任务 | 里程碑 | 资源数 | 预算成本 |");
        sb.AppendLine("|---------|------:|------:|--------:|-------:|------:|--------:|");
        foreach (var proj in projects)
        {
            try
            {
                var tasks = await ProjectService.GetTasksByProjectIdAsync(proj.Id);
                var overview = await AnalysisService.GetProjectOverviewAsync(proj.Id);
                var stage = await AnalysisService.GetStageCompletionAsync(proj.Id);
                var summary = await AnalysisService.GetResourceSummaryAsync(proj.Id);
                var total = tasks.Count;
                var done = tasks.Count(t => t.CompletionPercentage >= 100);
                var pct = total > 0 ? (done * 100.0 / total) : 0;
                var criticalDone = tasks.Count(t => t.IsCritical && t.CompletionPercentage >= 100);
                var criticalTotal = tasks.Count(t => t.IsCritical);
                var msDone = stage?.CompletedStages ?? 0;
                var msTotal = stage?.TotalStages ?? 0;
                sb.AppendLine($"| {proj.Name} | {total} | {pct:F0}% | {criticalDone}/{criticalTotal} | {msDone}/{msTotal} | {summary?.EquipmentCount ?? 0} | {summary?.TotalCost ?? 0:N0} |");
            }
            catch { }
        }
        sb.AppendLine();
        var data = sb.ToString();
        var prompt = ChatPromptBuilder.BuildAnalysisPrompt(data, null, isMultiProject: true);
        var result = await AiService.ChatAsync(prompt, data, overrideOptions: opts);
        _aiReport = result;
    }

